// Global error handler to catch and log cross-origin script errors
window.addEventListener('error', function(event) {
  if (event.message === 'Script error.' && !event.filename) {
    // Cross-origin script error — suppress to avoid noise
    console.warn('[RSM] Suppressed cross-origin script error (harmless)');
    event.preventDefault();
    return;
  }
  console.error('[RSM] Uncaught error:', event.message, 'at', event.filename, ':', event.lineno);
});

window.addEventListener('unhandledrejection', function(event) {
  console.error('[RSM] Unhandled promise rejection:', event.reason);
  event.preventDefault();
});

window.__initRSM = function() {
  try {
    window.__rsmInstance = new RSMApp();
    window.__rsmInstance.init();
  } catch (err) {
    console.error('[RSM] Initialization error:', err);
  }
};
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', () => window.__initRSM());
} else {
  window.__initRSM();
}

