  /* ═══════════════════════════════════════════════════════════════════════
     LAYOUT
     ═══════════════════════════════════════════════════════════════════════ */
  _createLayoutWorker() {
    try {
      const code = `
        self.onmessage = function(e) {
          const { nodes, edges, direction, type } = e.data;
          const positions = {};
          if (type === 'breadthfirst') {
            const adj = {}; const inDeg = {};
            nodes.forEach(n => { adj[n.id] = []; inDeg[n.id] = 0; });
            edges.forEach(e => { if(adj[e.source]) adj[e.source].push(e.target); if(inDeg[e.target]!==undefined) inDeg[e.target]++; });
            const roots = nodes.filter(n => inDeg[n.id] === 0).map(n => n.id);
            if (!roots.length && nodes.length) roots.push(nodes[0].id);
            const levels = {}; const visited = new Set();
            const queue = roots.map(r => ({ id:r, level:0 }));
            roots.forEach(r => visited.add(r));
            while (queue.length) {
              const { id, level } = queue.shift();
              levels[id] = level;
              (adj[id]||[]).forEach(child => {
                if (!visited.has(child)) { visited.add(child); queue.push({ id:child, level:level+1 }); }
              });
            }
            nodes.forEach(n => { if(levels[n.id]===undefined) levels[n.id] = 0; });
            const byLevel = {};
            Object.entries(levels).forEach(([id,lv]) => { (byLevel[lv]=byLevel[lv]||[]).push(id); });
            const spacingX = 180, spacingY = 100;
            const isDown = direction === 'top-down';
            Object.entries(byLevel).forEach(([lv, ids]) => {
              const lvNum = parseInt(lv);
              const startX = -(ids.length - 1) * spacingX / 2;
              ids.forEach((id, i) => {
                positions[id] = { x: startX + i * spacingX, y: isDown ? lvNum * spacingY : -lvNum * spacingY };
              });
            });
          }
          self.postMessage({ positions });
        };
      `;
      const blob = new Blob([code], { type: 'application/javascript' });
      return new Worker(URL.createObjectURL(blob));
    } catch(e) { return null; }
  }

  _runLayout(animate) {
    if (!this.cy) return;
    const elCount = this.cy.elements().length;

    if (this.groupMode) {
      // Custom tiered layout: preserves CI_TYPE_HIERARCHY order
      this._runTieredLayout();
    } else if (elCount > 500) {
      // For very large graphs, use preset layout with simple grid to avoid expensive algorithms
      this.cy.layout({
        name: 'breadthfirst',
        directed: true,
        spacingFactor: 0.5,
        animate: false,
        avoidOverlap: true,
        nodeDimensionsIncludeLabels: false,
      }).run();
    } else if (elCount > 150) {
      this.cy.layout({
        name: 'breadthfirst',
        directed: true,
        spacingFactor: 0.75,
        animate: false,
        avoidOverlap: true,
        nodeDimensionsIncludeLabels: true,
      }).run();
    } else {
      this.cy.layout({
        name: 'dagre',
        rankDir: this.direction === 'top-down' ? 'TB' : 'BT',
        nodeSep: 30, rankSep: 60, edgeSep: 15,
        animate: animate && elCount < 80,
        animationDuration: 300,
      }).run();
    }
    this.cy.fit(undefined, 40);
    this._scheduleMinimapUpdate();
  }

  /**
   * Custom tiered layout for group mode.
   * Places group nodes and their expanded children in strict CI_TYPE_HIERARCHY order.
   * Each tier (type) gets a fixed vertical band. Expanded groups spread their children
   * in a honeycomb-like pattern with subtle vertical offsets for visual appeal.
   */
  _runTieredLayout() {
    const hier = this.direction === 'top-down' ? CI_TYPE_HIERARCHY : [...CI_TYPE_HIERARCHY].reverse();
    const isDown = this.direction === 'top-down';

    // Collect which types are present in the current graph
    const groupNodes = this.cy.nodes('[?isGroup]');
    const typeOrder = [];
    hier.forEach(type => {
      const gNode = groupNodes.filter(n => n.data('groupType') === type);
      if (gNode.length > 0) typeOrder.push({ type, gNode: gNode[0] });
    });

    // Build layer zone lookup: which layer does each type belong to?
    const typeToLayer = {};
    LAYER_ZONES.forEach(zone => {
      zone.types.forEach(t => { typeToLayer[t] = zone.id; });
    });

    // Group typeOrder entries by layer zone for collapsed spreading
    const layerGroups = {};
    typeOrder.forEach((entry, idx) => {
      const layerId = typeToLayer[entry.type] || 'unknown';
      if (!layerGroups[layerId]) layerGroups[layerId] = [];
      layerGroups[layerId].push({ ...entry, globalIdx: idx });
    });

    // Layout parameters
    const TIER_GAP_COLLAPSED = 70;   // vertical gap between collapsed tiers
    const TIER_GAP_EXPANDED = 65;    // gap after an expanded tier
    const LAYER_GAP = 40;            // extra gap between layer zones
    const NODE_W = 165;              // horizontal spacing between expanded nodes
    const NODE_H = 52;               // vertical spacing between expanded rows
    const MAX_COLS = 10;             // max columns for expanded nodes
    const STAGGER_Y = 14;            // vertical offset for odd columns (honeycomb)
    const JITTER_X = 8;              // max random horizontal jitter
    const JITTER_Y = 5;              // max random vertical jitter
    const COLLAPSED_X_RANGE = 200;   // max horizontal offset for collapsed groups
    const COLLAPSED_JITTER_Y = 6;    // subtle vertical jitter for collapsed groups

    // Seeded pseudo-random for consistent layout across renders
    let seed = 42;
    const seededRandom = () => { seed = (seed * 16807 + 0) % 2147483647; return (seed - 1) / 2147483646; };

    let currentY = 0;
    const positions = {};
    let prevLayerId = null;

    // Process in hierarchy order, each type on its own row
    // but with horizontal offset that alternates left/right within each layer
    const layerOrder = this.direction === 'top-down'
      ? ['services', 'applications', 'infrastructure']
      : ['infrastructure', 'applications', 'services'];

    layerOrder.forEach(layerId => {
      const layerEntries = (layerGroups[layerId] || []).filter(e => {
        return typeOrder.some(t => t.type === e.type);
      });
      if (layerEntries.length === 0) return;

      // Add layer gap between zones
      if (prevLayerId !== null) currentY += LAYER_GAP;
      prevLayerId = layerId;

      // Process entries in hierarchy order, interleaving collapsed and expanded
      let collapsedIdx = 0; // track zigzag index for collapsed items within this layer
      layerEntries.forEach(entry => {
        const { type, gNode } = entry;
        const isExpanded = this.expandedGroups.has(type) && this.cy.nodes(`[!isGroup][ciType="${type}"]`).length > 0;

        if (!isExpanded) {
          // Collapsed group: own row with horizontal zigzag offset
          const direction = (collapsedIdx % 2 === 0) ? -1 : 1;
          const magnitude = (0.4 + seededRandom() * 0.6) * COLLAPSED_X_RANGE;
          const x = direction * magnitude;
          const jy = (seededRandom() - 0.5) * COLLAPSED_JITTER_Y * 2;
          const y = currentY + jy;
          positions[gNode.id()] = { x, y: isDown ? y : -y };
          currentY += TIER_GAP_COLLAPSED;
          collapsedIdx++;
        } else {
          // Expanded group: header + honeycomb children
          const childNodes = this.cy.nodes(`[!isGroup][ciType="${type}"]`);
          positions[gNode.id()] = { x: 0, y: isDown ? currentY : -currentY };
          currentY += 55;

          const childCount = childNodes.length;
          const cols = Math.min(childCount, MAX_COLS);
          const rows = Math.ceil(childCount / cols);
          const gridW = cols * NODE_W;
          const startX = -(gridW - NODE_W) / 2;

          childNodes.forEach((node, i) => {
            const col = i % cols;
            const row = Math.floor(i / cols);
            const rowStagger = (row % 2 === 1) ? NODE_W * 0.4 : 0;
            const colStagger = (col % 2 === 1) ? STAGGER_Y : 0;
            const jx = (seededRandom() - 0.5) * JITTER_X * 2;
            const jy = (seededRandom() - 0.5) * JITTER_Y * 2;

            const x = startX + col * NODE_W + rowStagger + jx;
            const baseY = currentY + row * NODE_H + colStagger + jy;

            positions[node.id()] = {
              x: x,
              y: isDown ? baseY : -baseY,
            };
          });

          currentY += rows * NODE_H + TIER_GAP_EXPANDED;
        }
      });
    });

    // Apply positions without animation for speed
    this.cy.startBatch();
    Object.entries(positions).forEach(([id, pos]) => {
      const node = this.cy.getElementById(id);
      if (node.length) node.position(pos);
    });
    this.cy.endBatch();
  }

  /* ═══════════════════════════════════════════════════════════════════════
     CY EVENTS
     ═══════════════════════════════════════════════════════════════════════ */
  _bindCyEvents() {
    const tooltip = document.createElement('div');
    tooltip.className = 'cy-tooltip';
    tooltip.style.display = 'none';
    document.body.appendChild(tooltip);

    // Node click
    this.cy.on('tap', 'node', e => {
      const node = e.target;
      const data = node.data();

      if (data.isGroup) {
        // Toggle group expansion
        const type = data.groupType;
        if (this.expandedGroups.has(type)) this.expandedGroups.delete(type);
        else this.expandedGroups.add(type);
        this._recordHistory();
        this._refresh();
        return;
      }

      // Individual CI click
      this.selectedNode = data.id;
      this.cy.nodes().removeClass('selected-node');
      node.addClass('selected-node');

      // Impact mode: run analysis from clicked node
      if (this.impactMode) {
        this._runImpactAnalysis(data.id);
      }

      // Open context panel
      this._openContextPanel(data.id);
    });

    // Background click
    this.cy.on('tap', e => {
      if (e.target === this.cy) {
        this.selectedNode = null;
        this.cy.nodes().removeClass('selected-node');
        if (!this.impactMode) {
          this.cy.elements().removeClass('faded');
        }
        this._closeContextPanel();
      }
    });

    // Hover highlight (disabled for large graphs)
    const HOVER_THRESHOLD = 300;
    this.cy.on('mouseover', 'node', e => {
      if (this.impactMode) return;
      if (this.cy.nodes().length > HOVER_THRESHOLD) return;
      const node = e.target;
      const neighborhood = node.closedNeighborhood();
      this.cy.elements().not(neighborhood).addClass('faded');
      neighborhood.connectedEdges().addClass('hover-edge');
    });
    this.cy.on('mouseout', 'node', () => {
      if (this.impactMode) return;
      this.cy.elements().removeClass('faded hover-edge');
    });

    // Right-click context menu on nodes
    this.cy.on('cxttap', 'node', e => {
      e.originalEvent.preventDefault();
      const node = e.target;
      const data = node.data();
      if (data.isGroup) return; // no context menu for groups
      this._showCtxMenu(data.id, e.originalEvent);
    });

    // Hide context menu on background click or left click
    this.cy.on('tap', () => this._hideCtxMenu());
    document.addEventListener('click', () => this._hideCtxMenu());
    document.addEventListener('keydown', e => { if (e.key === 'Escape') this._hideCtxMenu(); });

    // Prevent browser context menu on the cy container
    document.querySelector('.js-rsm-cy').addEventListener('contextmenu', e => e.preventDefault());

    // Edge tooltip
    this.cy.on('mouseover', 'edge', e => {
      const edge = e.target;
      const lbl = edge.data('label') || '';
      tooltip.textContent = lbl;
      tooltip.style.display = 'block';
      const pos = e.renderedPosition || e.position;
      const rect = this.cy.container().getBoundingClientRect();
      tooltip.style.left = (rect.left + pos.x + 10) + 'px';
      tooltip.style.top = (rect.top + pos.y - 20) + 'px';
    });
    this.cy.on('mouseout', 'edge', () => { tooltip.style.display = 'none'; });

    // Zoom label update
    this.cy.on('zoom', () => {
      const lbl = document.querySelector('.js-zoom-label');
      if (lbl) lbl.textContent = Math.round(this.cy.zoom() * 100) + '%';
      this._scheduleMinimapUpdate();
    });
    this.cy.on('pan', () => this._scheduleMinimapUpdate());
  }

  /* ═══════════════════════════════════════════════════════════════════════
     CONTEXT PANEL
     ═══════════════════════════════════════════════════════════════════════ */
  _openContextPanel(ciId) {
    const n = this._nodeIndex.get(ciId);
    if (!n) return;
    const panel = document.querySelector('.js-rsm-context-panel');
    const icon = document.querySelector('.js-ctx-icon');
    const name = document.querySelector('.js-ctx-name');
    const type = document.querySelector('.js-ctx-type');
    const body = document.querySelector('.js-ctx-body');

    icon.style.background = CI_TYPE_COLORS[n.type] + '20';
    icon.style.color = CI_TYPE_COLORS[n.type];
    icon.textContent = SHORT_NAMES[n.type] || '?';
    name.textContent = n.name;
    type.textContent = n.type;

    // Status badge class
    let statusClass = 'status-active';
    if (n.status === 'На обслуживании') statusClass = 'status-warning';
    if (n.status === 'Выведен') statusClass = 'status-danger';

    let h = '';

    // Actions
    h += `<div class="ctx-actions">
      <button class="ctx-action-btn primary" onclick="alert('Открытие карточки CI в SimpleOne')">Открыть карточку</button>
      <button class="ctx-action-btn danger js-ctx-impact-btn" data-ci="${n.id}">⚡ Impact</button>
    </div>`;

    // Attributes section
    h += `<div class="ctx-section">
      <div class="ctx-section-title">Основные атрибуты</div>
      <div class="ctx-row"><span class="ctx-label">Статус</span><span class="ctx-value"><span class="ctx-badge ${statusClass}">${this._esc(n.status)}</span></span></div>
      <div class="ctx-row"><span class="ctx-label">Окружение</span><span class="ctx-value">${this._esc(n.environment)}</span></div>
      <div class="ctx-row"><span class="ctx-label">Площадка</span><span class="ctx-value">${this._esc(n.site)}</span></div>
      <div class="ctx-row"><span class="ctx-label">SLA</span><span class="ctx-value">${this._esc(n.sla)}</span></div>
      <div class="ctx-row"><span class="ctx-label">IP-адрес</span><span class="ctx-value" style="font-family:monospace;font-size:12px">${this._esc(n.ip || '—')}</span></div>
      <div class="ctx-row"><span class="ctx-label">Hostname</span><span class="ctx-value" style="font-family:monospace;font-size:12px">${this._esc(n.hostname || '—')}</span></div>
      <div class="ctx-row"><span class="ctx-label">Теги</span><span class="ctx-value">${(n.tags || []).map(t => `<span style="display:inline-block;font-size:10px;background:${COLORS.accentBg};color:${COLORS.accent};padding:1px 6px;border-radius:3px;margin:1px 2px">${this._esc(t)}</span>`).join('') || '—'}</span></div>
      <div class="ctx-row"><span class="ctx-label">Последнее обновление</span><span class="ctx-value">${this._esc(n.lastUpdate)}</span></div>
      <div class="ctx-row"><span class="ctx-label">Источник данных</span><span class="ctx-value"><span class="ctx-badge ${n.dataSource}">${n.dataSource === 'auto' ? '⚡ Автоматический' : '✏️ Ручной'}</span></span></div>
    </div>`;

    // Owner section
    h += `<div class="ctx-section">
      <div class="ctx-section-title">Владелец / Ответственный</div>
      <div class="ctx-row"><span class="ctx-label">Ответственный</span><span class="ctx-value">${this._esc(n.responsible)}</span></div>
      <div class="ctx-row"><span class="ctx-label">Описание</span><span class="ctx-value">${this._esc(n.description)}</span></div>
    </div>`;

    // Incidents section
    h += `<div class="ctx-section">
      <div class="ctx-section-title">Открытые инциденты (${n.incidents.length})</div>`;
    if (n.incidents.length === 0) {
      h += `<div style="font-size:12px;color:${COLORS.textMuted};padding:4px 0">Нет открытых инцидентов</div>`;
    } else {
      n.incidents.forEach(inc => {
        let prClass = 'low';
        if (inc.priority === 'Критический') prClass = 'crit';
        else if (inc.priority === 'Высокий') prClass = 'high';
        else if (inc.priority === 'Средний') prClass = 'med';
        h += `<div class="incident-item">
          <div class="inc-header">
            <span class="inc-id">${this._esc(inc.id)}</span>
            <span class="inc-priority ${prClass}">${this._esc(inc.priority)}</span>
          </div>
          <div class="inc-title">${this._esc(inc.title)}</div>
          <div class="inc-date">${this._esc(inc.date)}</div>
        </div>`;
      });
    }
    h += '</div>';

    // Dependencies section
    const entry = this._adjacency[n.id];
    if (entry) {
      const parentNames = [...entry.parents].map(pid => this._nodeIndex.get(pid)?.name).filter(Boolean);
      const childNames = [...entry.children].map(cid => this._nodeIndex.get(cid)?.name).filter(Boolean);
      h += `<div class="ctx-section">
        <div class="ctx-section-title">Связи</div>
        <div class="ctx-row"><span class="ctx-label">Зависит от (${parentNames.length})</span><span class="ctx-value">${parentNames.slice(0,5).join(', ')}${parentNames.length>5?' ...':''}</span></div>
        <div class="ctx-row"><span class="ctx-label">Влияет на (${childNames.length})</span><span class="ctx-value">${childNames.slice(0,5).join(', ')}${childNames.length>5?' ...':''}</span></div>
      </div>`;
    }

    // Upstream services section (P1)
    const upstreamSvcs = this._getUpstreamServices(n.id);
    if (upstreamSvcs.length > 0) {
      h += `<div class="ctx-section">
        <div class="ctx-section-title">Зависимые сервисы (${upstreamSvcs.length})</div>
        <table class="upstream-svc-table">
          <thead><tr><th>Сервис</th><th>Тип</th><th>SLA</th><th>Глубина</th></tr></thead>
          <tbody>`;
      upstreamSvcs.forEach(svc => {
        const slaConf = SLA_HEATMAP[svc.sla] || SLA_HEATMAP['—'];
        h += `<tr class="upstream-svc-row" data-svc-class="js-${svc.id}">
          <td>${this._esc(svc.name)}</td>
          <td style="font-size:10px;color:${COLORS.textMuted}">${this._esc(svc.type)}</td>
          <td><span class="svc-sla" style="background:${slaConf.color}20;color:${slaConf.color}">${svc.sla}</span></td>
          <td style="text-align:center;color:${COLORS.textMuted}">${svc.depth}</td>
        </tr>`;
      });
      h += `</tbody></table></div>`;
    }

    body.innerHTML = h;
    panel.classList.add('open');

    // Bind impact button in context panel
    const impBtn = document.querySelector('.js-ctx-impact-btn');
    if (impBtn) {
      impBtn.addEventListener('click', () => {
        this.impactMode = true;
        this.activeMode = 'impact';
        this._updateModeUI();
        this._runImpactAnalysis(n.id);
      });
    }

    // Bind upstream service row clicks
    body.querySelectorAll('.upstream-svc-row').forEach(row => {
      row.addEventListener('click', () => {
        const svcId = row.dataset.svcId;
        if (svcId) this._openContextPanel(svcId);
      });
    });
  }

  _closeContextPanel() {
    document.querySelector('.js-rsm-context-panel')?.classList.remove('open');
  }

  /* ═══════════════════════════════════════════════════════════════════════
     MINIMAP
     ═══════════════════════════════════════════════════════════════════════ */
  _initMinimap() {
    this._minimapCanvas = document.querySelector('.js-minimap-canvas');
    if (!this._minimapCanvas) return;
    this._minimapCtx = this._minimapCanvas.getContext('2d');
    const container = document.querySelector('.js-rsm-minimap');

    // Toggle minimize
    document.querySelector('.js-minimap-toggle')?.addEventListener('click', e => {
      e.stopPropagation();
      this._minimapMinimized = !this._minimapMinimized;
      container.classList.toggle('minimized', this._minimapMinimized);
      document.querySelector('.js-minimap-toggle').textContent = this._minimapMinimized ? '+' : '−';
      if (!this._minimapMinimized) this._updateMinimap();
    });

    // Click to navigate
    container.addEventListener('mousedown', e => {
      if (this._minimapMinimized) {
        this._minimapMinimized = false;
        container.classList.remove('minimized');
        document.querySelector('.js-minimap-toggle').textContent = '−';
        this._updateMinimap();
        return;
      }
      this._minimapNavigate(e);
    });

    this._updateMinimap();
  }

  _scheduleMinimapUpdate() {
    if (this._minimapRAF) cancelAnimationFrame(this._minimapRAF);
    this._minimapRAF = requestAnimationFrame(() => this._updateMinimap());
  }

  _updateMinimap() {
    if (!this.cy || !this._minimapCtx || this._minimapMinimized) return;
    const canvas = this._minimapCanvas;
    const ctx = this._minimapCtx;
    const container = document.querySelector('.js-rsm-minimap');
    const w = container.clientWidth;
    const h = container.clientHeight - 0;
    canvas.width = w * 2; canvas.height = h * 2;
    ctx.scale(2, 2);
    ctx.clearRect(0, 0, w, h);
    ctx.fillStyle = COLORS.bg;
    ctx.fillRect(0, 0, w, h);

    const bb = this.cy.elements().boundingBox();
    if (bb.w === 0 || bb.h === 0) return;
    const pad = 10;
    const scaleX = (w - pad * 2) / bb.w;
    const scaleY = (h - pad * 2) / bb.h;
    const scale = Math.min(scaleX, scaleY);
    const offX = pad + (w - pad * 2 - bb.w * scale) / 2 - bb.x1 * scale;
    const offY = pad + (h - pad * 2 - bb.h * scale) / 2 - bb.y1 * scale;

    // Draw edges
    ctx.strokeStyle = COLORS.border;
    ctx.lineWidth = 0.5;
    ctx.globalAlpha = 0.3;
    this.cy.edges().forEach(edge => {
      const sp = edge.source().position();
      const tp = edge.target().position();
      ctx.beginPath();
      ctx.moveTo(sp.x * scale + offX, sp.y * scale + offY);
      ctx.lineTo(tp.x * scale + offX, tp.y * scale + offY);
      ctx.stroke();
    });
    ctx.globalAlpha = 1;

    // Draw nodes
    this.cy.nodes().forEach(node => {
      const pos = node.position();
      const x = pos.x * scale + offX;
      const y = pos.y * scale + offY;
      const color = node.data('color') || COLORS.accent;
      ctx.fillStyle = color;
      const sz = node.data('isGroup') ? 4 : 2;
      ctx.fillRect(x - sz, y - sz, sz * 2, sz * 2);
    });

    // Draw viewport rectangle
    const ext = this.cy.extent();
    const vx = ext.x1 * scale + offX;
    const vy = ext.y1 * scale + offY;
    const vw = ext.w * scale;
    const vh = ext.h * scale;
    ctx.strokeStyle = COLORS.accent;
    ctx.lineWidth = 1.5;
    ctx.strokeRect(vx, vy, vw, vh);
    ctx.fillStyle = COLORS.accent + '10';
    ctx.fillRect(vx, vy, vw, vh);
  }

  _minimapNavigate(e) {
    if (!this.cy) return;
    const container = document.querySelector('.js-rsm-minimap');
    const rect = container.getBoundingClientRect();
    const mx = e.clientX - rect.left;
    const my = e.clientY - rect.top;
    const w = container.clientWidth;
    const h = container.clientHeight;

    const bb = this.cy.elements().boundingBox();
    if (bb.w === 0 || bb.h === 0) return;
    const pad = 10;
    const scaleX = (w - pad * 2) / bb.w;
    const scaleY = (h - pad * 2) / bb.h;
    const scale = Math.min(scaleX, scaleY);
    const offX = pad + (w - pad * 2 - bb.w * scale) / 2 - bb.x1 * scale;
    const offY = pad + (h - pad * 2 - bb.h * scale) / 2 - bb.y1 * scale;

    const graphX = (mx - offX) / scale;
    const graphY = (my - offY) / scale;
    this.cy.center({ x: graphX, y: graphY });
  }

  /* ═══════════════════════════════════════════════════════════════════════
     HEADER & SIDEBAR BINDINGS
     ═══════════════════════════════════════════════════════════════════════ */
  _bindHeader() {
    document.querySelector('.js-zoom-in')?.addEventListener('click', () => this.cy?.zoom({ level: this.cy.zoom() * 1.3, renderedPosition: { x: this.cy.width()/2, y: this.cy.height()/2 }}));
    document.querySelector('.js-zoom-out')?.addEventListener('click', () => this.cy?.zoom({ level: this.cy.zoom() / 1.3, renderedPosition: { x: this.cy.width()/2, y: this.cy.height()/2 }}));
    document.querySelector('.js-zoom-fit')?.addEventListener('click', () => { this.cy?.fit(undefined, 40); this._scheduleMinimapUpdate(); });
    document.querySelector('.js-rsm-sidebar-toggle')?.addEventListener('click', () => document.querySelector('.js-rsm-sidebar')?.classList.toggle('collapsed'));
    document.querySelector('.js-btn-undo')?.addEventListener('click', () => this._undo());
    document.querySelector('.js-btn-redo')?.addEventListener('click', () => this._redo());
    // btn-impact removed, mode dropdown handles this now
    document.querySelector('.js-impact-exit')?.addEventListener('click', () => this._exitImpactMode());

    // Impact chain mode toggle
    document.querySelector('.js-impact-chain-toggle')?.querySelectorAll('.ict-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const mode = btn.dataset.mode;
        if (mode === this.impactChainMode) return;
        this.impactChainMode = mode;
        // Update active state
        document.querySelectorAll('#impact-chain-toggle .ict-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        // Re-run impact with current source
        if (this.impactSourceId) {
          this._runImpactAnalysis(this.impactSourceId);
        }
      });
    });
    // Export buttons
    document.querySelector('.js-btn-export-png')?.addEventListener('click', () => this._exportPNG());
    document.querySelector('.js-btn-export-csv')?.addEventListener('click', () => this._exportCSV());

    // Mode Dropdown
    const modeDropdown = document.querySelector('.js-mode-dropdown');
    const modeTrigger = document.querySelector('.js-mode-trigger');
    if (modeTrigger) {
      modeTrigger.addEventListener('click', (e) => {
        e.stopPropagation();
        modeDropdown.classList.toggle('open');
      });
    }
    // Close dropdown on outside click
    document.addEventListener('click', (e) => {
      if (!modeDropdown?.contains(e.target)) {
        modeDropdown?.classList.remove('open');
      }
    });
    // Mode option clicks
    document.querySelector('.js-mode-opt-model')?.addEventListener('click', () => {
      this._activateMode('model');
      modeDropdown?.classList.remove('open');
    });
    document.querySelector('.js-mode-opt-impact')?.addEventListener('click', () => {
      this._activateMode('impact');
      modeDropdown?.classList.remove('open');
    });

    // Diff button
    document.querySelector('.js-btn-diff')?.addEventListener('click', () => this._openSnapshotModal());
    document.querySelector('.js-diff-exit')?.addEventListener('click', () => this._exitDiffMode());
  }

  _bindSidebar() {
    const sc = document.querySelector('.js-sidebar-content');
    if (!sc) return;

    // Smart search
    const searchInput = document.querySelector('.js-rsm-search');
    const hints = document.querySelector('.js-search-hints');
    if (searchInput) {
      let searchDebounce = null;
      searchInput.addEventListener('input', () => {
        clearTimeout(searchDebounce);
        searchDebounce = setTimeout(() => {
          this._updateSearchHints(searchInput.value);
        }, 200);
      });
      searchInput.addEventListener('keydown', e => {
        if (e.key === 'Enter') {
          this.searchQuery = searchInput.value;
          hints?.classList.remove('open');
          this._invalidateFilterCache();
          this._recordHistory();
          this._refresh();
        }
        if (e.key === 'Escape') {
          hints?.classList.remove('open');
          searchInput.blur();
        }
      });
      searchInput.addEventListener('blur', () => {
        setTimeout(() => hints?.classList.remove('open'), 200);
      });
    }
    // Search hint clicks
    hints?.addEventListener('mousedown', e => {
      const item = e.target.closest('.search-hint-item');
      if (!item) return;
      e.preventDefault();
      const ciId = item.dataset.hintId;
      hints.classList.remove('open');
      // Focus on this node
      if (this.cy) {
        const node = this.cy.getElementById(ciId);
        if (node.length) {
          this.cy.animate({ center: { eles: node }, zoom: 1.5 }, { duration: 400 });
          node.addClass('highlighted');
          setTimeout(() => node.removeClass('highlighted'), 2000);
        } else {
          // Node might be in a collapsed group — expand it
          const nd = this._nodeIndex.get(ciId);
          if (nd) {
            this.expandedGroups.add(nd.type);
            this._refresh();
            setTimeout(() => {
              const n2 = this.cy?.$('#' + ciId);
              if (n2?.length) {
                this.cy.animate({ center: { eles: n2 }, zoom: 1.5 }, { duration: 400 });
                n2.addClass('highlighted');
                setTimeout(() => n2.removeClass('highlighted'), 2000);
              }
            }, 500);
          }
        }
        this._openContextPanel(ciId);
      }
    });

    // Root CI
    const rootInput = document.querySelector('.js-root-ci-input');
    const rootDropdown = document.querySelector('.js-root-ci-dropdown');
    if (rootInput) {
      rootInput.addEventListener('input', () => {
        const q = rootInput.value.toLowerCase();
        if (!q) { rootDropdown.classList.remove('open'); return; }
        const matches = this.data.nodes.filter(n => n.name.toLowerCase().includes(q) || n.type.toLowerCase().includes(q)).slice(0, 20);
        rootDropdown.innerHTML = matches.map(n => `<div class="root-ci-option" data-rid="${n.id}"><span class="opt-dot" style="background:${CI_TYPE_COLORS[n.type]}"></span><span class="opt-name">${this._esc(n.name)}</span><span class="opt-type">${this._esc(n.type)}</span></div>`).join('');
        rootDropdown.classList.toggle('open', matches.length > 0);
      });
      rootInput.addEventListener('blur', () => setTimeout(() => rootDropdown?.classList.remove('open'), 200));
      rootDropdown?.addEventListener('mousedown', e => {
        const opt = e.target.closest('.root-ci-option');
        if (!opt) return;
        e.preventDefault();
        this.rootCI = opt.dataset.rid;
        rootInput.value = '';
        rootDropdown.classList.remove('open');
        this._renderRootBadge();
        this._invalidateFilterCache();
        this._recordHistory();
        this._refresh();
        // Auto-trigger Impact when rootCI selected in impact mode
        if (this.impactMode && this.rootCI) {
          setTimeout(() => this._runImpactAnalysis(this.rootCI), 400);
        }
        // Bind close on new badge
        document.querySelector('.js-root-badge-close')?.addEventListener('click', () => {
          this.rootCI = null;
          this._renderRootBadge();
          this._invalidateFilterCache();
          this._recordHistory();
          this._refresh();
        });
      });
    }
    document.querySelector('.js-root-ci-clear')?.addEventListener('click', () => {
      this.rootCI = null;
      this._renderRootBadge();
      this._invalidateFilterCache();
      this._recordHistory();
      this._refresh();
    });
    // Bind existing badge close
    document.querySelector('.js-root-badge-close')?.addEventListener('click', () => {
      this.rootCI = null;
      this._renderRootBadge();
      this._invalidateFilterCache();
      this._recordHistory();
      this._refresh();
    });

    // Direction
    document.querySelector('.js-dir-td')?.addEventListener('click', () => {
      if (this.direction === 'top-down') return;
      this.direction = 'top-down';
      document.querySelector('.js-dir-td').classList.add('active');
      document.querySelector('.js-dir-bu').classList.remove('active');
      this._invalidateFilterCache();
      this._recordHistory();
      this._refresh();
    });
    document.querySelector('.js-dir-bu')?.addEventListener('click', () => {
      if (this.direction === 'bottom-up') return;
      this.direction = 'bottom-up';
      document.querySelector('.js-dir-bu').classList.add('active');
      document.querySelector('.js-dir-td').classList.remove('active');
      this._invalidateFilterCache();
      this._recordHistory();
      this._refresh();
    });

    // Focus Tree Mode
    document.querySelector('.js-ft-off')?.addEventListener('click', () => {
      this.focusTreeMode = false;
      document.querySelectorAll('.focus-tree-toggle button').forEach(b => b.classList.remove('active'));
      document.querySelector('.js-ft-off').classList.add('active');
      this._invalidateFilterCache();
      this._recordHistory();
      this._refresh();
    });
    document.querySelector('.js-ft-down')?.addEventListener('click', () => {
      this.focusTreeMode = 'down';
      document.querySelectorAll('.focus-tree-toggle button').forEach(b => b.classList.remove('active'));
      document.querySelector('.js-ft-down').classList.add('active');
      this._invalidateFilterCache();
      this._recordHistory();
      this._refresh();
    });
    document.querySelector('.js-ft-up')?.addEventListener('click', () => {
      this.focusTreeMode = 'up';
      document.querySelectorAll('.focus-tree-toggle button').forEach(b => b.classList.remove('active'));
      document.querySelector('.js-ft-up').classList.add('active');
      this._invalidateFilterCache();
      this._recordHistory();
      this._refresh();
    });

    // Group toggle
    document.querySelector('.js-group-toggle')?.addEventListener('change', e => {
      this.groupMode = e.target.checked;
      this._invalidateFilterCache();
      this._recordHistory();
      this._refresh();
    });

    // SLA Heatmap toggle
    document.querySelector('.js-sla-heatmap-toggle')?.addEventListener('change', e => {
      this.slaHeatmap = e.target.checked;
      this._buildSidebar();
      this._bindSidebar();
      this._applySlaHeatmap();
    });

    // Layer zones
    sc.querySelectorAll('[data-zone]').forEach(cb => {
      cb.addEventListener('change', e => {
        const zoneId = e.target.dataset.zone;
        if (e.target.checked) this.collapsedLayers.delete(zoneId);
        else this.collapsedLayers.add(zoneId);
        this._invalidateFilterCache();
        this._recordHistory();
        this._refresh();
      });
    });

    // Data source filter
    sc.querySelectorAll('.ds-chip').forEach(chip => {
      chip.addEventListener('click', () => {
        this.dataSourceFilter = chip.dataset.ds;
        sc.querySelectorAll('.ds-chip').forEach(c => c.classList.remove('active'));
        chip.classList.add('active');
        this._invalidateFilterCache();
        this._recordHistory();
        this._refresh();
      });
    });

    // Filter checkboxes (with debounce)
    sc.querySelectorAll('[data-fid]').forEach(cb => {
      cb.addEventListener('change', e => {
        const fid = e.target.dataset.fid;
        const val = e.target.dataset.val;
        const map = {'f-types':'types','f-stat':'statuses','f-site':'sites','f-env':'environments'};
        const setName = map[fid];
        if (!setName) return;
        if (e.target.checked) this.filters[setName].add(val);
        else this.filters[setName].delete(val);
        clearTimeout(this._filterDebounce);
        this._filterDebounce = setTimeout(() => {
          this._invalidateFilterCache();
          this._recordHistory();
          this._refresh();
        }, 300);
      });
    });

    // Section collapse
    sc.querySelectorAll('.section-title').forEach(title => {
      title.addEventListener('click', () => {
        const sec = title.dataset.sec;
        if (!sec) return;
        const body = sc.querySelector(`.section-body[data-sec="${sec}"]`);
        const arrow = title.querySelector('.arrow');
        if (body) body.classList.toggle('hidden');
        if (arrow) arrow.classList.toggle('collapsed');
      });
    });

    // Presets
    this._bindPresets();

    // Reset
    document.querySelector('.js-reset-filters')?.addEventListener('click', () => {
      this.filters.types = new Set(CI_TYPE_HIERARCHY);
      this.filters.statuses = new Set(STATUSES);
      this.filters.sites = new Set(SITES);
      this.filters.environments = new Set(ENVIRONMENTS);
      this.rootCI = null;
      this.searchQuery = '';
      this.collapsedLayers.clear();
      this.dataSourceFilter = 'all';
      this.expandedGroups.clear();
      this.groupMode = true;
      this._invalidateFilterCache();
      this._buildSidebar();
      this._bindSidebar();
      this._recordHistory();
      this._refresh();
    });
  }

  _bindPresets() {
    const sc = document.querySelector('.js-sidebar-content');
    if (!sc) return;

    // Save current
    document.querySelector('.js-save-btn')?.addEventListener('click', () => this._showSaveModal());

    // Load preset on click (but not on action buttons)
    sc.querySelectorAll('.preset-item').forEach(item => {
      item.addEventListener('click', e => {
        if (e.target.closest('.preset-action') || e.target.closest('.preset-actions')) return;
        const pi = parseInt(item.dataset.pi);
        const allPresets = [...DEFAULT_PRESETS, ...this.savedFilters];
        const preset = allPresets[pi];
        if (!preset) return;
        this._applyPreset(preset);
      });
    });

    // Preset action buttons
    sc.querySelectorAll('.preset-action').forEach(btn => {
      btn.addEventListener('click', e => {
        e.stopPropagation();
        const action = btn.dataset.action;
        const idx = parseInt(btn.dataset.sd);
        if (idx < 0 || idx >= this.savedFilters.length) return;

        if (action === 'delete') {
          this._showConfirmModal('Удалить пресет?', `Пресет \xab${this.savedFilters[idx].name}\xbb будет удал\u0451н безвозвратно.`, () => {
            this.savedFilters.splice(idx, 1);
            this._saveSaved();
            this._renderPresets();
            this._bindPresets();
            this._showToast('Пресет удал\u0451н');
          });
        } else if (action === 'rename') {
          this._showRenameModal(idx);
        } else if (action === 'share') {
          this._sharePreset(idx);
        }
      });
    });
  }

  _showConfirmModal(title, message, onConfirm) {
    const overlay = document.createElement('div');
    overlay.className = 'modal-overlay';
    overlay.innerHTML = `
      <div class="modal-box">
        <h3>${title}</h3>
        <p style="font-size:13px;color:${COLORS.textSecondary};margin-bottom:16px">${message}</p>
        <div class="modal-actions">
          <button class="btn-cancel js-confirm-cancel">Отмена</button>
          <button class="btn-save js-confirm-ok" style="background:${COLORS.danger}">Удалить</button>
        </div>
      </div>
    `;
    document.body.appendChild(overlay);
    document.querySelector('.js-confirm-cancel').addEventListener('click', () => overlay.remove());
    overlay.addEventListener('click', e => { if (e.target === overlay) overlay.remove(); });
    document.querySelector('.js-confirm-ok').addEventListener('click', () => {
      overlay.remove();
      onConfirm();
    });
  }

  _showRenameModal(idx) {
    const preset = this.savedFilters[idx];
    if (!preset) return;
    const overlay = document.createElement('div');
    overlay.className = 'modal-overlay';
    overlay.innerHTML = `
      <div class="modal-box">
        <h3>Переименовать пресет</h3>
        <input type="text" class="js-rename-name" value="${this._esc(preset.name)}" placeholder="Название">
        <textarea class="js-rename-desc" placeholder="Описание (необязательно)">${this._esc(preset.desc || '')}</textarea>
        <div class="modal-actions">
          <button class="btn-cancel js-rename-cancel">Отмена</button>
          <button class="btn-save js-rename-save">Сохранить</button>
        </div>
      </div>
    `;
    document.body.appendChild(overlay);
    document.querySelector('.js-rename-name').focus();
    document.querySelector('.js-rename-name').select();
    document.querySelector('.js-rename-cancel').addEventListener('click', () => overlay.remove());
    overlay.addEventListener('click', e => { if (e.target === overlay) overlay.remove(); });
    document.querySelector('.js-rename-save').addEventListener('click', () => {
      const newName = document.querySelector('.js-rename-name').value.trim();
      const newDesc = document.querySelector('.js-rename-desc').value.trim();
      if (!newName) { document.querySelector('.js-rename-name').style.borderColor = COLORS.danger; return; }
      preset.name = newName;
      preset.desc = newDesc;
      this._saveSaved();
      overlay.remove();
      this._renderPresets();
      this._bindPresets();
      this._showToast('Пресет переименован');
    });
  }

  _sharePreset(idx) {
    const preset = this.savedFilters[idx];
    if (!preset) return;
    // Generate a shareable URL with preset encoded in hash
    const presetData = {
      name: preset.name,
      desc: preset.desc || '',
      filters: preset.filters,
      direction: preset.direction,
      groupMode: preset.groupMode,
    };
    const encoded = btoa(unescape(encodeURIComponent(JSON.stringify(presetData))));
    const shareUrl = window.location.origin + window.location.pathname + '#preset=' + encoded;
    navigator.clipboard.writeText(shareUrl).then(() => {
      this._showToast('Ссылка на пресет скопирована в буфер');
    }).catch(() => {
      // Fallback: show URL in a modal
      this._showShareUrlModal(shareUrl);
    });
  }

  _showShareUrlModal(url) {
    const overlay = document.createElement('div');
    overlay.className = 'modal-overlay';
    overlay.innerHTML = `
      <div class="modal-box">
        <h3>Ссылка на пресет</h3>
        <p style="font-size:12px;color:${COLORS.textSecondary};margin-bottom:8px">Скопируйте ссылку и отправьте коллеге:</p>
        <input type="text" class="js-share-url" value="${this._esc(url)}" readonly style="font-size:11px;font-family:monospace">
        <div class="modal-actions">
          <button class="btn-save js-share-copy">Копировать</button>
          <button class="btn-cancel js-share-close">Закрыть</button>
        </div>
      </div>
    `;
    document.body.appendChild(overlay);
    document.querySelector('.js-share-url').select();
    document.querySelector('.js-share-close').addEventListener('click', () => overlay.remove());
    overlay.addEventListener('click', e => { if (e.target === overlay) overlay.remove(); });
    document.querySelector('.js-share-copy').addEventListener('click', () => {
      document.querySelector('.js-share-url').select();
      document.execCommand('copy');
      this._showToast('Скопировано');
      overlay.remove();
    });
  }

  _loadSharedPresetFromURL() {
    const hash = window.location.hash;
    if (!hash.startsWith('#preset=')) return;
    try {
      const encoded = hash.slice(8);
      const json = decodeURIComponent(escape(atob(encoded)));
      const preset = JSON.parse(json);
      if (preset && preset.name && preset.filters) {
        // Apply the shared preset
        this._applyPreset(preset);
        this._showToast(`Пресет \xab${preset.name}\xbb примен\u0451н из ссылки`);
        // Offer to save it
        setTimeout(() => {
          this._showSaveSharedPresetModal(preset);
        }, 1000);
      }
    } catch(e) {
      console.warn('[RSM] Failed to load shared preset from URL:', e);
    }
    // Clean up the hash
    history.replaceState(null, '', window.location.pathname + window.location.search);
  }

  _showSaveSharedPresetModal(preset) {
    const overlay = document.createElement('div');
    overlay.className = 'modal-overlay';
    overlay.innerHTML = `
      <div class="modal-box">
        <h3>Сохранить пресет?</h3>
        <p style="font-size:13px;color:${COLORS.textSecondary};margin-bottom:12px">Пресет \xab${this._esc(preset.name)}\xbb был примен\u0451н из ссылки. Сохранить его в ваши пресеты?</p>
        <div class="modal-actions">
          <button class="btn-cancel js-shared-skip">Нет, спасибо</button>
          <button class="btn-save js-shared-save">Сохранить</button>
        </div>
      </div>
    `;
    document.body.appendChild(overlay);
    document.querySelector('.js-shared-skip').addEventListener('click', () => overlay.remove());
    overlay.addEventListener('click', e => { if (e.target === overlay) overlay.remove(); });
    document.querySelector('.js-shared-save').addEventListener('click', () => {
      this.savedFilters.push({
        name: preset.name,
        desc: preset.desc || '',
        filters: preset.filters,
        direction: preset.direction,
        groupMode: preset.groupMode,
        shared: true,
        owner: 'Получен по ссылке',
      });
      this._saveSaved();
      overlay.remove();
      this._renderPresets();
      this._bindPresets();
      this._showToast('Пресет сохран\u0451н');
    });
  }

  _applyPreset(preset) {
    if (preset.filters) {
      this.filters.types = new Set(preset.filters.types || CI_TYPE_HIERARCHY);
      this.filters.statuses = new Set(preset.filters.statuses || STATUSES);
      this.filters.sites = new Set(preset.filters.sites || SITES);
      this.filters.environments = new Set(preset.filters.environments || ENVIRONMENTS);
    }
    if (preset.direction) this.direction = preset.direction;
    if (preset.groupMode !== undefined) this.groupMode = preset.groupMode;
    this._invalidateFilterCache();
    this._buildSidebar();
    this._bindSidebar();
    this._recordHistory();
    this._refresh();
  }

  _showSaveModal() {
    const overlay = document.createElement('div');
    overlay.className = 'modal-overlay';
    overlay.innerHTML = `
      <div class="modal-box">
        <h3>Сохранить пресет фильтров</h3>
        <input type="text" class="js-sf-name" placeholder="Название пресета">
        <textarea class="js-sf-desc" placeholder="Описание (необязательно)"></textarea>
        <div class="modal-actions">
          <button class="btn-cancel js-sf-cancel">Отмена</button>
          <button class="btn-save js-sf-save">Сохранить</button>
        </div>
      </div>
    `;
    document.body.appendChild(overlay);
    document.querySelector('.js-sf-name').focus();
    document.querySelector('.js-sf-cancel').addEventListener('click', () => overlay.remove());
    overlay.addEventListener('click', e => { if (e.target === overlay) overlay.remove(); });
    document.querySelector('.js-sf-save').addEventListener('click', () => {
      const name = document.querySelector('.js-sf-name').value.trim();
      if (!name) { document.querySelector('.js-sf-name').style.borderColor = COLORS.danger; return; }
      const desc = document.querySelector('.js-sf-desc').value.trim();
      this.savedFilters.push({
        name, desc,
        filters: {
          types: [...this.filters.types],
          statuses: [...this.filters.statuses],
          sites: [...this.filters.sites],
          environments: [...this.filters.environments],
        },
        direction: this.direction,
        groupMode: this.groupMode,
      });
      this._saveSaved();
      overlay.remove();
      this._renderPresets();
      this._bindPresets();
    });
  }

  /* ═══════════════════════════════════════════════════════════════════════
     REFRESH & UTILS
     ═══════════════════════════════════════════════════════════════════════ */
  _refresh() {
    if (!this.cy) return;
    this._invalidateFilterCache();
    if (this.impactMode) this._exitImpactMode();

    // Debounce rapid successive refreshes
    if (this._refreshRAF) cancelAnimationFrame(this._refreshRAF);

    const showLoading = () => {
      const main = document.querySelector('.js-rsm-main');
      let overlay = document.querySelector('.js-rsm-loading');
      if (!overlay) {
        overlay = document.createElement('div');
        overlay.classList.add('js-rsm-loading');
        overlay.style.cssText = `position:absolute;top:0;left:0;right:0;bottom:0;background:rgba(244,245,247,.85);z-index:60;display:flex;align-items:center;justify-content:center;font-size:14px;color:${COLORS.textSecondary};font-family:${FONT}`;
        overlay.textContent = 'Обновление модели...';
        main.appendChild(overlay);
      }
      overlay.style.display = 'flex';
    };
    const hideLoading = () => {
      const overlay = document.querySelector('.js-rsm-loading');
      if (overlay) overlay.style.display = 'none';
    };

    // Hide Quick Actions when graph is being used, show when no root CI
    if (this.rootCI) this._hideQuickActions(); else this._showQuickActions();

    showLoading();
    this._refreshRAF = requestAnimationFrame(() => {
      this._refreshRAF = null;
      this.cy.startBatch();
      this.cy.elements().remove();
      const els = this._buildElements();
      this.cy.add(els);
      this.cy.endBatch();
      this._runLayout(false);
      this._updateStats();
      hideLoading();
    });
  }

  _updateStats() {
    const vis = this._getFiltered();
    document.querySelector('.js-stat-nodes').textContent = this.data.nodes.length;
    document.querySelector('.js-stat-edges').textContent = this.data.edges.length;
    document.querySelector('.js-stat-visible').textContent = vis.length;
  }

  _loadSaved() {
    try { return JSON.parse(localStorage.getItem('rsm_saved_filters') || '[]'); } catch { return []; }
  }
  _saveSaved() {
    try { localStorage.setItem('rsm_saved_filters', JSON.stringify(this.savedFilters)); } catch {}
  }

  _esc(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

  /* ═══════════════════════════════════════════════════════════════════════
     RIGHT-CLICK CONTEXT MENU
     ═══════════════════════════════════════════════════════════════════════ */

  _showCtxMenu(ciId, mouseEvent) {
    const menu = document.querySelector('.js-rsm-ctx-menu');
    const n = this._nodeIndex.get(ciId);
    if (!menu || !n) return;

    // Store current CI for menu actions
    this._ctxMenuCiId = ciId;

    // Update menu header
    document.querySelector('.js-ctx-menu-title').textContent = n.name + ' (' + n.type + ')';

    // Update incident count hint
    const incCount = document.querySelector('.js-ctx-menu-inc-count');
    incCount.textContent = n.incidents.length > 0 ? n.incidents.length + ' шт.' : 'нет';

    // Position the menu at mouse coordinates relative to #rsm-main
    const main = document.querySelector('.js-rsm-main');
    const rect = main.getBoundingClientRect();
    let x = mouseEvent.clientX - rect.left;
    let y = mouseEvent.clientY - rect.top;

    // Show menu first to measure it
    menu.style.left = '0px';
    menu.style.top = '0px';
    menu.classList.add('visible');

    // Adjust if menu goes off-screen
    const mw = menu.offsetWidth;
    const mh = menu.offsetHeight;
    if (x + mw > rect.width) x = rect.width - mw - 8;
    if (y + mh > rect.height) y = rect.height - mh - 8;
    if (x < 0) x = 8;
    if (y < 0) y = 8;

    menu.style.left = x + 'px';
    menu.style.top = y + 'px';
  }

  _hideCtxMenu() {
    const menu = document.querySelector('.js-rsm-ctx-menu');
    if (menu) menu.classList.remove('visible');
  }

  _bindCtxMenuActions() {
    // Build model from this CI
    document.querySelector('.js-ctx-menu-build-from')?.addEventListener('click', (e) => {
      e.stopPropagation();
      const ciId = this._ctxMenuCiId;
      if (!ciId) return;
      this._hideCtxMenu();
      this.rootCI = ciId;
      this._renderRootBadge();
      this._invalidateFilterCache();
      this._recordHistory();
      this._refresh();
      // Update the root CI input display
      const n = this._nodeIndex.get(ciId);
      if (n) {
        const rootInput = document.querySelector('.js-root-ci-input');
        if (rootInput) rootInput.value = '';
      }
    });

    // Show related incidents
    document.querySelector('.js-ctx-menu-incidents')?.addEventListener('click', (e) => {
      e.stopPropagation();
      const ciId = this._ctxMenuCiId;
      if (!ciId) return;
      this._hideCtxMenu();
      // Open context panel and scroll to incidents section
      this._openContextPanel(ciId);
      // Scroll to incidents after panel opens
      setTimeout(() => {
        const panel = document.querySelector('.js-rsm-context-panel');
        if (!panel) return;
        const sections = panel.querySelectorAll('.ctx-section-title');
        for (const sec of sections) {
          if (sec.textContent.includes('инцидент') || sec.textContent.includes('Инцидент')) {
            sec.scrollIntoView({ behavior: 'smooth', block: 'start' });
            // Flash highlight
            sec.parentElement.style.background = COLORS.warningBg;
            setTimeout(() => { sec.parentElement.style.background = ''; }, 1500);
            break;
          }
        }
      }, 350);
    });

    // Impact analysis from context menu
    document.querySelector('.js-ctx-menu-impact')?.addEventListener('click', (e) => {
      e.stopPropagation();
      const ciId = this._ctxMenuCiId;
      if (!ciId) return;
      this._hideCtxMenu();
      this.impactMode = true;
      this.activeMode = 'impact';
      this._updateModeUI();
      this._runImpactAnalysis(ciId);
    });

    // Show details (open context panel)
    document.querySelector('.js-ctx-menu-details')?.addEventListener('click', (e) => {
      e.stopPropagation();
      const ciId = this._ctxMenuCiId;
      if (!ciId) return;
      this._hideCtxMenu();
      this._openContextPanel(ciId);
    });

    // Copy CI ID
    document.querySelector('.js-ctx-menu-copy-id')?.addEventListener('click', (e) => {
      e.stopPropagation();
      const ciId = this._ctxMenuCiId;
      const n = this._nodeIndex.get(ciId);
      if (!n) return;
      this._hideCtxMenu();
      const text = n.name + ' | ' + n.type + ' | ' + n.id;
      navigator.clipboard.writeText(text).then(() => {
        // Show brief toast
        this._showToast('Скопировано: ' + n.name);
      }).catch(() => {
        this._showToast('Не удалось скопировать');
      });
    });
  }

  /* ═══════════════════════════════════════════════════════════════════════
     SLA HEATMAP
     ═══════════════════════════════════════════════════════════════════════ */
  _applySlaHeatmap() {
    if (!this.cy) return;
    this.cy.startBatch();
    if (this.slaHeatmap) {
      this.cy.nodes('[!isGroup]').forEach(node => {
        const ciId = node.id();
        const nd = this._nodeIndex.get(ciId);
        if (!nd) return;
        const slaConf = SLA_HEATMAP[nd.sla] || SLA_HEATMAP['—'];
        node.style({
          'border-color': slaConf.border,
          'border-width': 3,
          'background-color': slaConf.color + '20',
        });
      });
      // Also color group nodes by most critical SLA in group
      this.cy.nodes('[?isGroup]').forEach(node => {
        const groupType = node.data('groupType');
        const nodesOfType = this.data.nodes.filter(n => n.type === groupType);
        const slaOrder = ['99.99%','99.95%','99.9%','99.5%','99%','—'];
        let bestSla = '—';
        nodesOfType.forEach(n => {
          const idx = slaOrder.indexOf(n.sla);
          if (idx >= 0 && idx < slaOrder.indexOf(bestSla)) bestSla = n.sla;
        });
        const slaConf = SLA_HEATMAP[bestSla] || SLA_HEATMAP['—'];
        node.style({
          'border-color': slaConf.border,
          'border-width': 3,
          'background-color': slaConf.color + '15',
        });
      });
    } else {
      // Reset to default styles
      this.cy.nodes('[!isGroup]').forEach(node => {
        const ciId = node.id();
        const nd = this._nodeIndex.get(ciId);
        const isRoot = nd && nd.id === this.rootCI;
        node.style({
          'border-color': isRoot ? COLORS.accent : (CI_TYPE_COLORS[nd?.type] || COLORS.border),
          'border-width': isRoot ? 3 : 2,
          'background-color': isRoot ? COLORS.accentBg : '#fff',
        });
      });
      this.cy.nodes('[?isGroup]').forEach(node => {
        node.style({
          'border-color': node.data('color') || COLORS.groupBorder,
          'border-width': 2,
          'background-color': (node.data('color') || COLORS.groupBg) + '15',
        });
      });
    }
    this.cy.endBatch();
  }

  /* ═══════════════════════════════════════════════════════════════════════
     EXPORT (PNG / CSV)
     ═══════════════════════════════════════════════════════════════════════ */
  _exportPNG() {
    if (!this.cy) return;
    const png = this.cy.png({ output: 'blob', bg: COLORS.bg, scale: 2, full: true });
    const url = URL.createObjectURL(png);
    const a = document.createElement('a');
    a.href = url;
    a.download = `rsm_model_${new Date().toISOString().slice(0,10)}.png`;
    a.click();
    URL.revokeObjectURL(url);
    this._showToast('Граф экспортирован в PNG');
  }

  _exportCSV() {
    const vis = this._getFiltered();
    const rows = [['ID','Имя','Тип','Статус','SLA','IP','Hostname','Площадка','Окружение','Ответственный','Инцидентов','Теги']];
    vis.forEach(n => {
      rows.push([
        n.id, n.name, n.type, n.status, n.sla,
        n.ip || '', n.hostname || '', n.site, n.environment,
        n.responsible, n.incidentCount,
        (n.tags || []).join(';'),
      ]);
    });
    // If in impact mode, add impact-specific columns
    if (this.impactMode && this.impactAffected.size > 0) {
      rows[0].push('Impact_Depth', 'Impact_Source');
      rows.slice(1).forEach((row, idx) => {
        const ciId = vis[idx].id;
        if (this.impactAffected.has(ciId)) {
          row.push('affected', this.impactSourceId || '');
        } else if (ciId === this.impactSourceId) {
          row.push('source', '');
        } else {
          row.push('', '');
        }
      });
    }
    const csvContent = rows.map(r => r.map(c => `"${String(c).replace(/"/g,'""')}"`).join(',')).join('\n');
    const BOM = '\uFEFF';
    const blob = new Blob([BOM + csvContent], { type: 'text/csv;charset=utf-8' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `rsm_data_${new Date().toISOString().slice(0,10)}.csv`;
    a.click();
    URL.revokeObjectURL(url);
    this._showToast(`Экспортировано ${vis.length} CI в CSV`);
  }

  /* ═══════════════════════════════════════════════════════════════════════
     IMPACT PATH NAVIGATOR
     ═══════════════════════════════════════════════════════════════════════ */
  _buildImpactPaths(bfsParent, sourceId) {
    // Find all "leaf" affected nodes (services at the top of the chain)
    const paths = [];
    const serviceTypes = new Set(['ИТ-сервис', 'ИТ-система']);
    const affected = [...this.impactAffected];
    
    // Prioritize service-level nodes, then sort by depth
    const leafNodes = affected.filter(id => {
      const nd = this._nodeIndex.get(id);
      return nd && serviceTypes.has(nd.type);
    });
    // If no services found, use all affected nodes
    const targets = leafNodes.length > 0 ? leafNodes : affected.slice(0, 20);
    
    targets.forEach(targetId => {
      const chain = [];
      let cur = targetId;
      let depth = 0;
      while (cur && cur !== sourceId && depth < IMPACT_MAX_DEPTH) {
        chain.unshift(cur);
        cur = bfsParent.get(cur);
        depth++;
      }
      if (cur === sourceId) {
        chain.unshift(sourceId);
        const nd = this._nodeIndex.get(targetId);
        paths.push({
          targetId,
          targetName: nd?.name || targetId,
          targetType: nd?.type || '',
          targetSla: nd?.sla || '—',
          chain,
          depth: chain.length - 1,
        });
      }
    });
    
    // Sort: services first, then by depth descending
    paths.sort((a, b) => {
      const aIsSvc = serviceTypes.has(a.targetType) ? 0 : 1;
      const bIsSvc = serviceTypes.has(b.targetType) ? 0 : 1;
      if (aIsSvc !== bIsSvc) return aIsSvc - bIsSvc;
      return b.depth - a.depth;
    });
    
    return paths.slice(0, 50); // Limit to 50 paths
  }

  _showImpactPaths(bfsParent, sourceId) {
    this._impactPaths = this._buildImpactPaths(bfsParent, sourceId);
    this._impactCurrentPath = -1;
    this._impactBfsParent = bfsParent;
    
    const panel = document.querySelector('.js-rsm-impact-paths');
    const list = document.querySelector('.js-impact-paths-list');
    const countEl = document.querySelector('.js-impact-paths-count');
    if (!panel || !list) return;
    
    if (this._impactPaths.length === 0) {
      panel.classList.remove('visible');
      return;
    }
    
    countEl.textContent = `(${this._impactPaths.length})`;
    
    let h = '';
    this._impactPaths.forEach((p, idx) => {
      const slaConf = SLA_HEATMAP[p.targetSla] || SLA_HEATMAP['—'];
      const chainNames = p.chain.map(id => {
        const nd = this._nodeIndex.get(id);
        return nd ? nd.name : id;
      });
      h += `<div class="impact-path-item" data-path-idx="${idx}">
        <div class="path-target">
          <span>${this._esc(p.targetName)}</span>
          <span class="path-sla" style="background:${slaConf.color}20;color:${slaConf.color}">${p.targetSla}</span>
        </div>
        <div class="path-chain">${chainNames.map(n => this._esc(n)).join('<span class="path-arrow">→</span>')}</div>
        <div class="path-depth">Глубина: ${p.depth}</div>
      </div>`;
    });
    list.innerHTML = h;
    panel.classList.add('visible');
    
    // Bind path clicks
    list.querySelectorAll('.impact-path-item').forEach(item => {
      item.addEventListener('click', () => {
        const idx = parseInt(item.dataset.pathIdx);
        this._highlightImpactPath(idx);
      });
    });
    
    // Bind nav buttons
    document.querySelector('.js-path-prev')?.addEventListener('click', () => {
      if (this._impactCurrentPath > 0) this._highlightImpactPath(this._impactCurrentPath - 1);
    });
    document.querySelector('.js-path-next')?.addEventListener('click', () => {
      if (this._impactCurrentPath < this._impactPaths.length - 1) this._highlightImpactPath(this._impactCurrentPath + 1);
    });
    document.querySelector('.js-impact-paths-close')?.addEventListener('click', () => {
      panel.classList.remove('visible');
    });
  }

  _highlightImpactPath(idx) {
    if (!this._impactPaths[idx] || !this.cy) return;
    this._impactCurrentPath = idx;
    const path = this._impactPaths[idx];
    
    // Update active state in list
    document.querySelectorAll('.impact-path-item').forEach(el => el.classList.remove('active'));
    const activeItem = document.querySelector(`.impact-path-item[data-path-idx="${idx}"]`);
    if (activeItem) {
      activeItem.classList.add('active');
      activeItem.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
    
    // Update nav buttons
    const prevBtn = document.querySelector('.js-path-prev');
    const nextBtn = document.querySelector('.js-path-next');
    if (prevBtn) prevBtn.disabled = idx <= 0;
    if (nextBtn) nextBtn.disabled = idx >= this._impactPaths.length - 1;
    
    // Highlight the path nodes and edges in the graph
    this.cy.startBatch();
    // First, reset all to impact-faded
    this.cy.elements().addClass('impact-faded').removeClass('impact-source impact-affected impact-affected-deep');
    this.cy.edges('.impact-chain-edge').removeClass('impact-faded');
    
    // Highlight nodes in this path
    const pathSet = new Set(path.chain);
    path.chain.forEach((ciId, i) => {
      const node = this.cy.getElementById(ciId);
      if (node.length) {
        node.removeClass('impact-faded');
        if (i === 0) node.addClass('impact-source');
        else if (i === path.chain.length - 1) node.addClass('impact-affected');
        else node.addClass('impact-affected-deep');
      }
      // Also handle group nodes
      const nd = this._nodeIndex.get(ciId);
      if (nd && this.groupMode && !this.expandedGroups.has(nd.type)) {
        const gNode = this.cy.getElementById('g_' + nd.type);
        if (gNode.length) {
          gNode.removeClass('impact-faded');
          if (i === 0) gNode.addClass('impact-source');
          else gNode.addClass('impact-affected');
        }
      }
    });
    
    // Highlight edges between consecutive path nodes
    for (let i = 0; i < path.chain.length - 1; i++) {
      const src = path.chain[i];
      const tgt = path.chain[i + 1];
      // Check both regular and chain edges
      this.cy.edges().forEach(edge => {
        const eSrc = edge.source().id();
        const eTgt = edge.target().id();
        const srcMatch = eSrc === src || (this.groupMode && eSrc === 'g_' + (this._nodeIndex.get(src)?.type));
        const tgtMatch = eTgt === tgt || (this.groupMode && eTgt === 'g_' + (this._nodeIndex.get(tgt)?.type));
        if (srcMatch && tgtMatch) {
          edge.removeClass('impact-faded').addClass('impact-edge');
        }
      });
    }
    
    this.cy.endBatch();
    
    // Animate to fit the path nodes
    const pathNodes = this.cy.collection();
    path.chain.forEach(ciId => {
      const node = this.cy.getElementById(ciId);
      if (node.length) pathNodes.merge(node);
      const nd = this._nodeIndex.get(ciId);
      if (nd && this.groupMode && !this.expandedGroups.has(nd.type)) {
        const gNode = this.cy.getElementById('g_' + nd.type);
        if (gNode.length) pathNodes.merge(gNode);
      }
    });
    if (pathNodes.length > 0) {
      this.cy.animate({ fit: { eles: pathNodes, padding: 80 } }, { duration: 400 });
    }
  }

  _hideImpactPaths() {
    const panel = document.querySelector('.js-rsm-impact-paths');
    if (panel) panel.classList.remove('visible');
    this._impactPaths = [];
    this._impactCurrentPath = -1;
  }

  /* ═══════════════════════════════════════════════════════════════════════
     UPSTREAM SERVICES (for context panel)
     ═══════════════════════════════════════════════════════════════════════ */
  _getUpstreamServices(ciId) {
    // BFS upward from ciId to find all ИТ-сервис / ИТ-система that depend on this CI
    const visited = new Set([ciId]);
    const queue = [ciId];
    const services = [];
    const serviceTypes = new Set(['ИТ-сервис', 'ИТ-система']);
    let depth = 0;
    const maxDepth = 15;
    const depthMap = new Map([[ciId, 0]]);
    
    while (queue.length && depth < maxDepth) {
      const cur = queue.shift();
      const curDepth = depthMap.get(cur) || 0;
      const entry = this._adjacency[cur];
      if (!entry) continue;
      for (const parent of entry.parents) {
        if (!visited.has(parent)) {
          visited.add(parent);
          depthMap.set(parent, curDepth + 1);
          const nd = this._nodeIndex.get(parent);
          if (nd && serviceTypes.has(nd.type)) {
            services.push({ id: parent, name: nd.name, type: nd.type, sla: nd.sla, depth: curDepth + 1 });
          }
          queue.push(parent);
        }
      }
      depth = curDepth + 1;
    }
    return services.sort((a, b) => a.depth - b.depth).slice(0, 20);
  }

  /* ═══════════════════════════════════════════════════════════════════════
     MODE MANAGEMENT
     ═══════════════════════════════════════════════════════════════════════ */
  _activateMode(mode) {
    // If clicking the same mode, deactivate it
    if (this.activeMode === mode) {
      this._deactivateMode();
      return;
    }

    // Exit previous mode if needed
    if (this.activeMode === 'impact' && mode !== 'impact') {
      if (this.impactMode) this._exitImpactMode();
    }

    this.activeMode = mode;

    if (mode === 'model') {
      this.direction = 'top-down';
      this.focusTreeMode = 'down';
      if (this.impactMode) this._exitImpactMode();
      const rootInput = document.querySelector('.js-root-ci-input');
      if (rootInput) {
        rootInput.focus();
        rootInput.placeholder = 'Введите имя ИТ-сервиса...';
      }
      this._buildSidebar();
      this._bindSidebar();
      this._showToast('Режим: Модель системы. Выберите корневой ИТ-сервис');
    } else if (mode === 'impact') {
      this.direction = 'bottom-up';
      this.focusTreeMode = 'up';
      this.impactMode = true;
      this._buildSidebar();
      this._bindSidebar();
      const rootInput = document.querySelector('.js-root-ci-input');
      if (rootInput) {
        rootInput.focus();
        rootInput.placeholder = 'Введите КЕ для анализа влияния...';
      }
      // If a node is already selected, run impact from it
      if (this.selectedNode) {
        this._runImpactAnalysis(this.selectedNode);
      }
      this._showToast('Режим: Анализ влияния. Выберите КЕ инфраструктуры');
    }

    this._updateModeUI();
  }

  _deactivateMode() {
    if (this.activeMode === 'impact' && this.impactMode) {
      this._exitImpactMode();
    }
    this.activeMode = null;
    this._updateModeUI();
  }

  _updateModeUI() {
    const trigger = document.querySelector('.js-mode-trigger');
    const triggerIcon = document.querySelector('.js-mode-trigger-icon');
    const triggerLabel = document.querySelector('.js-mode-trigger-label');
    const optModel = document.querySelector('.js-mode-opt-model');
    const optImpact = document.querySelector('.js-mode-opt-impact');

    // Reset all
    trigger?.classList.remove('active-model', 'active-impact');
    optModel?.classList.remove('selected');
    optImpact?.classList.remove('selected', 'impact-selected');

    if (this.activeMode === 'model') {
      trigger?.classList.add('active-model');
      if (triggerIcon) triggerIcon.textContent = '🔷';
      if (triggerLabel) triggerLabel.textContent = 'Модель';
      optModel?.classList.add('selected');
    } else if (this.activeMode === 'impact') {
      trigger?.classList.add('active-impact');
      if (triggerIcon) triggerIcon.textContent = '⚡';
      if (triggerLabel) triggerLabel.textContent = 'Влияние';
      optImpact?.classList.add('selected', 'impact-selected');
    } else {
      if (triggerIcon) triggerIcon.textContent = '◉';
      if (triggerLabel) triggerLabel.textContent = 'Режимы';
    }
  }

  // Legacy compat: keep these as no-ops
  _showQuickActions() {}
  _hideQuickActions() {}

  _showToast(msg) {
    let toast = document.querySelector('.js-rsm-toast');
    if (!toast) {
      toast = document.createElement('div');
      toast.classList.add('js-rsm-toast');
      toast.style.cssText = `position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:${COLORS.text};color:#fff;padding:10px 20px;border-radius:8px;font-size:13px;font-family:${FONT};z-index:300;box-shadow:0 4px 16px rgba(0,0,0,.2);opacity:0;transition:opacity .2s;pointer-events:none`;
      document.body.appendChild(toast);
    }
    toast.textContent = msg;
    toast.style.opacity = '1';
    clearTimeout(this._toastTimer);
    this._toastTimer = setTimeout(() => { toast.style.opacity = '0'; }, 2000);
  }

  /* ═══════════════════════════════════════════════════════════════════════
     SNAPSHOT / DIFF — Сравнение снимков модели
     ═══════════════════════════════════════════════════════════════════════ */

  _loadSnapshots() {
    try {
      const raw = localStorage.getItem('rsm_snapshots');
      return raw ? JSON.parse(raw) : [];
    } catch { return []; }
  }

  _saveSnapshots() {
    try {
      localStorage.setItem('rsm_snapshots', JSON.stringify(this._snapshots));
    } catch (e) {
      console.warn('[RSM] Failed to save snapshots:', e);
    }
  }

  _takeSnapshot(name) {
    const now = new Date();
    const snap = {
      id: 'snap_' + Date.now(),
      name: name || `Снимок ${now.toLocaleDateString('ru-RU')} ${now.toLocaleTimeString('ru-RU', {hour:'2-digit',minute:'2-digit'})}`,
      timestamp: now.toISOString(),
      nodeCount: this.data.nodes.length,
      edgeCount: this.data.edges.length,
      nodes: this.data.nodes.map(n => ({
        id: n.id, name: n.name, type: n.type, status: n.status,
        site: n.site, environment: n.environment, sla: n.sla,
        ip: n.ip, hostname: n.hostname, tags: n.tags ? [...n.tags] : [],
        source: n.source
      })),
      edges: this.data.edges.map(e => ({
        source: e.source, target: e.target, type: e.type, label: e.label
      })),
      filters: {
        rootCI: this.rootCI,
        direction: this.direction,
        types: [...this.filters.types],
        groupMode: this.groupMode
      }
    };
    this._snapshots.push(snap);
    this._saveSnapshots();
    return snap;
  }

  _deleteSnapshot(snapId) {
    this._snapshots = this._snapshots.filter(s => s.id !== snapId);
    this._saveSnapshots();
  }

  _openSnapshotModal() {
    if (this._diffMode) {
      this._exitDiffMode();
      return;
    }
    this._diffSelectedSnaps = [];
    const modal = document.querySelector('.js-rsm-snapshot-modal');
    modal?.classList.add('visible');
    this._renderSnapshotList();
    this._bindSnapshotModal();
  }

  _closeSnapshotModal() {
    document.querySelector('.js-rsm-snapshot-modal')?.classList.remove('visible');
  }

  _renderSnapshotList() {
    const body = document.querySelector('.js-snap-modal-body');
    if (!body) return;

    const snaps = this._snapshots;
    let html = '';

    // Current state as "live" snapshot
    html += '<div class="snap-section-label">Текущее состояние</div>';
    html += `<div class="snap-item snap-base ${this._diffSelectedSnaps.includes('__current__') ? 'selected' : ''}" data-snap-class="js-__current__">
      <div class="snap-radio"></div>
      <div class="snap-info">
        <div class="snap-name">📡 Текущая модель (live)</div>
        <div class="snap-meta">Актуальное состояние графа</div>
        <div class="snap-stats">${this.data.nodes.length} узлов, ${this.data.edges.length} связей</div>
      </div>
    </div>`;

    if (snaps.length > 0) {
      html += '<div class="snap-section-label">Сохранённые снимки</div>';
      html += '<div class="snap-list">';
      // Show newest first
      [...snaps].reverse().forEach(s => {
        const dt = new Date(s.timestamp);
        const dateStr = dt.toLocaleDateString('ru-RU', { day: '2-digit', month: '2-digit', year: 'numeric' });
        const timeStr = dt.toLocaleTimeString('ru-RU', { hour: '2-digit', minute: '2-digit' });
        const sel = this._diffSelectedSnaps.includes(s.id) ? 'selected' : '';
        html += `<div class="snap-item ${sel}" data-snap-class="js-${s.id}">
          <div class="snap-radio"></div>
          <div class="snap-info">
            <div class="snap-name">${s.name}</div>
            <div class="snap-meta">${dateStr} ${timeStr}</div>
            <div class="snap-stats">${s.nodeCount} узлов, ${s.edgeCount} связей</div>
          </div>
          <button class="snap-delete" data-delete-class="js-${s.id}" title="Удалить снимок">🗑</button>
        </div>`;
      });
      html += '</div>';
    } else {
      html += '<div class="snap-empty">Нет сохранённых снимков.<br>Сохраните текущее состояние модели для последующего сравнения.</div>';
    }

    body.innerHTML = html;

    // Update compare button state
    const compareBtn = document.querySelector('.js-snap-btn-compare');
    if (compareBtn) {
      compareBtn.disabled = this._diffSelectedSnaps.length !== 2;
    }
  }

  _bindSnapshotModal() {
    const modal = document.querySelector('.js-rsm-snapshot-modal');
    const body = document.querySelector('.js-snap-modal-body');

    // Close modal
    document.querySelector('.js-snap-modal-close')?.addEventListener('click', () => this._closeSnapshotModal());
    modal?.addEventListener('click', (e) => {
      if (e.target === modal) this._closeSnapshotModal();
    });

    // Save snapshot
    document.querySelector('.js-snap-btn-save')?.addEventListener('click', () => {
      const name = prompt('Название снимка:', `Снимок ${new Date().toLocaleDateString('ru-RU')} ${new Date().toLocaleTimeString('ru-RU', {hour:'2-digit',minute:'2-digit'})}`);
      if (name === null) return;
      this._takeSnapshot(name);
      this._showToast('📸 Снимок сохранён');
      this._renderSnapshotList();
      this._bindSnapshotModalItems();
    });

    // Compare button
    document.querySelector('.js-snap-btn-compare')?.addEventListener('click', () => {
      if (this._diffSelectedSnaps.length === 2) {
        this._runDiffComparison(this._diffSelectedSnaps[0], this._diffSelectedSnaps[1]);
        this._closeSnapshotModal();
      }
    });

    this._bindSnapshotModalItems();
  }

  _bindSnapshotModalItems() {
    const body = document.querySelector('.js-snap-modal-body');
    if (!body) return;

    // Select snapshot items
    body.querySelectorAll('.snap-item').forEach(item => {
      item.addEventListener('click', (e) => {
        if (e.target.closest('.snap-delete')) return;
        const snapId = item.dataset.snapId;
        const idx = this._diffSelectedSnaps.indexOf(snapId);
        if (idx >= 0) {
          this._diffSelectedSnaps.splice(idx, 1);
        } else {
          if (this._diffSelectedSnaps.length >= 2) {
            this._diffSelectedSnaps.shift();
          }
          this._diffSelectedSnaps.push(snapId);
        }
        this._renderSnapshotList();
        this._bindSnapshotModalItems();
      });
    });

    // Delete buttons
    body.querySelectorAll('.snap-delete').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const id = btn.dataset.deleteId;
        if (confirm('Удалить этот снимок?')) {
          this._deleteSnapshot(id);
          this._diffSelectedSnaps = this._diffSelectedSnaps.filter(s => s !== id);
          this._renderSnapshotList();
          this._bindSnapshotModalItems();
          this._showToast('Снимок удалён');
        }
      });
    });
  }

  _getSnapshotData(snapId) {
    if (snapId === '__current__') {
      return {
        name: 'Текущая модель',
        nodes: this.data.nodes,
        edges: this.data.edges
      };
    }
    const snap = this._snapshots.find(s => s.id === snapId);
    if (!snap) return null;
    return {
      name: snap.name,
      nodes: snap.nodes,
      edges: snap.edges
    };
  }

  _runDiffComparison(snapIdA, snapIdB) {
    const dataA = this._getSnapshotData(snapIdA);
    const dataB = this._getSnapshotData(snapIdB);
    if (!dataA || !dataB) {
      this._showToast('Ошибка: снимок не найден');
      return;
    }

    // Build node maps by ID
    const mapA = new Map();
    dataA.nodes.forEach(n => mapA.set(n.id, n));
    const mapB = new Map();
    dataB.nodes.forEach(n => mapB.set(n.id, n));

    // Build edge sets
    const edgeKey = (e) => `${e.source}|${e.target}|${e.type}`;
    const edgesA = new Set(dataA.edges.map(edgeKey));
    const edgesB = new Set(dataB.edges.map(edgeKey));

    const added = [];    // In B but not in A
    const removed = [];  // In A but not in B
    const changed = [];  // In both but attributes differ
    const unchanged = []; // Identical

    // Check nodes in B (new snapshot)
    mapB.forEach((nodeB, id) => {
      if (!mapA.has(id)) {
        added.push({ id, node: nodeB, reason: 'Новый CI' });
      } else {
        const nodeA = mapA.get(id);
        const diffs = [];
        if (nodeA.status !== nodeB.status) diffs.push(`статус: ${nodeA.status} → ${nodeB.status}`);
        if (nodeA.sla !== nodeB.sla) diffs.push(`SLA: ${nodeA.sla} → ${nodeB.sla}`);
        if (nodeA.site !== nodeB.site) diffs.push(`площадка: ${nodeA.site} → ${nodeB.site}`);
        if (nodeA.environment !== nodeB.environment) diffs.push(`окружение: ${nodeA.environment} → ${nodeB.environment}`);
        if (nodeA.ip !== nodeB.ip) diffs.push(`IP: ${nodeA.ip} → ${nodeB.ip}`);
        if (nodeA.hostname !== nodeB.hostname) diffs.push(`hostname: ${nodeA.hostname} → ${nodeB.hostname}`);
        // Check edge changes for this node
        const nodeEdgesA = dataA.edges.filter(e => e.source === id || e.target === id).map(edgeKey);
        const nodeEdgesB = dataB.edges.filter(e => e.source === id || e.target === id).map(edgeKey);
        const newEdges = nodeEdgesB.filter(e => !edgesA.has(e)).length;
        const lostEdges = nodeEdgesA.filter(e => !edgesB.has(e)).length;
        if (newEdges > 0) diffs.push(`+${newEdges} связей`);
        if (lostEdges > 0) diffs.push(`-${lostEdges} связей`);

        if (diffs.length > 0) {
          changed.push({ id, node: nodeB, reason: diffs.join(', ') });
        } else {
          unchanged.push({ id, node: nodeB });
        }
      }
    });

    // Check removed nodes (in A but not in B)
    mapA.forEach((nodeA, id) => {
      if (!mapB.has(id)) {
        removed.push({ id, node: nodeA, reason: 'Удалён из модели' });
      }
    });

    // Edge diff
    const addedEdges = [...edgesB].filter(e => !edgesA.has(e));
    const removedEdges = [...edgesA].filter(e => !edgesB.has(e));

    this._diffResult = {
      nameA: dataA.name,
      nameB: dataB.name,
      added, removed, changed, unchanged,
      addedEdges, removedEdges
    };

    this._enterDiffMode();
  }

  _enterDiffMode() {
    if (!this._diffResult) return;
    this._diffMode = true;
    const r = this._diffResult;

    // Update banner
    document.querySelector('.js-diff-snap-names').textContent = `«${r.nameA}» ↔ «${r.nameB}»`;
    document.querySelector('.js-diff-added').textContent = `+${r.added.length} новых`;
    document.querySelector('.js-diff-removed').textContent = `−${r.removed.length} удалённых`;
    document.querySelector('.js-diff-changed').textContent = `~${r.changed.length} изменённых`;
    document.querySelector('.js-diff-unchanged').textContent = `${r.unchanged.length} без изменений`;

    document.querySelector('.js-rsm-diff-banner')?.classList.add('visible');
    document.querySelector('.js-rsm-diff-legend')?.classList.add('visible');
    document.querySelector('.js-btn-diff')?.classList.add('active');
    this._hideQuickActions();

    // Apply visual diff to graph nodes
    this._applyDiffStyles();
    this._showToast(`Сравнение: +${r.added.length} / −${r.removed.length} / ~${r.changed.length}`);
  }

  _applyDiffStyles() {
    if (!this.cy || !this._diffResult) return;
    const r = this._diffResult;

    const addedIds = new Set(r.added.map(a => a.id));
    const removedIds = new Set(r.removed.map(a => a.id));
    const changedIds = new Set(r.changed.map(a => a.id));
    const changedReasons = new Map(r.changed.map(a => [a.id, a.reason]));

    // In group mode, we need to check if any node in a group is affected
    const groupDiff = new Map(); // groupType -> { added, removed, changed, unchanged }

    // Process all visible nodes
    this.cy.nodes().forEach(node => {
      const id = node.id();
      const isGroup = node.data('isGroup');

      if (isGroup) {
        // For group nodes, aggregate diff status of children
        const groupType = node.data('groupType') || id;
        const childNodes = this.data.nodes.filter(n => n.type === groupType);
        let gAdded = 0, gRemoved = 0, gChanged = 0, gUnchanged = 0;
        childNodes.forEach(cn => {
          if (addedIds.has(cn.id)) gAdded++;
          else if (removedIds.has(cn.id)) gRemoved++;
          else if (changedIds.has(cn.id)) gChanged++;
          else gUnchanged++;
        });

        // Color group by dominant change
        let color, borderColor, borderWidth;
        if (gAdded > 0 && gAdded >= gChanged && gAdded >= gRemoved) {
          color = '#C8E6C9'; borderColor = '#43A047'; borderWidth = 3;
        } else if (gRemoved > 0 && gRemoved >= gChanged) {
          color = '#FFCDD2'; borderColor = '#E53935'; borderWidth = 3;
        } else if (gChanged > 0) {
          color = '#FFF9C4'; borderColor = '#F9A825'; borderWidth = 3;
        } else {
          color = '#F5F5F5'; borderColor = '#BDBDBD'; borderWidth = 1;
        }

        node.style({
          'background-color': color,
          'border-color': borderColor,
          'border-width': borderWidth,
        });

        // Add diff summary label
        const parts = [];
        if (gAdded) parts.push(`+${gAdded}`);
        if (gRemoved) parts.push(`-${gRemoved}`);
        if (gChanged) parts.push(`~${gChanged}`);
        if (parts.length > 0) {
          node.data('diffLabel', parts.join(' '));
        }
      } else {
        // Individual node
        if (addedIds.has(id)) {
          node.style({
            'background-color': '#43A047',
            'border-color': '#2E7D32',
            'border-width': 3,
            'color': '#fff',
          });
        } else if (removedIds.has(id)) {
          node.style({
            'background-color': '#E53935',
            'border-color': '#C62828',
            'border-width': 3,
            'color': '#fff',
            'opacity': 0.7,
          });
        } else if (changedIds.has(id)) {
          node.style({
            'background-color': '#FFF9C4',
            'border-color': '#F9A825',
            'border-width': 3,
            'color': '#333',
          });
        } else {
          // Unchanged - dim it
          node.style({
            'opacity': 0.35,
            'border-width': 1,
          });
        }
      }
    });

    // Style edges
    const addedEdgeSet = new Set(r.addedEdges);
    const removedEdgeSet = new Set(r.removedEdges);
    this.cy.edges().forEach(edge => {
      const key = `${edge.data('source')}|${edge.data('target')}|${edge.data('edgeType') || 'depends_on'}`;
      if (addedEdgeSet.has(key)) {
        edge.style({ 'line-color': '#43A047', 'width': 3, 'opacity': 1, 'target-arrow-color': '#43A047' });
      } else if (removedEdgeSet.has(key)) {
        edge.style({ 'line-color': '#E53935', 'width': 3, 'opacity': 0.7, 'line-style': 'dashed', 'target-arrow-color': '#E53935' });
      } else {
        edge.style({ 'opacity': 0.15 });
      }
    });
  }

  _exitDiffMode() {
    this._diffMode = false;
    this._diffResult = null;
    document.querySelector('.js-rsm-diff-banner')?.classList.remove('visible');
    document.querySelector('.js-rsm-diff-legend')?.classList.remove('visible');
    document.querySelector('.js-btn-diff')?.classList.remove('active');

    // Restore normal graph styles
    if (this.cy) {
      this.cy.nodes().forEach(n => {
        n.removeStyle();
        n.removeData('diffLabel');
      });
      this.cy.edges().forEach(e => e.removeStyle());
    }
    // Re-apply SLA heatmap if active
    if (this.slaHeatmap) this._applySlaHeatmap();
    // Show Quick Actions if no rootCI
    if (!this.rootCI) this._showQuickActions();
    this._showToast('Режим сравнения отключён');
  }
}

