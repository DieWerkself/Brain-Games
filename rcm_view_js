  /* ═══════════════════════════════════════════════════════════════════════
     SMART SEARCH
     ═══════════════════════════════════════════════════════════════════════ */
  _parseSmartSearch(query) {
    const result = { text: '', attrs: {} };
    const attrPattern = /([\wа-яА-ЯёЁ]+):([^\s]+)/g;
    let match;
    let remaining = query;
    while ((match = attrPattern.exec(query)) !== null) {
      const key = match[1].toLowerCase();
      const val = match[2].toLowerCase();
      const keyMap = { 'тип':'type', 'type':'type', 'статус':'status', 'status':'status',
        'площадка':'site', 'site':'site', 'окружение':'environment', 'env':'environment',
        'ответственный':'responsible', 'responsible':'responsible', 'источник':'dataSource', 'source':'dataSource',
        'ip':'ip', 'адрес':'ip', 'hostname':'hostname', 'хост':'hostname',
        'тег':'tags', 'tag':'tags', 'tags':'tags', 'теги':'tags',
        'sla':'sla', 'id':'id' };
      if (keyMap[key]) {
        result.attrs[keyMap[key]] = val;
      }
      remaining = remaining.replace(match[0], '');
    }
    result.text = remaining.trim().toLowerCase();
    return result;
  }

  _smartSearchNodes(query) {
    if (!query.trim()) return [];
    const parsed = this._parseSmartSearch(query);
    let matches = this.data.nodes;

    // Filter by structured attributes
    Object.entries(parsed.attrs).forEach(([key, val]) => {
      matches = matches.filter(n => {
        if (key === 'tags') {
          return (n.tags || []).some(t => t.toLowerCase().includes(val));
        }
        const nodeVal = (n[key] || '').toLowerCase();
        return nodeVal.includes(val);
      });
    });

    // Full-text search across ALL fields
    if (parsed.text) {
      const t = parsed.text;
      matches = matches.filter(n =>
        n.name.toLowerCase().includes(t) ||
        n.type.toLowerCase().includes(t) ||
        n.status.toLowerCase().includes(t) ||
        n.site.toLowerCase().includes(t) ||
        n.responsible.toLowerCase().includes(t) ||
        (n.ip || '').toLowerCase().includes(t) ||
        (n.hostname || '').toLowerCase().includes(t) ||
        (n.tags || []).some(tag => tag.toLowerCase().includes(t)) ||
        (n.sla || '').toLowerCase().includes(t) ||
        (n.environment || '').toLowerCase().includes(t) ||
        (n.description || '').toLowerCase().includes(t) ||
        (n.id || '').toLowerCase().includes(t)
      );
    }

    return matches.slice(0, 50);
  }

  _updateSearchHints(query) {
    const hints = document.querySelector('.js-search-hints');
    if (!hints) return;
    if (!query.trim()) {
      hints.classList.remove('open');
      return;
    }
    const matches = this._smartSearchNodes(query);
    if (!matches.length) {
      hints.innerHTML = `<div class="search-syntax">Синтаксис: <code>тип:сервер</code> <code>статус:активен</code> <code>ip:10.0</code> <code>хост:srv</code> <code>тег:core</code> или свободный текст</div>
        <div style="padding:8px 12px;font-size:12px;color:${COLORS.textMuted}">Ничего не найдено</div>`;
      hints.classList.add('open');
      return;
    }
    let h = `<div class="search-syntax">Найдено: ${matches.length}${matches.length >= 50 ? '+' : ''} CI. Синтаксис: <code>тип:сервер</code> <code>ip:10.0</code> <code>хост:srv</code> <code>тег:core</code></div>`;
    matches.forEach(n => {
      const tagsStr = (n.tags || []).slice(0, 2).join(', ');
      h += `<div class="search-hint-item" data-hint-class="js-${n.id}">
        <span class="hint-dot" style="background:${CI_TYPE_COLORS[n.type]}"></span>
        <span class="hint-name">${this._esc(n.name)}</span>
        <span class="hint-type">${this._esc(n.type)}</span>
        <span class="hint-meta">${this._esc(n.ip || '')}</span>
        ${tagsStr ? `<span class="hint-tags">${this._esc(tagsStr)}</span>` : ''}
      </div>`;
    });
    hints.innerHTML = h;
    hints.classList.add('open');
  }

  /* ═══════════════════════════════════════════════════════════════════════
     CYTOSCAPE
     ═══════════════════════════════════════════════════════════════════════ */
  _initCy() {
    this.cy = cytoscape({
      container: document.querySelector('.js-rsm-cy'),
      elements: this._buildElements(),
      style: this._cyStyle(),
      layout: { name: 'preset' },
      minZoom: 0.05, maxZoom: 4,
      wheelSensitivity: 0.25,
      boxSelectionEnabled: false,
      textureOnViewport: true,
      hideEdgesOnViewport: true,
      hideLabelsOnViewport: true,
    });
    this._runLayout(false);
    this._bindCyEvents();
    this._updateStats();
  }

  _buildElements() {
    const els = [];
    const vis = this._getFiltered();
    const visIds = new Set(vis.map(n => n.id));
    const idx = this._nodeIndex;
    const transitiveEdges = this._computeTransitiveEdges([...visIds]);

    if (this.groupMode) {
      const byType = {};
      vis.forEach(n => { (byType[n.type] = byType[n.type] || []).push(n); });
      const hier = this.direction === 'top-down' ? CI_TYPE_HIERARCHY : [...CI_TYPE_HIERARCHY].reverse();

      hier.forEach(type => {
        const items = byType[type];
        if (!items?.length) return;
        const exp = this.expandedGroups.has(type);
        els.push({ data: { id:'g_'+type, label:`${type} (${items.length})`, isGroup:true, groupType:type, expanded:exp, color:CI_TYPE_COLORS[type] }});
        if (exp) {
          items.forEach(n => {
            els.push({ data: {
              id:n.id, label: n.dataSource === 'auto' ? `⚡ ${n.name}` : `✏️ ${n.name}`,
              ciType:n.type, status:n.status, environment:n.environment, site:n.site,
              responsible:n.responsible, incidents:n.incidentCount, name:n.name,
              color:CI_TYPE_COLORS[n.type], isGroup:false, isRoot: n.id === this.rootCI,
              dataSource: n.dataSource,
            }});
          });
        }
      });

      const edgeMap = new Map();
      this.data.edges.forEach(e => {
        const sn = idx.get(e.source);
        const tn = idx.get(e.target);
        if (!sn || !tn || !visIds.has(sn.id) || !visIds.has(tn.id)) return;
        const sId = this.expandedGroups.has(sn.type) ? e.source : 'g_'+sn.type;
        const tId = this.expandedGroups.has(tn.type) ? e.target : 'g_'+tn.type;
        if (sId === tId) return;
        const key = sId+'→'+tId;
        if (!edgeMap.has(key)) edgeMap.set(key, { source:sId, target:tId, label:e.label, type:e.type, count:0 });
        edgeMap.get(key).count++;
      });
      edgeMap.forEach((v, k) => {
        els.push({ data: { id:'e_'+k, source:v.source, target:v.target, label:v.count>1?`${v.label} (${v.count})`:v.label, edgeType:v.type }});
      });

      const tEdgeMap = new Map();
      transitiveEdges.forEach(e => {
        const sn = idx.get(e.source);
        const tn = idx.get(e.target);
        if (!sn || !tn) return;
        const sId = this.expandedGroups.has(sn.type) ? e.source : 'g_'+sn.type;
        const tId = this.expandedGroups.has(tn.type) ? e.target : 'g_'+tn.type;
        if (sId === tId) return;
        const directKey = sId+'→'+tId;
        if (edgeMap.has(directKey)) return;
        const key = 't_'+sId+'→'+tId;
        if (!tEdgeMap.has(key)) tEdgeMap.set(key, { source:sId, target:tId, count:0 });
        tEdgeMap.get(key).count++;
      });
      tEdgeMap.forEach((v, k) => {
        const lbl = v.count > 1 ? `транзитивная (${v.count})` : 'транзитивная связь';
        els.push({ data: { id:'te_'+k, source:v.source, target:v.target, label:lbl, edgeType:'transitive' }});
      });

    } else {
      vis.forEach(n => {
        els.push({ data: {
          id:n.id, label: n.dataSource === 'auto' ? `⚡ ${n.name}` : `✏️ ${n.name}`,
          ciType:n.type, status:n.status, environment:n.environment, site:n.site,
          responsible:n.responsible, incidents:n.incidentCount, name:n.name,
          color:CI_TYPE_COLORS[n.type], isGroup:false, isRoot: n.id === this.rootCI,
          dataSource: n.dataSource,
        }});
      });
      this.data.edges.forEach((e,i) => {
        if (visIds.has(e.source) && visIds.has(e.target)) {
          els.push({ data: { id:'e_'+i, source:e.source, target:e.target, label:e.label, edgeType:e.type }});
        }
      });
      const directSet = new Set();
      this.data.edges.forEach(e => {
        if (visIds.has(e.source) && visIds.has(e.target)) directSet.add(e.source+'→'+e.target);
      });
      transitiveEdges.forEach((e, i) => {
        if (!directSet.has(e.source+'→'+e.target)) {
          els.push({ data: { id:'te_'+i, source:e.source, target:e.target, label:e.label, edgeType:'transitive' }});
        }
      });
    }
    return els;
  }

  _getFiltered() {
    if (!this._filteredCacheDirty && this._filteredCache) return this._filteredCache;
    this._filteredCache = this._filtered();
    this._filteredCacheDirty = false;
    return this._filteredCache;
  }

  _invalidateFilterCache() {
    this._filteredCacheDirty = true;
    this._directEdgeIndex = null; // invalidate edge index on filter change
    this._filteredCache = null;
  }

  _filtered() {
    let nodes = this.data.nodes;

    if (this.rootCI) {
      const reachable = this._getReachableFromRoot(this.rootCI);
      nodes = nodes.filter(n => reachable.has(n.id));
    }

    // Layer zone filter
    if (this.collapsedLayers.size > 0) {
      const hiddenTypes = new Set();
      LAYER_ZONES.forEach(zone => {
        if (this.collapsedLayers.has(zone.id)) {
          zone.types.forEach(t => hiddenTypes.add(t));
        }
      });
      nodes = nodes.filter(n => !hiddenTypes.has(n.type) || n.id === this.rootCI);
    }

    nodes = nodes.filter(n =>
      this.filters.statuses.has(n.status) &&
      this.filters.sites.has(n.site) &&
      this.filters.environments.has(n.environment)
    );

    nodes = nodes.filter(n =>
      this.filters.types.has(n.type) || n.id === this.rootCI
    );

    // Data source filter
    if (this.dataSourceFilter !== 'all') {
      nodes = nodes.filter(n => n.dataSource === this.dataSourceFilter || n.id === this.rootCI);
    }

    // Smart search
    if (this.searchQuery.trim()) {
      const parsed = this._parseSmartSearch(this.searchQuery);
      if (parsed.text || Object.keys(parsed.attrs).length) {
        nodes = nodes.filter(n => {
          let match = true;
          Object.entries(parsed.attrs).forEach(([key, val]) => {
            if (!(n[key] || '').toLowerCase().includes(val)) match = false;
          });
          if (parsed.text) {
            const t = parsed.text;
            if (!(n.name.toLowerCase().includes(t) || n.type.toLowerCase().includes(t) ||
                  n.status.toLowerCase().includes(t) || n.site.toLowerCase().includes(t) ||
                  n.responsible.toLowerCase().includes(t) ||
                  (n.ip || '').toLowerCase().includes(t) ||
                  (n.hostname || '').toLowerCase().includes(t) ||
                  (n.tags || []).some(tag => tag.toLowerCase().includes(t)) ||
                  (n.environment || '').toLowerCase().includes(t) ||
                  (n.description || '').toLowerCase().includes(t))) match = false;
          }
          return match;
        });
      }
    }
    return nodes;
  }

