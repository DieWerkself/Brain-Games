      const userIdx = i - DEFAULT_PRESETS.length;
      const ownerLabel = p.owner ? this._esc(p.owner) : (isDefault ? 'Системный' : 'Мой');
      const isShared = !!p.shared;
      h += `<div class="preset-item ${isDefault?'is-default':''}" data-pi="${i}" data-user-idx="${userIdx}">
