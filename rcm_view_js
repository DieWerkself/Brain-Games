    .filter-chip{display:flex;align-items:center;gap:8px;padding:4px 8px;border-radius:5px;cursor:pointer;font-size:12px;transition:background .12s;user-select:none}
    .filter-chip:hover{background:${COLORS.accentBg}}
    .filter-chip input[type="checkbox"]{width:15px;height:15px;accent-color:${COLORS.accent};cursor:pointer;flex-shrink:0}
    .filter-chip .chip-label{flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .filter-chip .chip-count{font-size:10px;color:${COLORS.textMuted};background:${COLORS.bg};padding:1px 5px;border-radius:8px;min-width:20px;text-align:center}
    .filter-chip .chip-color{width:8px;height:8px;border-radius:50%;flex-shrink:0}

    /* SAVED FILTERS / PRESETS */
    .presets-section{margin-bottom:14px}
    .sf-header{display:flex;align-items:center;gap:8px;margin-bottom:6px}
    .sf-header h4{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.5px;color:${COLORS.textSecondary};flex:1}
    .sf-header button{font-size:11px;color:${COLORS.accent};background:none;border:none;cursor:pointer;font-family:${FONT};font-weight:500}
    .sf-header button:hover{text-decoration:underline}
    .preset-item{display:flex;align-items:center;gap:6px;padding:6px 8px;border-radius:6px;cursor:pointer;font-size:12px;transition:background .12s;border:1px solid transparent}
    .preset-item:hover{background:${COLORS.accentBg};border-color:${COLORS.border}}
    .preset-item .preset-icon{font-size:13px;flex-shrink:0}
    .preset-item .preset-info{flex:1;min-width:0}
    .preset-item .preset-name{font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;display:block}
    .preset-item .preset-desc{font-size:10px;color:${COLORS.textMuted};white-space:nowrap;overflow:hidden;text-overflow:ellipsis;display:block}
    .preset-item .preset-actions{display:flex;gap:4px;align-items:center;opacity:0;transition:opacity .15s;flex-shrink:0}
    .preset-item:hover .preset-actions{opacity:1}
    .preset-item .preset-action{width:22px;height:22px;display:flex;align-items:center;justify-content:center;border-radius:4px;cursor:pointer;font-size:11px;transition:background .12s,color .12s;color:${COLORS.textMuted}}
    .preset-item .preset-action:hover{background:${COLORS.accentBg};color:${COLORS.accent}}
    .preset-item .preset-delete-btn:hover{background:${COLORS.dangerBg};color:${COLORS.danger}}
    .preset-item .preset-owner{font-size:9px;color:${COLORS.textMuted};display:block;margin-top:1px}
    .preset-item.is-default .preset-actions{display:none}

    .group-toggle-row{margin-bottom:14px;display:flex;align-items:center;gap:8px;padding:4px 0}
    .group-toggle-row label{display:flex;align-items:center;gap:8px;cursor:pointer;font-size:13px;font-weight:500}
    .group-toggle-row input{width:15px;height:15px;accent-color:${COLORS.accent}}

    /* DATA SOURCE FILTER */
    .ds-filter{margin-bottom:14px;display:flex;gap:6px}
    .ds-chip{display:flex;align-items:center;gap:5px;padding:4px 10px;border-radius:6px;cursor:pointer;font-size:11px;font-weight:500;border:1px solid ${COLORS.border};transition:all .15s;user-select:none}
    .ds-chip:hover{border-color:${COLORS.accent}}
    .ds-chip.active{background:${COLORS.accentBg};border-color:${COLORS.accent};color:${COLORS.accent}}
    .ds-chip .ds-icon{font-size:12px}

    .reset-btn{width:100%;height:34px;border:1px solid ${COLORS.border};border-radius:6px;background:${COLORS.surface};color:${COLORS.textSecondary};font-size:12px;font-family:${FONT};cursor:pointer;transition:all .15s;margin-top:6px}
    .reset-btn:hover{border-color:${COLORS.accent};color:${COLORS.accent}}

    /* MAIN */
    .js-rsm-main{flex:1;position:relative;overflow:hidden;background:${COLORS.bg}}
    .js-rsm-cy{width:100%;height:100%}

    #rsm-sidebar-toggle{position:absolute;top:12px;left:12px;z-index:50;width:36px;height:36px;border-radius:8px;border:1px solid ${COLORS.border};background:${COLORS.surface};cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:16px;color:${COLORS.text};transition:all .15s;box-shadow:0 2px 4px rgba(0,0,0,.06)}
    #rsm-sidebar-toggle:hover{border-color:${COLORS.accent};color:${COLORS.accent}}

    /* IMPACT BANNER */
    .js-rsm-impact-banner{position:absolute;top:12px;left:56px;z-index:55;background:${COLORS.dangerBg};border:1px solid ${COLORS.danger};border-radius:8px;padding:8px 14px;display:none;align-items:center;gap:10px;box-shadow:0 2px 8px rgba(0,0,0,.1);font-size:12px;flex-wrap:wrap}
    .js-rsm-impact-banner.visible{display:flex}
    .js-rsm-impact-banner .impact-info{font-weight:500;color:${COLORS.danger}}
    .js-rsm-impact-banner .impact-count{font-weight:700}
    .js-rsm-impact-banner .impact-exit{border:none;background:${COLORS.danger};color:#fff;padding:4px 10px;border-radius:5px;cursor:pointer;font-size:11px;font-family:${FONT};font-weight:500;transition:opacity .15s}
    .js-rsm-impact-banner .impact-exit:hover{opacity:.85}
    .impact-chain-toggle{display:flex;gap:2px;background:${COLORS.bg};border:1px solid ${COLORS.border};border-radius:5px;padding:2px;margin-left:4px}
    .impact-chain-toggle .ict-btn{border:none;background:transparent;padding:3px 8px;border-radius:3px;cursor:pointer;font-size:10px;font-family:${FONT};font-weight:500;color:${COLORS.textSecondary};transition:all .15s;white-space:nowrap}
    .impact-chain-toggle .ict-btn.active{background:${COLORS.danger};color:#fff}
    .impact-chain-toggle .ict-btn:hover:not(.active){background:${COLORS.dangerBg};color:${COLORS.danger}}

    /* CONTEXT PANEL (slide-in from right) */
    .js-rsm-context-panel{position:absolute;top:0;right:0;width:380px;height:100%;background:${COLORS.surface};border-left:1px solid ${COLORS.border};box-shadow:-4px 0 20px rgba(0,0,0,.08);z-index:70;transform:translateX(100%);transition:transform .3s ease;overflow-y:auto}
    .js-rsm-context-panel.open{transform:translateX(0)}
    .ctx-header{display:flex;align-items:center;padding:16px 18px;border-bottom:1px solid ${COLORS.border};gap:10px;position:sticky;top:0;background:${COLORS.surface};z-index:1}
    .ctx-header .ctx-icon{width:36px;height:36px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0}
    .ctx-header .ctx-title-area{flex:1;min-width:0}
    .ctx-header .ctx-name{font-size:15px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .ctx-header .ctx-type{font-size:11px;color:${COLORS.textSecondary}}
    .ctx-header .ctx-close{width:30px;height:30px;border:none;background:${COLORS.bg};border-radius:6px;cursor:pointer;font-size:14px;color:${COLORS.textSecondary};display:flex;align-items:center;justify-content:center;transition:all .15s;flex-shrink:0}
    .ctx-header .ctx-close:hover{background:${COLORS.border};color:${COLORS.text}}

    .ctx-section{padding:14px 18px;border-bottom:1px solid ${COLORS.border}}
    .ctx-section:last-child{border-bottom:none}
    .ctx-section-title{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.5px;color:${COLORS.textSecondary};margin-bottom:10px;display:flex;align-items:center;gap:6px}
    .ctx-row{display:flex;margin-bottom:8px}
    .ctx-label{width:120px;font-size:12px;color:${COLORS.textSecondary};font-weight:500;padding-top:1px;flex-shrink:0}
    .ctx-value{flex:1;font-size:13px;color:${COLORS.text}}
    .ctx-badge{display:inline-flex;align-items:center;gap:4px;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:500}
    .ctx-badge.auto{background:rgba(21,101,192,.1);color:${COLORS.autoSource}}
    .ctx-badge.manual{background:rgba(123,31,162,.1);color:${COLORS.manualSource}}
    .ctx-badge.status-active{background:${COLORS.successBg};color:${COLORS.success}}
    .ctx-badge.status-warning{background:${COLORS.warningBg};color:${COLORS.warning}}
    .ctx-badge.status-danger{background:${COLORS.dangerBg};color:${COLORS.danger}}

    .ctx-actions{display:flex;gap:6px;padding:14px 18px;border-bottom:1px solid ${COLORS.border}}
    .ctx-action-btn{flex:1;height:34px;border:1px solid ${COLORS.border};border-radius:6px;background:${COLORS.surface};cursor:pointer;font-size:12px;font-family:${FONT};color:${COLORS.text};font-weight:500;transition:all .15s;display:flex;align-items:center;justify-content:center;gap:5px}
    .ctx-action-btn:hover{border-color:${COLORS.accent};color:${COLORS.accent}}
    .ctx-action-btn.primary{background:${COLORS.accent};color:#fff;border-color:${COLORS.accent}}
    .ctx-action-btn.primary:hover{background:#005FA3}
    .ctx-action-btn.danger{color:${COLORS.danger};border-color:${COLORS.danger}}
    .ctx-action-btn.danger:hover{background:${COLORS.dangerBg}}

    /* INCIDENT LIST */
    .incident-item{padding:8px 10px;border:1px solid ${COLORS.border};border-radius:6px;margin-bottom:6px;transition:background .12s}
    .incident-item:hover{background:${COLORS.bg}}
    .incident-item .inc-header{display:flex;align-items:center;gap:6px;margin-bottom:3px}
    .incident-item .inc-id{font-size:11px;font-weight:600;color:${COLORS.accent}}
    .incident-item .inc-priority{font-size:10px;padding:1px 6px;border-radius:3px;font-weight:500}
    .inc-priority.crit{background:${COLORS.dangerBg};color:${COLORS.danger}}
    .inc-priority.high{background:${COLORS.warningBg};color:${COLORS.warning}}
    .inc-priority.med{background:${COLORS.accentBg};color:${COLORS.accent}}
    .inc-priority.low{background:${COLORS.bg};color:${COLORS.textSecondary}}
    .incident-item .inc-title{font-size:12px;color:${COLORS.text}}
    .incident-item .inc-date{font-size:10px;color:${COLORS.textMuted};margin-top:2px}

    /* STATS */
    #rsm-stats{position:absolute;bottom:12px;left:12px;z-index:50;background:${COLORS.surface};border:1px solid ${COLORS.border};border-radius:8px;padding:6px 14px;font-size:11px;color:${COLORS.textSecondary};box-shadow:0 2px 4px rgba(0,0,0,.06);display:flex;gap:12px}
    #rsm-stats span{font-weight:600;color:${COLORS.text}}

    /* LEGEND */
    .legend-section{margin-top:12px;padding-top:12px;border-top:1px solid ${COLORS.border}}
    .legend-item{display:flex;align-items:center;gap:8px;padding:2px 0;font-size:11px;color:${COLORS.textSecondary}}
    .legend-line{width:24px;height:2px;position:relative}
    .legend-line::after{content:'';position:absolute;right:-1px;top:-3px;border:4px solid transparent;border-left:6px solid}
    .legend-line.depends{background:${COLORS.edge}}
    .legend-line.depends::after{border-left-color:${COLORS.edge}}
    .legend-line.influences{background:${COLORS.accentLight}}
    .legend-line.influences::after{border-left-color:${COLORS.accentLight}}
    .legend-line.transitive{background:repeating-linear-gradient(90deg,${COLORS.transitiveEdge} 0,${COLORS.transitiveEdge} 4px,transparent 4px,transparent 7px);height:2px}
    .legend-line.transitive::after{border-left-color:${COLORS.transitiveEdge}}
    .legend-line.impact{background:${COLORS.impactEdge}}
    .legend-line.impact::after{border-left-color:${COLORS.impactEdge}}

    ::-webkit-scrollbar{width:5px}
    ::-webkit-scrollbar-track{background:transparent}
    ::-webkit-scrollbar-thumb{background:${COLORS.border};border-radius:3px}
    ::-webkit-scrollbar-thumb:hover{background:${COLORS.textMuted}}

    /* MODAL */
    .modal-overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.3);z-index:200;display:flex;align-items:center;justify-content:center}
    .modal-box{background:${COLORS.surface};border-radius:10px;padding:24px;width:380px;box-shadow:0 8px 32px rgba(0,0,0,.15)}
    .modal-box h3{font-size:15px;font-weight:600;margin-bottom:14px}
    .modal-box input,.modal-box textarea{width:100%;border:1px solid ${COLORS.border};border-radius:6px;padding:0 12px;font-size:13px;font-family:${FONT};outline:none;margin-bottom:10px}
    .modal-box input{height:38px}
    .modal-box textarea{height:60px;padding:8px 12px;resize:vertical}
    .modal-box input:focus,.modal-box textarea:focus{border-color:${COLORS.accent}}
    .modal-actions{display:flex;gap:8px;justify-content:flex-end}
    .modal-actions button{height:34px;padding:0 18px;border-radius:6px;font-size:12px;font-family:${FONT};cursor:pointer;font-weight:500;transition:all .15s}
    .btn-cancel{border:1px solid ${COLORS.border};background:${COLORS.surface};color:${COLORS.textSecondary}}
    .btn-cancel:hover{border-color:${COLORS.text};color:${COLORS.text}}
    .btn-save{border:none;background:${COLORS.accent};color:#fff}
    .btn-save:hover{background:#005FA3}

    .cy-tooltip{position:absolute;z-index:100;background:${COLORS.text};color:#fff;padding:5px 10px;border-radius:5px;font-size:11px;pointer-events:none;white-space:nowrap;box-shadow:0 2px 8px rgba(0,0,0,.2)}

    /* MINIMAP */
    .js-rsm-minimap{position:absolute;bottom:12px;right:12px;z-index:55;width:200px;height:150px;background:${COLORS.surface};border:1px solid ${COLORS.border};border-radius:8px;box-shadow:0 2px 8px rgba(0,0,0,.1);overflow:hidden;cursor:crosshair;transition:opacity .2s}
    #rsm-minimap:hover{box-shadow:0 4px 16px rgba(0,0,0,.15)}
    .js-rsm-minimap canvas{width:100%;height:100%;display:block}
    .js-rsm-minimap .minimap-label{position:absolute;top:4px;left:8px;font-size:9px;font-weight:600;text-transform:uppercase;letter-spacing:.5px;color:${COLORS.textMuted};pointer-events:none;user-select:none}
    .js-rsm-minimap .minimap-toggle{position:absolute;top:3px;right:5px;width:18px;height:18px;border:none;background:transparent;cursor:pointer;font-size:10px;color:${COLORS.textMuted};display:flex;align-items:center;justify-content:center;border-radius:3px;transition:all .15s}
    .js-rsm-minimap .minimap-toggle:hover{background:${COLORS.bg};color:${COLORS.text}}
    .js-rsm-minimap.minimized{width:80px;height:24px;cursor:pointer}
    .js-rsm-minimap.minimized canvas{display:none}
    .js-rsm-minimap.minimized .minimap-label{top:5px;left:10px}

    /* DATA SOURCE MARKER on nodes */
    .ds-marker{position:absolute;font-size:8px;bottom:-2px;right:-2px}

    /* RIGHT-CLICK CONTEXT MENU */
    .js-rsm-ctx-menu{position:absolute;z-index:200;background:${COLORS.surface};border:1px solid ${COLORS.border};border-radius:8px;box-shadow:0 4px 20px rgba(0,0,0,.15);padding:4px 0;min-width:220px;display:none;font-family:${FONT};animation:ctxFadeIn .12s ease}
    @keyframes ctxFadeIn{from{opacity:0;transform:translateY(-4px)}to{opacity:1;transform:translateY(0)}}
    .js-rsm-ctx-menu.visible{display:block}
    .ctx-menu-item{display:flex;align-items:center;gap:10px;padding:9px 16px;font-size:13px;color:${COLORS.text};cursor:pointer;transition:background .1s,color .1s;user-select:none}
    .ctx-menu-item:hover{background:${COLORS.accentBg};color:${COLORS.accent}}
    .ctx-menu-item .ctx-menu-icon{width:20px;text-align:center;font-size:14px;flex-shrink:0}
    .ctx-menu-item .ctx-menu-label{flex:1}
    .ctx-menu-item .ctx-menu-hint{font-size:10px;color:${COLORS.textMuted};margin-left:auto}
    .ctx-menu-divider{height:1px;background:${COLORS.border};margin:4px 0}
    .ctx-menu-header{padding:8px 16px 4px;font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.5px;color:${COLORS.textMuted};user-select:none}

    /* FOCUS TREE TOGGLE */
    .focus-tree-toggle{display:flex;gap:3px;margin-bottom:14px;background:${COLORS.bg};border-radius:8px;padding:3px}
    .focus-tree-toggle button{flex:1;height:30px;border:none;border-radius:6px;font-size:11px;font-family:${FONT};cursor:pointer;background:transparent;color:${COLORS.textSecondary};font-weight:500;transition:all .2s;display:flex;align-items:center;justify-content:center;gap:5px}
    .focus-tree-toggle button.active{background:${COLORS.surface};color:${COLORS.accent};box-shadow:0 1px 3px rgba(0,0,0,.1)}
    .focus-tree-toggle button .ft-icon{font-size:13px}

    /* IMPACT PATH NAVIGATOR */
    .js-rsm-impact-paths{position:absolute;top:56px;left:56px;z-index:55;background:${COLORS.surface};border:1px solid ${COLORS.border};border-radius:10px;padding:0;width:340px;max-height:50vh;display:none;box-shadow:0 4px 20px rgba(0,0,0,.12);font-size:12px;overflow:hidden}
    .js-rsm-impact-paths.visible{display:flex;flex-direction:column}
    .impact-paths-header{display:flex;align-items:center;padding:10px 14px;border-bottom:1px solid ${COLORS.border};gap:8px}
    .impact-paths-header h4{flex:1;font-size:12px;font-weight:600;color:${COLORS.text}}
    .impact-paths-header .paths-nav{display:flex;gap:4px}
    .impact-paths-header .paths-nav button{width:26px;height:26px;border:1px solid ${COLORS.border};border-radius:5px;background:${COLORS.surface};cursor:pointer;font-size:12px;color:${COLORS.text};display:flex;align-items:center;justify-content:center;transition:all .12s}
    .impact-paths-header .paths-nav button:hover{border-color:${COLORS.accent};color:${COLORS.accent}}
    .impact-paths-header .paths-nav button:disabled{opacity:.3;cursor:default}
    .impact-paths-close{width:24px;height:24px;border:none;background:${COLORS.bg};border-radius:5px;cursor:pointer;font-size:12px;color:${COLORS.textMuted};display:flex;align-items:center;justify-content:center;transition:all .12s}
    .impact-paths-close:hover{background:${COLORS.border};color:${COLORS.text}}
    .impact-paths-list{overflow-y:auto;max-height:calc(50vh - 48px);padding:6px 0}
    .impact-path-item{padding:8px 14px;cursor:pointer;transition:background .1s;border-left:3px solid transparent}
    .impact-path-item:hover{background:${COLORS.accentBg}}
    .impact-path-item.active{background:${COLORS.dangerBg};border-left-color:${COLORS.danger}}
    .impact-path-item .path-target{font-weight:600;font-size:12px;color:${COLORS.text};margin-bottom:3px;display:flex;align-items:center;gap:6px}
    .impact-path-item .path-target .path-sla{font-size:9px;padding:1px 5px;border-radius:3px;font-weight:500}
    .impact-path-item .path-chain{font-size:10px;color:${COLORS.textMuted};line-height:1.5;word-break:break-all}
    .impact-path-item .path-chain .path-arrow{color:${COLORS.danger};font-weight:700;margin:0 3px}
    .impact-path-item .path-depth{font-size:10px;color:${COLORS.textMuted};margin-top:2px}

    /* MODE DROPDOWN */
    .mode-dropdown{position:relative}
    .mode-dropdown-trigger{height:32px;padding:0 10px 0 12px;border:1px solid ${COLORS.border};border-radius:6px;background:${COLORS.surface};cursor:pointer;font-size:12px;font-family:${FONT};color:${COLORS.text};display:flex;align-items:center;gap:6px;transition:all .15s;font-weight:500}
    .mode-dropdown-trigger:hover{border-color:${COLORS.accent};color:${COLORS.accent}}
    .mode-dropdown-trigger.active-model{background:${COLORS.accentBg};border-color:${COLORS.accent};color:${COLORS.accent}}
    .mode-dropdown-trigger.active-impact{background:${COLORS.dangerBg};border-color:${COLORS.danger};color:${COLORS.danger}}
    .mode-dropdown-trigger .mode-icon{font-size:14px}
    .mode-dropdown-trigger .mode-arrow{font-size:10px;margin-left:2px;transition:transform .2s}
    .mode-dropdown.open .mode-dropdown-trigger .mode-arrow{transform:rotate(180deg)}
    .mode-dropdown-menu{position:absolute;top:calc(100% + 6px);left:0;min-width:300px;background:${COLORS.surface};border:1px solid ${COLORS.border};border-radius:10px;box-shadow:0 8px 30px rgba(0,0,0,.12);z-index:200;display:none;overflow:hidden}
    .mode-dropdown.open .mode-dropdown-menu{display:block}
    .mode-option{padding:12px 16px;cursor:pointer;transition:background .12s;border-bottom:1px solid ${COLORS.bg}}
    .mode-option:last-child{border-bottom:none}
    .mode-option:hover{background:${COLORS.bg}}
    .mode-option.selected{background:${COLORS.accentBg}}
    .mode-option.selected.impact-selected{background:${COLORS.dangerBg}}
    .mode-option-header{display:flex;align-items:center;gap:8px;margin-bottom:4px}
    .mode-option-icon{font-size:18px;width:28px;height:28px;border-radius:6px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
    .mode-option-icon.model-icon{background:${COLORS.accentBg};color:${COLORS.accent}}
    .mode-option-icon.impact-icon{background:${COLORS.dangerBg};color:${COLORS.danger}}
    .mode-option-title{font-size:13px;font-weight:600;color:${COLORS.text}}
    .mode-option-desc{font-size:11px;color:${COLORS.textSecondary};line-height:1.5;margin-left:36px}
    .mode-option-check{margin-left:auto;font-size:14px;color:${COLORS.accent};display:none}
    .mode-option.selected .mode-option-check{display:block}
    .mode-option.selected.impact-selected .mode-option-check{color:${COLORS.danger}}

    /* SLA HEATMAP LEGEND */
    .sla-legend{display:flex;flex-wrap:wrap;gap:6px;margin-top:8px}
    .sla-legend-item{display:flex;align-items:center;gap:4px;font-size:10px;color:${COLORS.textSecondary}}
    .sla-legend-dot{width:10px;height:10px;border-radius:2px}

    /* EXPORT BUTTONS */
    .export-controls{display:flex;gap:4px;align-items:center}
    .export-btn{height:32px;padding:0 10px;border:1px solid ${COLORS.border};border-radius:6px;background:${COLORS.surface};cursor:pointer;font-size:11px;font-family:${FONT};color:${COLORS.text};display:flex;align-items:center;gap:5px;transition:all .15s;font-weight:500}
    .export-btn:hover{border-color:${COLORS.accent};color:${COLORS.accent}}
    .export-btn .export-icon{font-size:13px}

    /* UPSTREAM SERVICES in context panel */
    .upstream-svc-table{width:100%;border-collapse:collapse;font-size:11px;margin-top:6px}
