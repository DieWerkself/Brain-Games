function generateMockData() {
  const nodes = [];
  const edges = [];
  let idCounter = 1;
  function uid() { return 'ci_' + (idCounter++); }
  function pick(arr) { return arr[Math.floor(Math.random() * arr.length)]; }
  function randInt(a, b) { return Math.floor(Math.random() * (b - a + 1)) + a; }
  function randIP() { return `10.${randInt(0,255)}.${randInt(0,255)}.${randInt(1,254)}`; }
  function randHostname(short, idx) { return `${short.toLowerCase()}-${String(idx).padStart(3,'0')}.corp.local`; }
  const TAG_POOL = ['критичный','резерв','мониторинг','бэкап','HA','DR','legacy','cloud','on-prem','DMZ','PCI-DSS','core','edge','mgmt','test','pilot'];

  const ciByType = {};
  const ciCounts = {
    'ИТ-сервис':20,'ИТ-система':30,'Прикладное ПО':50,
    'Компонент прикладного ПО':60,'База данных':50,'Кластер':25,
    'Виртуальное рабочее место':30,'Пул виртуальных рабочих мест':20,
    'Частная подписка':20,'Виртуальный сервер':80,
    'Кластер контейнеризации':25,'Публичная подписка':15,
    'Кластер виртуализации':25,'Сервер':100,'Том/раздел':70,
    'Сетевое оборудование':50,'Коммутатор SAN':30,'СХД':30,
    'Шасси':25,'Устройство резервного копирования':20,'Шкаф':30,
    'ПАК':15,'Оборудование не Банка':15,'Площадка':30,
    'Кондиционер':25,'ИБП':25,
  };

  const incidentTitles = [
    'Недоступность сервиса','Высокая нагрузка CPU','Ошибка репликации БД',
    'Потеря связности','Сбой авторизации','Переполнение диска',
    'Таймаут соединения','Ошибка сертификата','Деградация производительности',
  ];

  CI_TYPE_HIERARCHY.forEach(type => {
    ciByType[type] = [];
    const count = ciCounts[type] || 2;
    for (let i = 0; i < count; i++) {
      const incCount = randInt(0, 5);
      const incidents = [];
      for (let j = 0; j < incCount; j++) {
        const daysAgo = randInt(0, 30);
        const d = new Date(); d.setDate(d.getDate() - daysAgo);
        incidents.push({
          id: 'INC-' + String(randInt(10000, 99999)),
          title: pick(incidentTitles),
          priority: pick(['Критический', 'Высокий', 'Средний', 'Низкий']),
          date: d.toISOString().slice(0, 10),
        });
      }
      const shortName = SHORT_NAMES[type];
      const ciName = `${shortName}-${String(i+1).padStart(3,'0')}`;
      const tagCount = randInt(1, 4);
      const tags = [];
      for (let t = 0; t < tagCount; t++) { const tag = pick(TAG_POOL); if (!tags.includes(tag)) tags.push(tag); }
      const ci = {
        id: uid(),
        name: ciName,
        type, status: pick(STATUSES), environment: pick(ENVIRONMENTS),
        site: pick(SITES), responsible: pick(RESPONSIBLES),
        incidents,
        incidentCount: incCount,
        sla: pick(SLA_VALUES),
        dataSource: Math.random() > 0.35 ? 'auto' : 'manual',
        lastUpdate: new Date(Date.now() - randInt(0, 90) * 86400000).toISOString().slice(0, 10),
        description: `${type} — ${ciName}`,
        ip: randIP(),
        hostname: randHostname(shortName, i+1),
        tags,
      };
      nodes.push(ci);
      ciByType[type].push(ci);
    }
  });

  for (let lvl = 0; lvl < CI_TYPE_HIERARCHY.length - 1; lvl++) {
    const parents = ciByType[CI_TYPE_HIERARCHY[lvl]];
    const children = ciByType[CI_TYPE_HIERARCHY[lvl + 1]];
    if (!parents?.length || !children?.length) continue;
    children.forEach(child => {
      const n = Math.min(parents.length, randInt(1, 2));
      const shuffled = [...parents].sort(() => Math.random() - 0.5);
      for (let p = 0; p < n; p++) {
        edges.push({ source: shuffled[p].id, target: child.id, type: 'depends_on', label: 'зависит от' });
      }
    });
  }

  for (let i = 0; i < 80; i++) {
    const a = randInt(0, CI_TYPE_HIERARCHY.length - 4);
    const b = a + randInt(2, 3);
    if (b >= CI_TYPE_HIERARCHY.length) continue;
    const tA = CI_TYPE_HIERARCHY[a], tB = CI_TYPE_HIERARCHY[b];
    if (!ciByType[tA]?.length || !ciByType[tB]?.length) continue;
    edges.push({ source: pick(ciByType[tA]).id, target: pick(ciByType[tB]).id, type: 'influences', label: 'влияет на' });
  }

  return { nodes, edges };
}


