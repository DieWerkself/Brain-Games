        <span class="badge-close js-root-badge-close">✕</span>
      </div>
    `;
  }

  _filterHTML(id, title, items, activeSet, colors=false) {
    if (!this._countCache) {
      this._countCache = { types:{}, statuses:{}, sites:{}, environments:{} };
      this.data.nodes.forEach(n => {
        this._countCache.types[n.type] = (this._countCache.types[n.type]||0) + 1;
        this._countCache.statuses[n.status] = (this._countCache.statuses[n.status]||0) + 1;
        this._countCache.sites[n.site] = (this._countCache.sites[n.site]||0) + 1;
        this._countCache.environments[n.environment] = (this._countCache.environments[n.environment]||0) + 1;
      });
    }
    const cacheMap = {'f-types':'types','f-stat':'statuses','f-site':'sites','f-env':'environments'};
    const counts = this._countCache[cacheMap[id]] || {};
    let h = `<div class="filter-section"><div class="section-title" data-sec="${id}"><span class="arrow" data-sec="${id}">▼</span> ${title}</div><div class="section-body" data-sec="${id}">`;
    items.forEach(item => {
      const ck = activeSet.has(item) ? 'checked' : '';
      const dot = colors ? `<span class="chip-color" style="background:${CI_TYPE_COLORS[item]}"></span>` : '';
      h += `<label class="filter-chip"><input type="checkbox" ${ck} data-fid="${id}" data-val="${item}">${dot}<span class="chip-label">${item}</span><span class="chip-count">${counts[item]||0}</span></label>`;
    });
    h += '</div></div>';
    return h;
  }

  _renderPresets() {
    const el = document.querySelector('.js-sf-section');
    if (!el) return;
    const allPresets = [...DEFAULT_PRESETS.map(p => ({...p, isDefault: true})), ...this.savedFilters.map(p => ({...p, isDefault: false}))];
