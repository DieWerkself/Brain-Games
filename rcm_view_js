      const checked = !this.collapsedLayers.has(zone.id) ? 'checked' : '';
      layerHTML += `<label class="layer-zone"><input type="checkbox" ${checked} data-zone="${zone.id}"><span class="zone-icon">${zone.icon}</span><span class="zone-name">${zone.name}</span><span class="zone-count">${typeCount}</span></label>`;
