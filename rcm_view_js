/* ═══════════════════════════════════════════════════════════════════════════
   5. ПРИЛОЖЕНИЕ
   ═══════════════════════════════════════════════════════════════════════════ */

class RSMApp {
  constructor() {
    this.data = generateMockData();
    this.cy = null;
    this.direction = 'top-down';
    this.filters = {
      types: new Set(CI_TYPE_HIERARCHY),
      statuses: new Set(STATUSES),
      sites: new Set(SITES),
      environments: new Set(ENVIRONMENTS),
    };
    this.savedFilters = this._loadSaved();
    this.searchQuery = '';
    this.groupMode = true;
    this.expandedGroups = new Set();
    this.selectedNode = null;
    this.rootCI = null;
    this._rootSearchQuery = '';
    this._filterDebounce = null;
    this._filteredCache = null;
    this._filteredCacheDirty = true;
    this._nodeIndex = new Map();
    this.data.nodes.forEach(n => this._nodeIndex.set(n.id, n));
    this._adjacency = this._buildAdjacency();
    this._minimapCanvas = null;
    this._minimapCtx = null;
    this._minimapMinimized = false;
    this._minimapRAF = null;
    this._layoutWorker = this._createLayoutWorker();

    // v4.0: New state
    this._history = [];       // Undo stack
    this._future = [];        // Redo stack
    this._historyMax = 50;
    this._skipHistory = false; // Flag to skip recording during undo/redo
    this.impactMode = false;
    this.impactSourceId = null;
    this.impactAffected = new Set();
    this.impactChainMode = 'full'; // 'full' = show all intermediate types, 'filtered' = only user-selected types
    this.activeMode = null; // null | 'model' | 'impact'
    this.collapsedLayers = new Set(); // Collapsed zone IDs
    this.dataSourceFilter = 'all'; // 'all', 'auto', 'manual'
    this.focusTreeMode = false; // Focus tree: show only one direction
    this.slaHeatmap = false; // SLA heatmap mode
    this._impactPaths = []; // Reconstructed paths for Impact Path Navigator
    this._impactCurrentPath = -1; // Currently highlighted path index
    this._impactBfsParent = null; // BFS parent map for path reconstruction
    this._preImpactExpandedGroups = null; // Saved groups before impact auto-expand

    // v5.1: Diff / Snapshot comparison
    this._snapshots = this._loadSnapshots();
    this._diffMode = false;
    this._diffResult = null; // { added, removed, changed, unchanged }
    this._diffSelectedSnaps = []; // [snapId1, snapId2] for comparison
  }

  init() {
    injectStyles();
    buildDOM();
    this._buildSidebar();
    this._initCy();
    this._bindHeader();
    this._bindSidebar();
    this._bindKeyboard();
    this._initMinimap();
    this._bindCtxMenuActions();
    this._recordHistory(); // Record initial state
    this._loadSharedPresetFromURL(); // Check for shared preset in URL
    if (!this.rootCI) this._showQuickActions();
    console.log('[RSM] Initialized. Nodes:', this.data.nodes.length, '| Edges:', this.data.edges.length);
  }

  /* ═══════════════════════════════════════════════════════════════════════
     HISTORY (UNDO / REDO)
     ═══════════════════════════════════════════════════════════════════════ */
  _getStateSnapshot() {
    return {
      types: [...this.filters.types],
      statuses: [...this.filters.statuses],
      sites: [...this.filters.sites],
      environments: [...this.filters.environments],
      direction: this.direction,
      groupMode: this.groupMode,
      expandedGroups: [...this.expandedGroups],
      rootCI: this.rootCI,
      searchQuery: this.searchQuery,
      collapsedLayers: [...this.collapsedLayers],
      dataSourceFilter: this.dataSourceFilter,
      focusTreeMode: this.focusTreeMode,
    };
  }

  _applyStateSnapshot(snap) {
    this.filters.types = new Set(snap.types);
    this.filters.statuses = new Set(snap.statuses);
    this.filters.sites = new Set(snap.sites);
    this.filters.environments = new Set(snap.environments);
    this.direction = snap.direction;
    this.groupMode = snap.groupMode;
    this.expandedGroups = new Set(snap.expandedGroups);
    this.rootCI = snap.rootCI;
    this.searchQuery = snap.searchQuery || '';
    this.collapsedLayers = new Set(snap.collapsedLayers || []);
    this.dataSourceFilter = snap.dataSourceFilter || 'all';
    this.focusTreeMode = snap.focusTreeMode || false;
  }

  _recordHistory() {
    if (this._skipHistory) return;
    const snap = this._getStateSnapshot();
    this._history.push(JSON.stringify(snap));
    if (this._history.length > this._historyMax) this._history.shift();
    this._future = []; // Clear redo stack on new action
    this._updateHistoryButtons();
  }

  _undo() {
    if (this._history.length <= 1) return; // Need at least 2 states (current + previous)
    this._future.push(this._history.pop()); // Move current to future
    const prev = JSON.parse(this._history[this._history.length - 1]);
    this._skipHistory = true;
    this._applyStateSnapshot(prev);
    this._buildSidebar();
    this._bindSidebar();
    this._refresh();
    this._skipHistory = false;
    this._updateHistoryButtons();
  }

  _redo() {
    if (this._future.length === 0) return;
    const next = JSON.parse(this._future.pop());
    this._history.push(JSON.stringify(next));
    this._skipHistory = true;
    this._applyStateSnapshot(next);
    this._buildSidebar();
    this._bindSidebar();
    this._refresh();
    this._skipHistory = false;
    this._updateHistoryButtons();
  }

  _updateHistoryButtons() {
    const undo = document.querySelector('.js-btn-undo');
    const redo = document.querySelector('.js-btn-redo');
    if (undo) undo.disabled = this._history.length <= 1;
    if (redo) redo.disabled = this._future.length === 0;
  }

  _bindKeyboard() {
    document.addEventListener('keydown', e => {
      if ((e.ctrlKey || e.metaKey) && e.key === 'z' && !e.shiftKey) {
        e.preventDefault();
        this._undo();
      }
      if ((e.ctrlKey || e.metaKey) && (e.key === 'y' || (e.key === 'z' && e.shiftKey))) {
        e.preventDefault();
        this._redo();
      }
      if (e.key === 'Escape') {
        if (this.impactMode) this._exitImpactMode();
        this._closeContextPanel();
        this._hideCtxMenu();
        this._hideImpactPaths();
      }
    });
  }

  /* ═══════════════════════════════════════════════════════════════════════
     IMPACT ANALYSIS
     ═══════════════════════════════════════════════════════════════════════ */
  _toggleImpactMode() {
    // Legacy method - now delegates to mode management
    if (this.activeMode === 'impact') {
      this._activateMode('impact'); // Will deactivate since same mode
    } else {
      this._activateMode('impact');
    }
  }

  _runImpactAnalysis(ciId) {
    if (!this.cy) return;
    this.impactSourceId = ciId;
    this.impactAffected = new Set();

    // Show loading overlay for large graphs
    const main = document.querySelector('.js-rsm-main');
    let loadEl = document.querySelector('.js-rsm-impact-loading');
    if (!loadEl) {
      loadEl = document.createElement('div');
      loadEl.classList.add('js-rsm-impact-loading');
      loadEl.style.cssText = `position:absolute;top:0;left:0;right:0;bottom:0;background:rgba(244,245,247,.85);z-index:60;display:none;align-items:center;justify-content:center;flex-direction:column;gap:10px;font-family:${FONT}`;
      loadEl.innerHTML = `<div style="font-size:14px;color:${COLORS.textSecondary}">Анализ влияния...</div><div style="font-size:11px;color:${COLORS.textMuted}" class="js-impact-progress"></div>`;
      main.appendChild(loadEl);
    }
    loadEl.style.display = 'flex';
    const progressEl = document.querySelector('.js-impact-progress');

    // === PRE-IMPACT: Save current type filters ===
    if (!this._preImpactTypeFilters) {
      this._preImpactTypeFilters = new Set(this.filters.types);
    }

    if (this.impactChainMode === 'full') {
      // FULL CHAIN MODE: auto-expand type filters to show all intermediate layers
      // Run a preliminary BFS on the full adjacency graph to discover all affected types
      const preQueue = [ciId];
      const preVisited = new Set([ciId]);
      const preDepthMap = new Map([[ciId, 0]]);
      while (preQueue.length) {
        const cur = preQueue.shift();
        const entry = this._adjacency[cur];
        if (!entry) continue;
        const curDepth = preDepthMap.get(cur);
        if (curDepth >= IMPACT_MAX_DEPTH) continue;
        for (const parent of entry.parents) {
          if (!preVisited.has(parent)) {
            if (preVisited.size >= IMPACT_MAX_NODES + 1) break;
            preVisited.add(parent);
            preDepthMap.set(parent, curDepth + 1);
            preQueue.push(parent);
          }
        }
      }
      // Add types of all affected nodes to the type filter
      let filtersChanged = false;
      preVisited.forEach(id => {
        const nd = this._nodeIndex.get(id);
        if (nd && !this.filters.types.has(nd.type)) {
          this.filters.types.add(nd.type);
          filtersChanged = true;
        }
      });
      // If filters changed, rebuild graph elements before running impact
      if (filtersChanged) {
        this._invalidateFilterCache();
        this.cy.startBatch();
        this.cy.elements().remove();
        const els = this._buildElements();
        this.cy.add(els);
        this.cy.endBatch();
        this._runLayout(false);
        this._buildSidebar();
        this._bindSidebar();
      }
    } else {
      // FILTERED MODE: restore original user filters (only show selected types)
      this.filters.types = new Set(this._preImpactTypeFilters);
      this._invalidateFilterCache();
      this.cy.startBatch();
      this.cy.elements().remove();
      const els = this._buildElements();
      this.cy.add(els);
      this.cy.endBatch();
      this._runLayout(false);
      this._buildSidebar();
      this._bindSidebar();
    }

    // Use requestAnimationFrame to allow the loading overlay to render
    requestAnimationFrame(() => {
      this._runImpactAnalysisCore(ciId, progressEl, loadEl);
    });
  }

  _runImpactAnalysisCore(ciId, progressEl, loadEl) {
    // === PHASE 1: BFS with depth & node limits ===
    const queue = [ciId];
    const visited = new Set([ciId]);
    const depthMap = new Map([[ciId, 0]]);
    const bfsParent = new Map();
    let truncated = false;

    while (queue.length) {
      const cur = queue.shift();
      const entry = this._adjacency[cur];
      if (!entry) continue;
      const curDepth = depthMap.get(cur);
      if (curDepth >= IMPACT_MAX_DEPTH) continue; // depth limit
      for (const parent of entry.parents) {
        if (!visited.has(parent)) {
          if (this.impactAffected.size >= IMPACT_MAX_NODES) { truncated = true; break; }
          visited.add(parent);
          depthMap.set(parent, curDepth + 1);
          bfsParent.set(parent, cur);
          this.impactAffected.add(parent);
          queue.push(parent);
        }
      }
      if (truncated) break;
    }

    // === PHASE 2: Build chain edges from BFS parent map (O(n), not O(n*depth)) ===
    const chainEdges = [];
    const addedChainKeys = new Set();

    // Each BFS parent entry IS one chain edge — no need to trace full paths
    bfsParent.forEach((fromNode, toNode) => {
      if (addedChainKeys.size >= IMPACT_MAX_CHAIN_EDGES) return;
      let visSource = fromNode;
      let visTarget = toNode;
      if (this.groupMode) {
        const fromData = this._nodeIndex.get(fromNode);
        const toData = this._nodeIndex.get(toNode);
        if (fromData && !this.expandedGroups.has(fromData.type)) visSource = 'g_' + fromData.type;
        if (toData && !this.expandedGroups.has(toData.type)) visTarget = 'g_' + toData.type;
      }
      if (visSource !== visTarget) {
        // Safety check: ensure both source and target nodes exist in the graph
        if (this.cy.getElementById(visSource).length === 0 || this.cy.getElementById(visTarget).length === 0) return;
        const key = visSource + '->' + visTarget;
        if (!addedChainKeys.has(key)) {
          addedChainKeys.add(key);
          chainEdges.push({
            group: 'edges',
            data: { id: 'impact_chain_' + key, source: visSource, target: visTarget, edgeType: 'impact_chain' },
            classes: 'impact-chain-edge',
          });
        }
      }
    });

    // === PHASE 3: Apply visual styles in a single batch ===
    this.cy.startBatch();

    // Remove old impact chain edges
    this.cy.edges('.impact-chain-edge').remove();
    this.cy.elements().removeClass('impact-source impact-affected impact-affected-deep impact-faded impact-edge');

    // Fade everything
    this.cy.elements().addClass('impact-faded');

    // Build lookup sets for fast edge matching
    const affectedAndSource = new Set([ciId, ...this.impactAffected]);
    const affectedTypes = new Set();
    const srcData = this._nodeIndex.get(ciId);
    if (srcData) affectedTypes.add(srcData.type);

    // Highlight source
    const sourceNode = this.cy.getElementById(ciId);
    if (sourceNode.length) {
      sourceNode.removeClass('impact-faded').addClass('impact-source');
    } else if (this.groupMode) {
      if (srcData) {
        const gNode = this.cy.getElementById('g_' + srcData.type);
        if (gNode.length) gNode.removeClass('impact-faded').addClass('impact-source');
      }
    }

    // Highlight affected nodes
    this.impactAffected.forEach(id => {
      const nd = this._nodeIndex.get(id);
      if (nd) affectedTypes.add(nd.type);
      const node = this.cy.getElementById(id);
      if (node.length) {
        const depth = depthMap.get(id) || 1;
        node.removeClass('impact-faded').addClass(depth <= 2 ? 'impact-affected' : 'impact-affected-deep');
      }
      if (nd && this.groupMode && !this.expandedGroups.has(nd.type)) {
        const gNode = this.cy.getElementById('g_' + nd.type);
        if (gNode.length) gNode.removeClass('impact-faded').addClass('impact-affected');
      }
    });

    // Highlight existing edges between affected nodes (use filter instead of forEach)
    this.cy.edges().filter(edge => {
      const src = edge.source().id();
      const tgt = edge.target().id();
      let srcIn = affectedAndSource.has(src);
      let tgtIn = affectedAndSource.has(tgt);
      if (!srcIn && src.startsWith('g_')) srcIn = affectedTypes.has(src.slice(2));
      if (!tgtIn && tgt.startsWith('g_')) tgtIn = affectedTypes.has(tgt.slice(2));
      return srcIn && tgtIn;
    }).removeClass('impact-faded').addClass('impact-edge');

    // Add chain edges
    if (chainEdges.length > 0) {
      this.cy.add(chainEdges);
      this.cy.edges('.impact-chain-edge').removeClass('impact-faded').addClass('impact-edge');
    }

    this.cy.endBatch();

    // Hide loading overlay
    if (loadEl) loadEl.style.display = 'none';

    // === PHASE 4: Auto-expand groups that contain affected nodes ===
    if (this.groupMode && this.impactAffected.size > 0) {
      this._preImpactExpandedGroups = new Set(this.expandedGroups);
      const activeTypes = this.filters.types;
      this.impactAffected.forEach(id => {
        const nd = this._nodeIndex.get(id);
        if (nd && activeTypes.has(nd.type)) this.expandedGroups.add(nd.type);
      });
      const srcNd = this._nodeIndex.get(ciId);
      if (srcNd && activeTypes.has(srcNd.type)) this.expandedGroups.add(srcNd.type);
      // Re-render with expanded groups but keep impact styles
      // We need to rebuild elements and re-apply impact
      if (loadEl) loadEl.style.display = 'flex';
      if (progressEl) progressEl.textContent = 'Раскрытие групп...';
      this.cy.startBatch();
      this.cy.elements().remove();
      const els = this._buildElements();
      this.cy.add(els);
      this.cy.endBatch();
      this._runLayout(false);
      // Re-apply impact styles after layout (longer timeout for large graphs)
      const reapplyDelay = this.impactAffected.size > 100 ? 800 : 400;
      setTimeout(() => {
        this._reapplyImpactStyles(ciId, depthMap, bfsParent, chainEdges, affectedAndSource, affectedTypes);
        if (loadEl) loadEl.style.display = 'none';
      }, reapplyDelay);
    }

    // Show banner
    const chainCount = addedChainKeys.size;
    const banner = document.querySelector('.js-rsm-impact-banner');
    const infoSpan = banner.querySelector('.impact-info');
    if (infoSpan) {
      let text = `\u26a1 Impact-\u0430\u043d\u0430\u043b\u0438\u0437: \u0437\u0430\u0442\u0440\u043e\u043d\u0443\u0442\u043e <span class="impact-count js-impact-count">${this.impactAffected.size}</span> CI, <span class="impact-count">${chainCount}</span> \u0441\u0432\u044f\u0437\u0435\u0439 \u0432\u043b\u0438\u044f\u043d\u0438\u044f`;
      if (truncated) {
        text += ` <span style="color:${COLORS.warning};font-weight:600">(\u043e\u0433\u0440\u0430\u043d\u0438\u0447\u0435\u043d\u043e: \u0433\u043b\u0443\u0431\u0438\u043d\u0430 ${IMPACT_MAX_DEPTH}, \u043c\u0430\u043a\u0441 ${IMPACT_MAX_NODES} CI)</span>`;
      }
      if (this.impactChainMode === 'filtered') {
        text += ` <span style="color:${COLORS.accent};font-weight:500">(\u0442\u043e\u043b\u044c\u043a\u043e \u0432\u044b\u0431\u0440\u0430\u043d\u043d\u044b\u0435 \u0442\u0438\u043f\u044b)</span>`;
      }
      infoSpan.innerHTML = text;
    }
    // Update toggle active state
    document.querySelectorAll('#impact-chain-toggle .ict-btn').forEach(b => {
      b.classList.toggle('active', b.dataset.mode === this.impactChainMode);
    });
    banner.classList.add('visible');

    // === PHASE 5: Show Impact Path Navigator ===
    this._showImpactPaths(bfsParent, ciId);
  }

  _reapplyImpactStyles(ciId, depthMap, bfsParent, chainEdges, affectedAndSource, affectedTypes) {
    if (!this.cy) return;
    this.cy.startBatch();
    this.cy.elements().addClass('impact-faded').removeClass('impact-source impact-affected impact-affected-deep impact-edge');
    // Source
    const sourceNode = this.cy.getElementById(ciId);
    if (sourceNode.length) sourceNode.removeClass('impact-faded').addClass('impact-source');
    // Affected
    this.impactAffected.forEach(id => {
      const node = this.cy.getElementById(id);
      if (node.length) {
        const depth = depthMap.get(id) || 1;
        node.removeClass('impact-faded').addClass(depth <= 2 ? 'impact-affected' : 'impact-affected-deep');
      }
    });
    // Edges
    this.cy.edges().filter(edge => {
      const src = edge.source().id();
      const tgt = edge.target().id();
      return affectedAndSource.has(src) && affectedAndSource.has(tgt);
    }).removeClass('impact-faded').addClass('impact-edge');
    // Re-add chain edges
    this.cy.edges('.impact-chain-edge').remove();
    if (chainEdges.length > 0) {
      // Rebuild chain edges for expanded view
      const newChainEdges = [];
      const addedKeys = new Set();
      bfsParent.forEach((fromNode, toNode) => {
        if (addedKeys.size >= IMPACT_MAX_CHAIN_EDGES) return;
        // Safety check: ensure both nodes exist in the graph
        if (this.cy.getElementById(fromNode).length === 0 || this.cy.getElementById(toNode).length === 0) return;
        const key = fromNode + '->' + toNode;
        if (!addedKeys.has(key)) {
          addedKeys.add(key);
          newChainEdges.push({
            group: 'edges',
            data: { id: 'impact_chain_' + key, source: fromNode, target: toNode, edgeType: 'impact_chain' },
            classes: 'impact-chain-edge',
          });
        }
      });
      this.cy.add(newChainEdges);
      this.cy.edges('.impact-chain-edge').removeClass('impact-faded').addClass('impact-edge');
    }
    this.cy.endBatch();
  }

  _exitImpactMode() {
    this.impactMode = false;
    this.impactSourceId = null;
    this.impactAffected.clear();
    this.impactChainMode = 'full'; // Reset to default
    // Reset toggle UI
    document.querySelectorAll('#impact-chain-toggle .ict-btn').forEach(b => {
      b.classList.toggle('active', b.dataset.mode === 'full');
    });
    this.activeMode = null;
    this._updateModeUI();
    document.querySelector('.js-rsm-impact-banner').classList.remove('visible');
    // Reset banner text
    const infoSpan = document.querySelector('.js-rsm-impact-banner .impact-info');
    if (infoSpan) {
      infoSpan.innerHTML = `\u26a1 Impact-\u0430\u043d\u0430\u043b\u0438\u0437: \u0437\u0430\u0442\u0440\u043e\u043d\u0443\u0442\u043e <span class="impact-count js-impact-count">0</span> CI`;
    }
    // Hide Impact Path Navigator
    this._hideImpactPaths();
    // Restore pre-impact expanded groups
    if (this._preImpactExpandedGroups) {
      this.expandedGroups = this._preImpactExpandedGroups;
      this._preImpactExpandedGroups = null;
    }
    // Restore pre-impact type filters
    if (this._preImpactTypeFilters) {
      this.filters.types = this._preImpactTypeFilters;
      this._preImpactTypeFilters = null;
      this._invalidateFilterCache();
      // Rebuild sidebar to reflect restored filters
      this._buildSidebar();
      this._bindSidebar();
    }
    if (this.cy) {
      this.cy.startBatch();
      // Remove dedicated impact chain edges
      this.cy.edges('.impact-chain-edge').remove();
      this.cy.elements().removeClass('impact-source impact-affected impact-affected-deep impact-faded impact-edge');
      this.cy.endBatch();
      // Rebuild with restored groups and filters
      this._refresh();
    }
  }

  /* ═══════════════════════════════════════════════════════════════════════
     ADJACENCY & BFS
     ═══════════════════════════════════════════════════════════════════════ */
  _buildAdjacency() {
    const adj = {};
    this.data.nodes.forEach(n => { adj[n.id] = { parents: new Set(), children: new Set() }; });
    this.data.edges.forEach(e => {
      if (adj[e.source]) adj[e.source].children.add(e.target);
      if (adj[e.target]) adj[e.target].parents.add(e.source);
    });
    return adj;
  }

  _getReachableFromRoot(rootId) {
    const reachable = new Set([rootId]);
    // Focus Tree Mode: restrict traversal direction
    const goDown = !this.focusTreeMode || this.focusTreeMode === 'down';
    const goUp = !this.focusTreeMode || this.focusTreeMode === 'up';
    if (goDown) {
      const qDown = [rootId];
      while (qDown.length) {
        const cur = qDown.shift();
        const entry = this._adjacency[cur];
        if (!entry) continue;
        for (const child of entry.children) {
          if (!reachable.has(child)) { reachable.add(child); qDown.push(child); }
        }
      }
    }
    if (goUp) {
      const qUp = [rootId];
      while (qUp.length) {
        const cur = qUp.shift();
        const entry = this._adjacency[cur];
        if (!entry) continue;
        for (const parent of entry.parents) {
          if (!reachable.has(parent)) { reachable.add(parent); qUp.push(parent); }
        }
      }
    }
    return reachable;
  }

  _computeTransitiveEdges(visibleIds) {
    const visSet = new Set(visibleIds);
    const transitiveEdges = [];
    const allTypesActive = CI_TYPE_HIERARCHY.every(t => this.filters.types.has(t));
    if (allTypesActive && this.collapsedLayers.size === 0) return transitiveEdges;

    // Build hidden set
    const hiddenIds = new Set();
    const allNodes = this.data.nodes;
    for (let i = 0; i < allNodes.length; i++) {
      if (!visSet.has(allNodes[i].id)) hiddenIds.add(allNodes[i].id);
    }
    if (hiddenIds.size === 0) return transitiveEdges;

    // Build direct edge index for O(1) lookup
    if (!this._directEdgeIndex) {
      this._directEdgeIndex = new Set();
      this.data.edges.forEach(e => this._directEdgeIndex.add(e.source + '→' + e.target));
    }
    const directIdx = this._directEdgeIndex;
    const seen = new Set();
    const MAX_BFS_DEPTH = 10; // prevent deep BFS chains

    for (const startId of visSet) {
      const entry = this._adjacency[startId];
      if (!entry || entry.children.size === 0) continue;
      // BFS through hidden nodes to find transitive targets
      const queue = [];
      for (const child of entry.children) queue.push({ id: child, depth: 1 });
      const visited = new Set([startId]);
      while (queue.length) {
        const { id: cur, depth } = queue.shift();
        if (visited.has(cur)) continue;
        visited.add(cur);
        if (visSet.has(cur)) {
          if (!directIdx.has(startId + '→' + cur)) {
            const key = startId + '→' + cur;
            if (!seen.has(key)) {
              seen.add(key);
              transitiveEdges.push({ source: startId, target: cur, type: 'transitive', label: 'транзитивная связь' });
            }
          }
        } else if (hiddenIds.has(cur) && depth < MAX_BFS_DEPTH) {
          const curEntry = this._adjacency[cur];
          if (curEntry) {
            for (const child of curEntry.children) {
              if (!visited.has(child)) queue.push({ id: child, depth: depth + 1 });
            }
          }
        }
      }
    }
    return transitiveEdges;
  }

