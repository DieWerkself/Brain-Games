        <button class="js-ft-down ${this.focusTreeMode==='down'?'active':''}"><span class="ft-icon">🔽</span> Дерево вниз</button>
        <button class="js-ft-up ${this.focusTreeMode==='up'?'active':''}"><span class="ft-icon">🔼</span> Дерево вверх</button>
      </div>
    `);

    // Group toggle
    c.insertAdjacentHTML('beforeend', `
