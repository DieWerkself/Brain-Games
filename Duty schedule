    engagementLog: [],
    customHolidays: {},
    globalApproved: false,
    auditLog: [],
    editingCell: null,
    activeJournalTab: 'audit'
  };

  // --- DOM references via classes ---
  const $el = (selector) => document.querySelector(selector);
  const $all = (selector) => document.querySelectorAll(selector);

  // --- Helpers ---
  const fmtDate = (day) => {
    const y = state.currentMonth.getFullYear();
    const m = state.currentMonth.getMonth();
    return String(day).padStart(2, '0') + '.' + String(m + 1).padStart(2, '0') + '.' + y;
  };

  const fmtDateTime = () => new Date().toLocaleString('ru-RU', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit', second: '2-digit' });

  const getDaysInMonth = (date) => new Date(date.getFullYear(), date.getMonth() + 1, 0).getDate();

  const isWeekend = (year, month, day) => {
    const d = new Date(year, month, day);
    return d.getDay() === 0 || d.getDay() === 6;
  };

  const isHoliday = (month, day) => HOLIDAYS_RU.includes(String(month + 1).padStart(2, '0') + '-' + String(day).padStart(2, '0'));

  const isCustomHoliday = (year, month, day) => !!state.customHolidays[year + '-' + String(month + 1).padStart(2, '0') + '-' + String(day).padStart(2, '0')];

  const isNonWorkingDay = (year, month, day) => isWeekend(year, month, day) || isHoliday(month, day) || isCustomHoliday(year, month, day);

  // Smart Focus: determine the "operational day" for a direction based on shift change time
  const getOperationalDay = (direction) => {
    const now = new Date();
    const y = state.currentMonth.getFullYear();
    const m = state.currentMonth.getMonth();
    if (y !== now.getFullYear() || m !== now.getMonth()) return -1;
    const parts = direction.shiftChangeTime.split(':');
    const hh = parseInt(parts[0]);
    const mm = parseInt(parts[1]);
    const shiftTime = new Date(now.getFullYear(), now.getMonth(), now.getDate(), hh, mm);
    return now < shiftTime ? now.getDate() - 1 : now.getDate();
  };

  const isPastDate = (day, direction) => {
    const now = new Date();
    if (state.currentMonth.getFullYear() < now.getFullYear()) return true;
    if (state.currentMonth.getFullYear() === now.getFullYear() && state.currentMonth.getMonth() < now.getMonth()) return true;
    if (state.currentMonth.getFullYear() === now.getFullYear() && state.currentMonth.getMonth() === now.getMonth()) {
      return day < getOperationalDay(direction);
    }
    return false;
  };

  const getShift = (empId, day) => {
    const key = empId + '_' + day;
    if (state.currentRole === 'specialist' && state.draftData[key]) return state.draftData[key];
    return state.scheduleData[key] || { shift: '', draft: false };
  };

  const setShift = (empId, day, shiftValue) => {
    const key = empId + '_' + day;
    const old = state.scheduleData[key] || { shift: '', draft: false };
    if (state.currentRole === 'specialist') {
      state.draftData[key] = { shift: shiftValue, draft: true };
    } else {
      state.scheduleData[key] = { shift: shiftValue, draft: false };
    }
    state.auditLog.unshift({
      timestamp: fmtDateTime(),
      user: state.currentRole === 'manager' ? 'Начальник смены' : 'Специалист',
      employee: (EMPLOYEES.find((e) => e.id === empId) || {}).name || empId,
      editDate: fmtDate(day),
      oldValue: old.shift || '—',
      newValue: shiftValue || '—'
    });
  };

  const calculateTotal = (empId, direction) => {
    const days = getDaysInMonth(state.currentMonth);
    let t = 0;
    for (let d = 1; d <= days; d++) {
      const s = getShift(empId, d).shift;
      if (s === 'Д/Н') t++;
      else if (s === 'Н') t++;
      else if (s === 'Д' && direction.countDayShift) t++;
    }
    return t;
  };

  const checkHole = (dirId, day) => {
    const dir = DIRECTIONS.find((d) => d.id === dirId);
    if (!dir || !dir.checkStaffing) return false;
    const y = state.currentMonth.getFullYear();
    const m = state.currentMonth.getMonth();
    if (dir.weekdaysOnly && isNonWorkingDay(y, m, day)) return false;
    const emps = EMPLOYEES.filter((e) => e.directionId === dirId);
    return !emps.some((emp) => {
      const s = getShift(emp.id, day).shift;
      return s === 'Д' || s === 'Н' || s === 'Д/Н';
    });
  };

  // Enhanced slot validation: Day slot (Д or Д/Н) max 1, Night slot (Н or Д/Н) max 1
  const validateSlot = (dirId, day, excludeEmpId, newShift) => {
    if (!newShift) return null;
    const emps = EMPLOYEES.filter((e) => e.directionId === dirId && e.id !== excludeEmpId);
    const occupiesDay = newShift === 'Д' || newShift === 'Д/Н';
    const occupiesNight = newShift === 'Н' || newShift === 'Д/Н';
    for (let i = 0; i < emps.length; i++) {
      const emp = emps[i];
      const s = getShift(emp.id, day).shift;
      if (!s) continue;
      const hasDaySlot = s === 'Д' || s === 'Д/Н';
      const hasNightSlot = s === 'Н' || s === 'Д/Н';
      if (occupiesDay && hasDaySlot) return 'Дневной слот на ' + fmtDate(day) + ' уже занят (' + emp.name + ')';
      if (occupiesNight && hasNightSlot) return 'Ночной слот на ' + fmtDate(day) + ' уже занят (' + emp.name + ')';
    }
    return null;
  };

  const canEdit = (empId, day) => {
    const emp = EMPLOYEES.find((e) => e.id === empId);
    if (!emp) return false;
    const dir = DIRECTIONS.find((d) => d.id === emp.directionId);
    if (!dir) return false;
    if (state.currentRole === 'specialist' && state.specialistDirection && state.specialistDirection !== dir.id) return false;
    if (state.globalApproved && state.currentRole !== 'manager') {
      if (!dir.unlocked) return false;
    }
    if (isPastDate(day, dir) && state.currentRole !== 'manager') return false;
    const y = state.currentMonth.getFullYear();
    const m = state.currentMonth.getMonth();
    if (dir.weekdaysOnly && isNonWorkingDay(y, m, day)) return false;
    return true;
  };

  // Smart Focus: is this employee the current on-duty person?
  const isCurrentDuty = (empId, day, direction) => {
    const opDay = getOperationalDay(direction);
    if (opDay < 1) return false;
    if (day !== opDay) return false;
    const s = getShift(empId, day).shift;
    if (!s) return false;
    const now = new Date();
    const parts = direction.shiftChangeTime.split(':');
    const hh = parseInt(parts[0]);
    const mm = parseInt(parts[1]);
    const shiftStart = new Date(now.getFullYear(), now.getMonth(), now.getDate(), hh, mm);
    // For Д/Н (24h): always on duty during operational day
    if (s === 'Д/Н') return true;
    // For Д (day): on duty from shift start until evening
    if (s === 'Д') {
      return now >= shiftStart;
    }
    // For Н (night): on duty from evening until next shift start
    if (s === 'Н') {
      return now < shiftStart;
    }
    return false;
  };

  const showToast = (msg, type) => {
    const container = $el('.ds-toast-container');
    const toast = document.createElement('div');
    toast.className = 'ds-toast ' + type;
    toast.textContent = msg;
    container.appendChild(toast);
    setTimeout(() => {
      toast.style.opacity = '0';
      toast.style.transition = 'opacity .3s';
      setTimeout(() => toast.remove(), 300);
    }, 3000);
  };

  const getExcelCol = (i) => {
    let c = '';
    let idx = i;
    while (idx >= 0) {
      c = String.fromCharCode(65 + (idx % 26)) + c;
      idx = Math.floor(idx / 26) - 1;
    }
    return c;
  };

  // --- Demo data ---
  const generateDemoData = () => {
    const y = state.currentMonth.getFullYear();
    const m = state.currentMonth.getMonth();
    const days = new Date(y, m + 1, 0).getDate();
    state.scheduleData = {};
    state.engagementData = {};
    EMPLOYEES.forEach((emp) => {
      const dir = DIRECTIONS.find((d) => d.id === emp.directionId);
      for (let d = 1; d <= days; d++) {
        const date = new Date(y, m, d);
        if (dir.weekdaysOnly && (date.getDay() === 0 || date.getDay() === 6)) continue;
        const r = Math.random();
        if (r < 0.10) state.scheduleData[emp.id + '_' + d] = { shift: 'Д/Н', draft: false };
        else if (r < 0.22) state.scheduleData[emp.id + '_' + d] = { shift: 'Д', draft: false };
        else if (r < 0.30) state.scheduleData[emp.id + '_' + d] = { shift: 'Н', draft: false };
      }
    });
  };

  // --- Render Grid ---
  const renderGrid = () => {
    const y = state.currentMonth.getFullYear();
    const m = state.currentMonth.getMonth();
    const days = getDaysInMonth(state.currentMonth);
    const now = new Date();
    const isCurMonth = (y === now.getFullYear() && m === now.getMonth());

    let visDirs = DIRECTIONS;
    if (state.currentRole === 'specialist' && state.specialistDirection) {
      visDirs = DIRECTIONS.filter((d) => d.id === state.specialistDirection);
    }

    let fHTML = '<table><thead><tr class="ds-header-row">';
    fHTML += '<th class="ds-col-dept">Подразделение</th><th class="ds-col-dir">Направление</th><th class="ds-col-pos">Должность</th><th class="ds-col-name">ФИО</th><th class="ds-col-phone">Телефон</th><th class="ds-col-total">Итого</th>';
    fHTML += '</tr></thead><tbody>';

    let sHTML = '<table><thead><tr class="ds-header-row">';
    for (let d = 1; d <= days; d++) {
      const date = new Date(y, m, d);
      const dn = DAY_NAMES[date.getDay()];
      const isNW = isWeekend(y, m, d) || isHoliday(m, d);
      const isCH = isCustomHoliday(y, m, d);
      let cls = 'ds-day-cell';
      if (isNW || isCH) cls += ' ds-weekend';
      if (isCH && !isNW) cls += ' ds-holiday-custom';
      if (isCurMonth && d === now.getDate()) cls += ' ds-today-col';
      let hasHole = false;
      visDirs.forEach((dir) => { if (checkHole(dir.id, d)) hasHole = true; });
      if (hasHole) cls += ' ds-hole';
      if (state.currentRole === 'manager') cls += ' ds-clickable-header';
      sHTML += '<th class="' + cls + '" data-day="' + d + '"><span class="ds-day-num">' + d + '</span><span class="ds-day-name">' + dn + '</span></th>';
    }
    sHTML += '</tr></thead><tbody>';

    visDirs.forEach((dir) => {
      const dirEmps = EMPLOYEES.filter((e) => e.directionId === dir.id);
      const opDay = isCurMonth ? getOperationalDay(dir) : -1;

      fHTML += '<tr class="ds-section-row"><td colspan="6"><div class="ds-section-title"><span>' + dir.name + '</span><span class="ds-section-mode">' + dir.mode + '</span>';
      if (state.currentRole === 'manager' && state.globalApproved) {
        fHTML += '<button class="ds-unlock-btn" data-dir="' + dir.id + '">' + (dir.unlocked ? '🔓 Заблокировать' : '🔒 Разблокировать') + '</button>';
      }
      fHTML += '</div></td></tr>';
      sHTML += '<tr class="ds-section-row"><td colspan="' + days + '" style="background:var(--ds-section-bg);border-bottom:2px solid #c5cae9"></td></tr>';

      dirEmps.forEach((emp) => {
        const total = calculateTotal(emp.id, dir);
        fHTML += '<tr class="ds-data-row" data-emp="' + emp.id + '"><td class="ds-col-dept" title="' + dir.department + '">' + dir.department + '</td><td class="ds-col-dir" title="' + dir.name + '">' + dir.name + '</td><td class="ds-col-pos" title="' + emp.position + '">' + emp.position + '</td><td class="ds-col-name" title="' + emp.name + '">' + emp.name + '</td><td class="ds-col-phone">' + emp.phone + '</td><td class="ds-col-total">' + total + '</td></tr>';

        sHTML += '<tr class="ds-data-row" data-emp="' + emp.id + '">';
        for (let d = 1; d <= days; d++) {
          const data = getShift(emp.id, d);
          const isNW2 = isNonWorkingDay(y, m, d);
          const ed = canEdit(emp.id, d);
          const past = isPastDate(d, dir);
          const isFocus = isCurMonth && isCurrentDuty(emp.id, d, dir);
          const engKey = emp.id + '_' + d;
          const hasEng = !!state.engagementData[engKey];

          let cls2 = 'ds-day-cell';
          if (data.shift === 'Д') cls2 += ' ds-shift-d';
          else if (data.shift === 'Н') cls2 += ' ds-shift-n';
          else if (data.shift === 'Д/Н') cls2 += ' ds-shift-dn';
          if (isCurMonth && d === opDay) cls2 += ' ds-today-col';
          if (past && state.currentRole !== 'manager') cls2 += ' ds-past';
          if (ed) cls2 += ' ds-editable'; else cls2 += ' ds-locked';
          if (data.draft) cls2 += ' ds-draft-cell';
          if (isNW2 && !data.shift) cls2 += ' ds-weekend-cell';
          if (isFocus) cls2 += ' ds-focus-cell';

          let inner = data.shift || '';
          if (hasEng) inner += '<span class="ds-alert-badge" data-eng-key="' + engKey + '">!</span>';

          sHTML += '<td class="' + cls2 + '" data-emp="' + emp.id + '" data-day="' + d + '" data-dir="' + dir.id + '">' + inner + '</td>';
        }
        sHTML += '</tr>';
      });
    });

    fHTML += '</tbody></table>';
    sHTML += '</tbody></table>';
    $el('.ds-frozen-left').innerHTML = fHTML;
    $el('.ds-scroll-right').innerHTML = sHTML;

    // Attach cell handlers
    $all('.ds-scroll-right td.ds-editable').forEach((td) => {
      td.addEventListener('click', (e) => {
        onCellClick(e, td.getAttribute('data-emp'), parseInt(td.getAttribute('data-day')), td.getAttribute('data-dir'));
      });
      td.addEventListener('contextmenu', (e) => {
        onCellContext(e, td.getAttribute('data-emp'), parseInt(td.getAttribute('data-day')), td.getAttribute('data-dir'));
      });
    });

    // Attach unlock buttons
    $all('.ds-unlock-btn').forEach((btn) => {
      btn.addEventListener('click', () => { toggleDirectionLock(btn.getAttribute('data-dir')); });
    });

    // Attach header click for custom holidays (manager only)
    if (state.currentRole === 'manager') {
      $all('.ds-scroll-right .ds-header-row th.ds-clickable-header').forEach((th) => {
        th.addEventListener('click', () => {
          const d = parseInt(th.getAttribute('data-day'));
          toggleCustomHoliday(d);
        });
      });
    }

    // Attach tooltip for engagement badges
    $all('.ds-alert-badge').forEach((badge) => {
      badge.addEventListener('mouseenter', (e) => {
        const key = badge.getAttribute('data-eng-key');
        const eng = state.engagementData[key];
        if (!eng) return;
        const tip = $el('.ds-tooltip');
        tip.innerHTML = '<b>Привлечение</b><br>Время: ' + eng.timestamp + '<br>Основание: ' + eng.reason + '<br>Эскалация: ' + (eng.escalation || '—') + '<br>Автор: ' + eng.author;
        tip.style.display = 'block';
        tip.style.left = (e.clientX + 12) + 'px';
        tip.style.top = (e.clientY + 12) + 'px';
      });
      badge.addEventListener('mouseleave', () => {
        $el('.ds-tooltip').style.display = 'none';
      });
    });
  };

  const toggleCustomHoliday = (day) => {
    const y = state.currentMonth.getFullYear();
    const m = state.currentMonth.getMonth();
    const key = y + '-' + String(m + 1).padStart(2, '0') + '-' + String(day).padStart(2, '0');
    if (state.customHolidays[key]) {
      delete state.customHolidays[key];
      showToast('День ' + fmtDate(day) + ' снят как праздничный', 'info');
    } else {
      state.customHolidays[key] = true;
      showToast('День ' + fmtDate(day) + ' отмечен как праздничный', 'success');
    }
    renderGrid();
  };

  const updateToolbar = () => {
    const rb = $el('.ds-role-badge-el');
    const df = $el('.ds-direction-filter');
    const ba = $el('.ds-btn-approve');
    const bp = $el('.ds-btn-publish');
    const bc = $el('.ds-btn-copy-month');
    const sb = $el('.ds-status-badge-el');

    if (state.currentRole === 'manager') {
      rb.textContent = 'Начальник смены';
      rb.className = 'ds-role-badge manager ds-role-badge-el';
      df.style.display = 'none';
      ba.style.display = '';
      bp.style.display = 'none';
      bc.style.display = 'none';
    } else {
      rb.textContent = 'Специалист';
      rb.className = 'ds-role-badge specialist ds-role-badge-el';
      df.style.display = '';
      ba.style.display = 'none';
      bp.style.display = '';
      bc.style.display = '';
    }
    if (state.globalApproved) {
      sb.textContent = 'Утвержден';
      sb.className = 'ds-status-indicator approved ds-status-badge-el';
      ba.textContent = '🔓 Снять утверждение';
    } else {
      sb.textContent = 'Открыт';
      sb.className = 'ds-status-indicator open ds-status-badge-el';
      ba.textContent = '✅ Утвердить график';
    }
  };

  // --- Event handlers ---
  const onCellClick = (e, empId, day, dirId) => {
    e.stopPropagation();
    const emp = EMPLOYEES.find((x) => x.id === empId);
    if (!emp) return;
    state.editingCell = { employeeId: empId, day: day, directionId: dirId };
    $el('.ds-modal-employee').value = emp.name;
    $el('.ds-modal-date').value = fmtDate(day);
    $el('.ds-modal-shift').value = getShift(empId, day).shift || '';
    $el('.ds-cell-modal').classList.add('ds-active');
  };

  const onCellContext = (e, empId, day, dirId) => {
    e.preventDefault();
    e.stopPropagation();
    state.editingCell = { employeeId: empId, day: day, directionId: dirId };
    const menu = $el('.ds-context-menu');
    menu.style.left = e.clientX + 'px';
    menu.style.top = e.clientY + 'px';

    // Show/hide engage/remove-engage based on current state
    const engKey = empId + '_' + day;
    const hasEng = !!state.engagementData[engKey];
    const engItem = menu.querySelector('[data-action="engage"]');
    const remItem = menu.querySelector('[data-action="remove-engage"]');
    engItem.style.display = hasEng ? 'none' : '';
    remItem.style.display = hasEng ? '' : 'none';

    menu.classList.add('ds-active');
  };

  const closeModal = () => {
    $el('.ds-cell-modal').classList.remove('ds-active');
    state.editingCell = null;
  };

  const closeEngModal = () => {
    $el('.ds-engagement-modal').classList.remove('ds-active');
  };

  const saveShift = () => {
    if (!state.editingCell) return;
    const { employeeId, day, directionId } = state.editingCell;
    const sv = $el('.ds-modal-shift').value;
    const err = validateSlot(directionId, day, employeeId, sv);
    if (err) { showToast(err, 'error'); return; }
    setShift(employeeId, day, sv);
    closeModal();
    renderGrid();
    showToast('Смена сохранена', 'success');
  };

  const toggleApprove = () => {
    state.globalApproved = !state.globalApproved;
    if (state.globalApproved) {
      DIRECTIONS.forEach((d) => { d.unlocked = false; });
      showToast('График утвержден. Редактирование заблокировано.', 'info');
    } else {
      DIRECTIONS.forEach((d) => { d.unlocked = true; });
      showToast('Утверждение снято. Редактирование разрешено.', 'info');
    }
    updateToolbar();
    renderGrid();
  };

  const toggleDirectionLock = (dirId) => {
    const dir = DIRECTIONS.find((d) => d.id === dirId);
    if (!dir) return;
    dir.unlocked = !dir.unlocked;
    showToast('Направление "' + dir.name + '" ' + (dir.unlocked ? 'разблокировано' : 'заблокировано'), 'info');
    renderGrid();
  };

  const publishDraft = () => {
    let c = 0;
    Object.keys(state.draftData).forEach((k) => {
      state.scheduleData[k] = { shift: state.draftData[k].shift, draft: false };
      c++;
    });
    state.draftData = {};
    renderGrid();
    showToast('Опубликовано ' + c + ' изменений', 'success');
  };

  const copyPreviousMonth = () => {
    const dp = getDaysInMonth(new Date(state.currentMonth.getFullYear(), state.currentMonth.getMonth() - 1, 1));
    const dc = getDaysInMonth(state.currentMonth);
    let c = 0;
    EMPLOYEES.forEach((emp) => {
      if (state.currentRole === 'specialist' && state.specialistDirection && state.specialistDirection !== emp.directionId) return;
      for (let d = 1; d <= Math.min(dp, dc); d++) {
        const pd = state.scheduleData[emp.id + '_' + d];
        if (pd && pd.shift) {
          if (state.currentRole === 'specialist') {
            state.draftData[emp.id + '_' + d] = { shift: pd.shift, draft: true };
          } else {
            state.scheduleData[emp.id + '_' + d] = { shift: pd.shift, draft: false };
          }
          c++;
        }
      }
    });
    renderGrid();
    showToast('Скопировано ' + c + ' смен из предыдущего месяца', 'success');
  };

  // --- Engagement ---
  const openEngagementModal = () => {
    if (!state.editingCell) return;
    const emp = EMPLOYEES.find((e) => e.id === state.editingCell.employeeId);
    if (!emp) return;
    $el('.ds-eng-employee').value = emp.name;
    $el('.ds-eng-date').value = fmtDate(state.editingCell.day);
    $el('.ds-eng-reason').value = '';
    $el('.ds-eng-escalation').value = '';
    $el('.ds-context-menu').classList.remove('ds-active');
    $el('.ds-engagement-modal').classList.add('ds-active');
  };

  const saveEngagement = () => {
    if (!state.editingCell) return;
    const { employeeId, day, directionId } = state.editingCell;
    const reason = $el('.ds-eng-reason').value.trim();
    const escalation = $el('.ds-eng-escalation').value.trim();
    if (!reason) { showToast('Укажите основание привлечения', 'error'); return; }
    const emp = EMPLOYEES.find((e) => e.id === employeeId);
    const dir = DIRECTIONS.find((d) => d.id === directionId);
    const ts = fmtDateTime();
    const author = state.currentRole === 'manager' ? 'Начальник смены' : 'Специалист';
    state.engagementData[employeeId + '_' + day] = { reason, escalation, author, timestamp: ts };
    state.engagementLog.unshift({ timestamp: ts, employee: emp ? emp.name : employeeId, direction: dir ? dir.name : '', reason, escalation, author });
    closeEngModal();
    renderGrid();
    showToast('Привлечение отмечено', 'success');
  };

  const removeEngagement = () => {
    if (!state.editingCell) return;
    const key = state.editingCell.employeeId + '_' + state.editingCell.day;
    delete state.engagementData[key];
    $el('.ds-context-menu').classList.remove('ds-active');
    renderGrid();
    showToast('Привлечение снято', 'info');
  };

  // --- Settings ---
  const toggleSettings = () => {
    const p = $el('.ds-settings-panel');
    p.classList.toggle('ds-active');
    $el('.ds-journal-panel').classList.remove('ds-active');
    if (p.classList.contains('ds-active')) renderSettings();
  };

  const renderSettings = () => {
    let h = '';
    DIRECTIONS.forEach((dir) => {
      h += '<div class="ds-setting-card"><h4>' + dir.name + '</h4>'
        + '<div class="ds-setting-row"><label>Время пересменки</label><input type="time" value="' + dir.shiftChangeTime + '" style="width:100px;padding:4px 8px;border:1px solid var(--ds-border);border-radius:4px" data-dir="' + dir.id + '" data-key="shiftChangeTime" class="ds-si" /></div>'
        + '<div class="ds-setting-row"><label>Учитывать «Д» в Итого</label><label class="ds-toggle-switch"><input type="checkbox" ' + (dir.countDayShift ? 'checked' : '') + ' data-dir="' + dir.id + '" data-key="countDayShift" class="ds-st" /><span class="ds-toggle-slider"></span></label></div>'
        + '<div class="ds-setting-row"><label>Только будние дни</label><label class="ds-toggle-switch"><input type="checkbox" ' + (dir.weekdaysOnly ? 'checked' : '') + ' data-dir="' + dir.id + '" data-key="weekdaysOnly" class="ds-st" /><span class="ds-toggle-slider"></span></label></div>'
        + '<div class="ds-setting-row"><label>Контроль укомплектованности</label><label class="ds-toggle-switch"><input type="checkbox" ' + (dir.checkStaffing ? 'checked' : '') + ' data-dir="' + dir.id + '" data-key="checkStaffing" class="ds-st" /><span class="ds-toggle-slider"></span></label></div>'
        + '</div>';
    });
    $el('.ds-settings-content').innerHTML = h;
    $all('.ds-si').forEach((el) => {
      el.addEventListener('change', (e) => {
        const dir = DIRECTIONS.find((d) => d.id === e.target.dataset.dir);
        if (dir) { dir[e.target.dataset.key] = e.target.value; renderGrid(); showToast('Настройка обновлена', 'success'); }
      });
    });
    $all('.ds-st').forEach((el) => {
      el.addEventListener('change', (e) => {
        const dir = DIRECTIONS.find((d) => d.id === e.target.dataset.dir);
        if (dir) { dir[e.target.dataset.key] = e.target.checked; renderGrid(); showToast('Настройка обновлена', 'success'); }
      });
    });
  };

  // --- Journal (Audit + Engagement tabs) ---
  const toggleJournal = () => {
    const p = $el('.ds-journal-panel');
    p.classList.toggle('ds-active');
    $el('.ds-settings-panel').classList.remove('ds-active');
    if (p.classList.contains('ds-active')) renderJournal();
  };

  const renderJournal = () => {
    if (state.activeJournalTab === 'audit') renderAudit();
    else renderEngagementLog();
  };

  const renderAudit = () => {
    const body = $el('.ds-audit-body');
    if (!state.auditLog.length) {
      body.innerHTML = '<tr><td colspan="6" style="text-align:center;padding:20px;color:var(--ds-text-light)">Нет записей</td></tr>';
      return;
    }
    body.innerHTML = state.auditLog.slice(0, 100).map((l) =>
      '<tr><td>' + l.timestamp + '</td><td>' + l.user + '</td><td>' + l.employee + '</td><td>' + l.editDate + '</td><td>' + l.oldValue + '</td><td>' + l.newValue + '</td></tr>'
    ).join('');
  };

  const renderEngagementLog = () => {
    const body = $el('.ds-engagement-body');
    if (!state.engagementLog.length) {
      body.innerHTML = '<tr><td colspan="6" style="text-align:center;padding:20px;color:var(--ds-text-light)">Нет записей</td></tr>';
      return;
    }
    body.innerHTML = state.engagementLog.slice(0, 100).map((l) =>
      '<tr><td>' + l.timestamp + '</td><td>' + l.employee + '</td><td>' + l.direction + '</td><td>' + l.reason + '</td><td>' + (l.escalation || '—') + '</td><td>' + l.author + '</td></tr>'
    ).join('');
  };

  // --- Export XLSX ---
  const exportXLSX = () => {
    const X = window.XLSX;
    if (!X) { showToast('XLSX не загружен', 'error'); return; }
    const y = state.currentMonth.getFullYear();
    const m = state.currentMonth.getMonth();
    const days = getDaysInMonth(state.currentMonth);
    const wb = X.utils.book_new();
    const ws = [];
    const merges = [];
    const cw = [{ wch: 18 }, { wch: 22 }, { wch: 16 }, { wch: 22 }, { wch: 16 }, { wch: 8 }];
    for (let d = 1; d <= days; d++) cw.push({ wch: 5 });
    const hr = ['Подразделение', 'Направление', 'Должность', 'ФИО', 'Телефон', 'Итого'];
    for (let d = 1; d <= days; d++) {
      const dt = new Date(y, m, d);
      hr.push(d + ' ' + DAY_NAMES[dt.getDay()]);
    }
    ws.push(hr);
    let ri = 1;
    DIRECTIONS.forEach((dir) => {
      const de = EMPLOYEES.filter((e) => e.directionId === dir.id);
      const sr = [dir.name + ' (' + dir.mode + ')'];
      for (let i = 1; i < 6 + days; i++) sr.push('');
      ws.push(sr);
      merges.push({ s: { r: ri, c: 0 }, e: { r: ri, c: 5 + days } });
      ri++;
      de.forEach((emp) => {
        const row = [dir.department, dir.name, emp.position, emp.name, emp.phone];
        const fp = [];
        for (let d = 1; d <= days; d++) {
          const s = getShift(emp.id, d);
          row.push(s.shift || '');
          const cl = getExcelCol(6 + d - 1);
          const cr = cl + (ri + 1);
          if (dir.countDayShift) fp.push('IF(OR(' + cr + '="Д",' + cr + '="Н",' + cr + '="Д/Н"),1,0)');
          else fp.push('IF(OR(' + cr + '="Н",' + cr + '="Д/Н"),1,0)');
        }
        row.splice(5, 0, { f: fp.join('+') });
        ws.push(row);
        ri++;
      });
    });
    const sheet = X.utils.aoa_to_sheet(ws);
    sheet['!cols'] = cw;
    sheet['!merges'] = merges;
    if (!sheet['!views']) sheet['!views'] = [{}];
    sheet['!views'][0] = { state: 'frozen', xSplit: 6, ySplit: 1 };
    X.utils.book_append_sheet(wb, sheet, MONTH_NAMES[m] + ' ' + y);
    X.writeFile(wb, 'График_дежурств_' + MONTH_NAMES[m] + '_' + y + '.xlsx');
    showToast('Файл XLSX экспортирован', 'success');
  };

  // --- Init ---
  const now = new Date();
  const mp = $el('.ds-month-picker');
  mp.value = now.getFullYear() + '-' + String(now.getMonth() + 1).padStart(2, '0');
  state.currentMonth = new Date(now.getFullYear(), now.getMonth(), 1);

  const df = $el('.ds-direction-filter');
  DIRECTIONS.forEach((d) => {
    const o = document.createElement('option');
    o.value = d.id;
    o.textContent = d.name;
    df.appendChild(o);
  });

  generateDemoData();

  // Bind events
  mp.addEventListener('change', (e) => {
    const parts = e.target.value.split('-');
    state.currentMonth = new Date(parseInt(parts[0]), parseInt(parts[1]) - 1, 1);
    generateDemoData();
    renderGrid();
  });

  $el('.ds-role-select').addEventListener('change', (e) => {
    state.currentRole = e.target.value;
    updateToolbar();
    renderGrid();
  });

  df.addEventListener('change', (e) => {
    state.specialistDirection = e.target.value;
    renderGrid();
  });

  $el('.ds-btn-settings').addEventListener('click', toggleSettings);
  $el('.ds-btn-close-settings').addEventListener('click', toggleSettings);
  $el('.ds-btn-journal').addEventListener('click', toggleJournal);
  $el('.ds-btn-close-journal').addEventListener('click', toggleJournal);
  $el('.ds-btn-export').addEventListener('click', exportXLSX);
  $el('.ds-btn-approve').addEventListener('click', toggleApprove);
  $el('.ds-btn-publish').addEventListener('click', publishDraft);
  $el('.ds-btn-copy-month').addEventListener('click', copyPreviousMonth);
  $el('.ds-btn-cancel-modal').addEventListener('click', closeModal);
  $el('.ds-btn-save-shift').addEventListener('click', saveShift);
  $el('.ds-btn-cancel-eng').addEventListener('click', closeEngModal);
  $el('.ds-btn-save-eng').addEventListener('click', saveEngagement);

  // Journal tabs
  $all('.ds-journal-tabs .ds-tab-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      $all('.ds-journal-tabs .ds-tab-btn').forEach((b) => b.classList.remove('ds-tab-active'));
      btn.classList.add('ds-tab-active');
      const tab = btn.getAttribute('data-tab');
      state.activeJournalTab = tab;
      $el('.ds-journal-audit-content').style.display = tab === 'audit' ? '' : 'none';
      $el('.ds-journal-engagement-content').style.display = tab === 'engagement' ? '' : 'none';
      renderJournal();
    });
  });

  // Context menu
  $el('.ds-context-menu').addEventListener('click', (e) => {
    const action = e.target.dataset ? e.target.dataset.action : null;
    if (!action || !state.editingCell) return;
    const { employeeId, day, directionId } = state.editingCell;
    if (action === 'engage') { openEngagementModal(); return; }
    if (action === 'remove-engage') { removeEngagement(); return; }
    let sv = '';
    if (action === 'set-d') sv = 'Д';
    else if (action === 'set-n') sv = 'Н';
    else if (action === 'set-dn') sv = 'Д/Н';
    const err = validateSlot(directionId, day, employeeId, sv);
    if (err) { showToast(err, 'error'); return; }
    setShift(employeeId, day, sv);
    renderGrid();
    showToast('Смена обновлена', 'success');
    $el('.ds-context-menu').classList.remove('ds-active');
  });

  document.addEventListener('click', () => {
    $el('.ds-context-menu').classList.remove('ds-active');
  });

  const frozenLeft = $el('.ds-frozen-left');
  const scrollRight = $el('.ds-scroll-right');
  scrollRight.addEventListener('scroll', () => {
    frozenLeft.scrollTop = scrollRight.scrollTop;
  });

  renderGrid();
  updateToolbar();
})();
</script>
</body>
</html>
