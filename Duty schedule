        var state = {
          currentMonth: null,
          currentRole: 'manager',
          specialistDirection: '',
          scheduleData: {},
          draftData: {},
          engagementData: {},
          engagementLog: [],
          customHolidays: {},
          globalApproved: false,
          auditLog: [],
          editingCell: null,
          activeJournalTab: 'audit',
        };

        // --- Helpers ---
        function fmtDate(day) {
          var y = state.currentMonth.getFullYear(),
            m = state.currentMonth.getMonth();
          return (
            String(day).padStart(2, '0') +
            '.' +
            String(m + 1).padStart(2, '0') +
            '.' +
            y
          );
        }
        function fmtDateTime() {
          return new Date().toLocaleString('ru-RU', {
            day: '2-digit',
            month: '2-digit',
            year: 'numeric',
            hour: '2-digit',
            minute: '2-digit',
            second: '2-digit',
          });
        }
        function getDaysInMonth(date) {
          return new Date(date.getFullYear(), date.getMonth() + 1, 0).getDate();
        }
        function isWeekend(year, month, day) {
          var d = new Date(year, month, day);
          return d.getDay() === 0 || d.getDay() === 6;
        }
        function isHoliday(month, day) {
          return HOLIDAYS_RU.includes(
            String(month + 1).padStart(2, '0') +
              '-' +
              String(day).padStart(2, '0'),
          );
        }
        function isCustomHoliday(year, month, day) {
          return !!state.customHolidays[
            year +
              '-' +
              String(month + 1).padStart(2, '0') +
              '-' +
              String(day).padStart(2, '0')
          ];
        }
        function isNonWorkingDay(year, month, day) {
          return (
            isWeekend(year, month, day) ||
            isHoliday(month, day) ||
            isCustomHoliday(year, month, day)
          );
        }

        // Smart Focus: determine the "operational day" for a direction based on shift change time
        function getOperationalDay(direction) {
          var now = new Date();
          var y = state.currentMonth.getFullYear(),
            m = state.currentMonth.getMonth();
          if (y !== now.getFullYear() || m !== now.getMonth()) return -1;
          var parts = direction.shiftChangeTime.split(':');
          var hh = parseInt(parts[0]),
            mm = parseInt(parts[1]);
          var shiftTime = new Date(
            now.getFullYear(),
            now.getMonth(),
            now.getDate(),
            hh,
            mm,
          );
          return now < shiftTime ? now.getDate() - 1 : now.getDate();
        }

        function isPastDate(day, direction) {
          var now = new Date();
          if (state.currentMonth.getFullYear() < now.getFullYear()) return true;
          if (
            state.currentMonth.getFullYear() === now.getFullYear() &&
            state.currentMonth.getMonth() < now.getMonth()
          )
            return true;
          if (
            state.currentMonth.getFullYear() === now.getFullYear() &&
            state.currentMonth.getMonth() === now.getMonth()
          ) {
            return day < getOperationalDay(direction);
          }
          return false;
        }

        function getShift(empId, day) {
          var key = empId + '_' + day;
          if (state.currentRole === 'specialist' && state.draftData[key])
            return state.draftData[key];
          return state.scheduleData[key] || { shift: '', draft: false };
        }

        function setShift(empId, day, shiftValue) {
          var key = empId + '_' + day;
          var old = state.scheduleData[key] || { shift: '', draft: false };
          if (state.currentRole === 'specialist') {
            state.draftData[key] = { shift: shiftValue, draft: true };
          } else {
            state.scheduleData[key] = { shift: shiftValue, draft: false };
          }
          state.auditLog.unshift({
            timestamp: fmtDateTime(),
            user:
              state.currentRole === 'manager'
                ? 'Начальник смены'
                : 'Специалист',
            employee:
              (
                EMPLOYEES.find(function (e) {
                  return e.id === empId;
                }) || {}
              ).name || empId,
            editDate: fmtDate(day),
            oldValue: old.shift || '—',
            newValue: shiftValue || '—',
          });
        }

        function calculateTotal(empId, direction) {
          var days = getDaysInMonth(state.currentMonth);
          var t = 0;
          for (var d = 1; d <= days; d++) {
            var s = getShift(empId, d).shift;
            if (s === 'Д/Н') t++;
            else if (s === 'Н') t++;
            else if (s === 'Д' && direction.countDayShift) t++;
          }
          return t;
        }

        function checkHole(dirId, day) {
          var dir = DIRECTIONS.find(function (d) {
            return d.id === dirId;
          });
          if (!dir || !dir.checkStaffing) return false;
          var y = state.currentMonth.getFullYear(),
            m = state.currentMonth.getMonth();
          if (dir.weekdaysOnly && isNonWorkingDay(y, m, day)) return false;
          var emps = EMPLOYEES.filter(function (e) {
            return e.directionId === dirId;
          });
          return !emps.some(function (emp) {
            var s = getShift(emp.id, day).shift;
            return s === 'Д' || s === 'Н' || s === 'Д/Н';
          });
        }

        // Enhanced slot validation: Day slot (Д or Д/Н) max 1, Night slot (Н or Д/Н) max 1
        function validateSlot(dirId, day, excludeEmpId, newShift) {
          if (!newShift) return null;
          var emps = EMPLOYEES.filter(function (e) {
            return e.directionId === dirId && e.id !== excludeEmpId;
          });
          var occupiesDay = newShift === 'Д' || newShift === 'Д/Н';
          var occupiesNight = newShift === 'Н' || newShift === 'Д/Н';
          for (var i = 0; i < emps.length; i++) {
            var emp = emps[i];
            var s = getShift(emp.id, day).shift;
            if (!s) continue;
            var hasDaySlot = s === 'Д' || s === 'Д/Н';
            var hasNightSlot = s === 'Н' || s === 'Д/Н';
            if (occupiesDay && hasDaySlot)
              return (
                'Дневной слот на ' +
                fmtDate(day) +
                ' уже занят (' +
                emp.name +
                ')'
              );
            if (occupiesNight && hasNightSlot)
              return (
                'Ночной слот на ' +
                fmtDate(day) +
                ' уже занят (' +
                emp.name +
                ')'
              );
          }
          return null;
        }

        function canEdit(empId, day) {
          var emp = EMPLOYEES.find(function (e) {
            return e.id === empId;
          });
          if (!emp) return false;
          var dir = DIRECTIONS.find(function (d) {
            return d.id === emp.directionId;
          });
          if (!dir) return false;
          if (
            state.currentRole === 'specialist' &&
            state.specialistDirection &&
            state.specialistDirection !== dir.id
          )
            return false;
          if (state.globalApproved && state.currentRole !== 'manager') {
            if (!dir.unlocked) return false;
          }
          if (isPastDate(day, dir) && state.currentRole !== 'manager')
            return false;
          var y = state.currentMonth.getFullYear(),
            m = state.currentMonth.getMonth();
          if (dir.weekdaysOnly && isNonWorkingDay(y, m, day)) return false;
          return true;
        }

        // Smart Focus: is this employee the current on-duty person?
        function isCurrentDuty(empId, day, direction) {
          var opDay = getOperationalDay(direction);
          if (opDay < 1) return false;
          if (day !== opDay) return false;
          var s = getShift(empId, day).shift;
          if (!s) return false;
          var now = new Date();
          var parts = direction.shiftChangeTime.split(':');
          var hh = parseInt(parts[0]),
            mm = parseInt(parts[1]);
          var shiftStart = new Date(
            now.getFullYear(),
            now.getMonth(),
            now.getDate(),
            hh,
            mm,
          );
          // For Д/Н (24h): always on duty during operational day
          if (s === 'Д/Н') return true;
          // For Д (day): on duty from shift start until evening
          if (s === 'Д') {
            if (now >= shiftStart) return true;
            return false;
          }
          // For Н (night): on duty from evening until next shift start
          if (s === 'Н') {
            if (now < shiftStart) return true;
            return false;
          }
          return false;
        }

        function showToast(msg, type) {
          var c = document.getElementById('dsToastContainer');
          var t = document.createElement('div');
          t.className = 'ds-toast ' + type;
          t.textContent = msg;
          c.appendChild(t);
          setTimeout(function () {
            t.style.opacity = '0';
            t.style.transition = 'opacity .3s';
            setTimeout(function () {
              t.remove();
            }, 300);
          }, 3000);
        }

        function getExcelCol(i) {
          var c = '';
          while (i >= 0) {
            c = String.fromCharCode(65 + (i % 26)) + c;
            i = Math.floor(i / 26) - 1;
          }
          return c;
        }

        // --- Demo data ---
        function generateDemoData() {
          var y = state.currentMonth.getFullYear(),
            m = state.currentMonth.getMonth();
          var days = new Date(y, m + 1, 0).getDate();
          state.scheduleData = {};
          state.engagementData = {};
          EMPLOYEES.forEach(function (emp) {
            var dir = DIRECTIONS.find(function (d) {
              return d.id === emp.directionId;
            });
            for (var d = 1; d <= days; d++) {
              var date = new Date(y, m, d);
              if (
                dir.weekdaysOnly &&
                (date.getDay() === 0 || date.getDay() === 6)
              )
                continue;
              var r = Math.random();
              if (r < 0.1)
                state.scheduleData[emp.id + '_' + d] = {
                  shift: 'Д/Н',
                  draft: false,
                };
              else if (r < 0.22)
                state.scheduleData[emp.id + '_' + d] = {
                  shift: 'Д',
                  draft: false,
                };
              else if (r < 0.3)
                state.scheduleData[emp.id + '_' + d] = {
                  shift: 'Н',
                  draft: false,
                };
            }
          });
        }

        // --- Render Grid ---
        function renderGrid() {
          var y = state.currentMonth.getFullYear(),
            m = state.currentMonth.getMonth();
          var days = getDaysInMonth(state.currentMonth);
          var now = new Date();
          var isCurMonth = y === now.getFullYear() && m === now.getMonth();

          var visDirs = DIRECTIONS;
          if (state.currentRole === 'specialist' && state.specialistDirection)
            visDirs = DIRECTIONS.filter(function (d) {
              return d.id === state.specialistDirection;
            });

          var fHTML = '<table><thead><tr class="ds-header-row">';
          fHTML +=
            '<th class="ds-col-dept">Подразделение</th><th class="ds-col-dir">Направление</th><th class="ds-col-pos">Должность</th><th class="ds-col-name">ФИО</th><th class="ds-col-phone">Телефон</th><th class="ds-col-total">Итого</th>';
          fHTML += '</tr></thead><tbody>';

          var sHTML = '<table><thead><tr class="ds-header-row">';
          for (var d = 1; d <= days; d++) {
            var date = new Date(y, m, d);
            var dn = DAY_NAMES[date.getDay()];
            var isNW = isWeekend(y, m, d) || isHoliday(m, d);
            var isCH = isCustomHoliday(y, m, d);
            var cls = 'ds-day-cell';
            if (isNW || isCH) cls += ' ds-weekend';
            if (isCH && !isNW) cls += ' ds-holiday-custom';
            if (isCurMonth && d === now.getDate()) cls += ' ds-today-col';
            var hasHole = false;
            visDirs.forEach(function (dir) {
              if (checkHole(dir.id, d)) hasHole = true;
            });
            if (hasHole) cls += ' ds-hole';
            if (state.currentRole === 'manager') cls += ' ds-clickable-header';
            sHTML +=
              '<th class="' +
              cls +
              '" data-day="' +
              d +
              '"><span class="ds-day-num">' +
              d +
              '</span><span class="ds-day-name">' +
              dn +
              '</span></th>';
          }
          sHTML += '</tr></thead><tbody>';

          visDirs.forEach(function (dir) {
            var dirEmps = EMPLOYEES.filter(function (e) {
              return e.directionId === dir.id;
            });
            var opDay = isCurMonth ? getOperationalDay(dir) : -1;

            fHTML +=
              '<tr class="ds-section-row"><td colspan="6"><div class="ds-section-title"><span>' +
              dir.name +
              '</span><span class="ds-section-mode">' +
              dir.mode +
              '</span>';
            if (state.currentRole === 'manager' && state.globalApproved) {
              fHTML +=
                '<button class="ds-unlock-btn" data-dir="' +
                dir.id +
                '">' +
                (dir.unlocked ? '🔓 Заблокировать' : '🔒 Разблокировать') +
                '</button>';
            }
            fHTML += '</div></td></tr>';
            sHTML +=
              '<tr class="ds-section-row"><td colspan="' +
              days +
              '" style="background:var(--ds-section-bg);border-bottom:2px solid #c5cae9"></td></tr>';

            dirEmps.forEach(function (emp) {
              var total = calculateTotal(emp.id, dir);
              fHTML +=
                '<tr class="ds-data-row" data-emp="' +
                emp.id +
                '"><td class="ds-col-dept" title="' +
                dir.department +
                '">' +
                dir.department +
                '</td><td class="ds-col-dir" title="' +
                dir.name +
                '">' +
                dir.name +
                '</td><td class="ds-col-pos" title="' +
                emp.position +
                '">' +
                emp.position +
                '</td><td class="ds-col-name" title="' +
                emp.name +
                '">' +
                emp.name +
                '</td><td class="ds-col-phone">' +
                emp.phone +
                '</td><td class="ds-col-total">' +
                total +
                '</td></tr>';

              sHTML += '<tr class="ds-data-row" data-emp="' + emp.id + '">';
              for (var d = 1; d <= days; d++) {
                var data = getShift(emp.id, d);
                var isNW2 = isNonWorkingDay(y, m, d);
                var ed = canEdit(emp.id, d);
                var past = isPastDate(d, dir);
                var isFocus = isCurMonth && isCurrentDuty(emp.id, d, dir);
                var engKey = emp.id + '_' + d;
                var hasEng = !!state.engagementData[engKey];

                var cls2 = 'ds-day-cell';
                if (data.shift === 'Д') cls2 += ' ds-shift-d';
                else if (data.shift === 'Н') cls2 += ' ds-shift-n';
                else if (data.shift === 'Д/Н') cls2 += ' ds-shift-dn';
                if (isCurMonth && d === opDay) cls2 += ' ds-today-col';
                if (past && state.currentRole !== 'manager') cls2 += ' ds-past';
                if (ed) cls2 += ' ds-editable';
                else cls2 += ' ds-locked';
                if (data.draft) cls2 += ' ds-draft-cell';
                if (isNW2 && !data.shift) cls2 += ' ds-weekend-cell';
                if (isFocus) cls2 += ' ds-focus-cell';

                var inner = data.shift || '';
                if (hasEng)
                  inner +=
                    '<span class="ds-alert-badge" data-eng-key="' +
                    engKey +
                    '">!</span>';

                sHTML +=
                  '<td class="' +
                  cls2 +
                  '" data-emp="' +
                  emp.id +
                  '" data-day="' +
                  d +
                  '" data-dir="' +
                  dir.id +
                  '">' +
                  inner +
                  '</td>';
              }
              sHTML += '</tr>';
            });
          });

          fHTML += '</tbody></table>';
          sHTML += '</tbody></table>';
          document.getElementById('dsFrozenLeft').innerHTML = fHTML;
          document.getElementById('dsScrollRight').innerHTML = sHTML;

          // Attach cell handlers
          document
            .querySelectorAll('#dsScrollRight td.ds-editable')
            .forEach(function (td) {
              td.addEventListener('click', function (e) {
                onCellClick(
                  e,
                  td.getAttribute('data-emp'),
                  parseInt(td.getAttribute('data-day')),
                  td.getAttribute('data-dir'),
                );
              });
              td.addEventListener('contextmenu', function (e) {
                onCellContext(
                  e,
                  td.getAttribute('data-emp'),
                  parseInt(td.getAttribute('data-day')),
                  td.getAttribute('data-dir'),
                );
              });
            });

          // Attach unlock buttons
          document.querySelectorAll('.ds-unlock-btn').forEach(function (btn) {
            btn.addEventListener('click', function () {
              toggleDirectionLock(btn.getAttribute('data-dir'));
            });
          });

          // Attach header click for custom holidays (manager only)
          if (state.currentRole === 'manager') {
            document
              .querySelectorAll(
                '#dsScrollRight .ds-header-row th.ds-clickable-header',
              )
              .forEach(function (th) {
                th.addEventListener('click', function () {
                  var d = parseInt(th.getAttribute('data-day'));
                  toggleCustomHoliday(d);
                });
              });
          }

          // Attach tooltip for engagement badges
          document
            .querySelectorAll('.ds-alert-badge')
            .forEach(function (badge) {
              badge.addEventListener('mouseenter', function (e) {
                var key = badge.getAttribute('data-eng-key');
                var eng = state.engagementData[key];
                if (!eng) return;
                var tip = document.getElementById('dsTooltip');
                tip.innerHTML =
                  '<b>Привлечение</b><br>Время: ' +
                  eng.timestamp +
                  '<br>Основание: ' +
                  eng.reason +
                  '<br>Эскалация: ' +
                  (eng.escalation || '—') +
                  '<br>Автор: ' +
                  eng.author;
                tip.style.display = 'block';
                tip.style.left = e.clientX + 12 + 'px';
                tip.style.top = e.clientY + 12 + 'px';
              });
              badge.addEventListener('mouseleave', function () {
                document.getElementById('dsTooltip').style.display = 'none';
              });
            });
        }

        function toggleCustomHoliday(day) {
          var y = state.currentMonth.getFullYear(),
            m = state.currentMonth.getMonth();
          var key =
            y +
            '-' +
            String(m + 1).padStart(2, '0') +
            '-' +
            String(day).padStart(2, '0');
          if (state.customHolidays[key]) {
            delete state.customHolidays[key];
            showToast('День ' + fmtDate(day) + ' снят как праздничный', 'info');
          } else {
            state.customHolidays[key] = true;
            showToast(
              'День ' + fmtDate(day) + ' отмечен как праздничный',
              'success',
            );
          }
          renderGrid();
        }

        function updateToolbar() {
          var rb = document.getElementById('dsRoleBadge');
          var df = document.getElementById('dsDirectionFilter');
          var ba = document.getElementById('dsBtnApprove');
          var bp = document.getElementById('dsBtnPublish');
          var bc = document.getElementById('dsBtnCopyMonth');
          var sb = document.getElementById('dsStatusBadge');

          if (state.currentRole === 'manager') {
            rb.textContent = 'Начальник смены';
            rb.className = 'ds-role-badge manager';
            df.style.display = 'none';
            ba.style.display = '';
            bp.style.display = 'none';
            bc.style.display = 'none';
          } else {
            rb.textContent = 'Специалист';
            rb.className = 'ds-role-badge specialist';
            df.style.display = '';
            ba.style.display = 'none';
            bp.style.display = '';
            bc.style.display = '';
          }
          if (state.globalApproved) {
            sb.textContent = 'Утвержден';
            sb.className = 'ds-status-indicator approved';
            ba.textContent = '🔓 Снять утверждение';
          } else {
            sb.textContent = 'Открыт';
            sb.className = 'ds-status-indicator open';
            ba.textContent = '✅ Утвердить график';
          }
        }

        // --- Event handlers ---
        function onCellClick(e, empId, day, dirId) {
          e.stopPropagation();
          var emp = EMPLOYEES.find(function (x) {
            return x.id === empId;
          });
          if (!emp) return;
          state.editingCell = {
            employeeId: empId,
            day: day,
            directionId: dirId,
          };
          document.getElementById('dsModalEmployee').value = emp.name;
          document.getElementById('dsModalDate').value = fmtDate(day);
          document.getElementById('dsModalShift').value =
            getShift(empId, day).shift || '';
          document.getElementById('dsCellModal').classList.add('ds-active');
        }

        function onCellContext(e, empId, day, dirId) {
          e.preventDefault();
          e.stopPropagation();
          state.editingCell = {
            employeeId: empId,
            day: day,
            directionId: dirId,
          };
          var menu = document.getElementById('dsContextMenu');
          menu.style.left = e.clientX + 'px';
          menu.style.top = e.clientY + 'px';

          // Show/hide engage/remove-engage based on current state
          var engKey = empId + '_' + day;
          var hasEng = !!state.engagementData[engKey];
          var engItem = menu.querySelector('[data-action="engage"]');
          var remItem = menu.querySelector('[data-action="remove-engage"]');
          engItem.style.display = hasEng ? 'none' : '';
          remItem.style.display = hasEng ? '' : 'none';

          menu.classList.add('ds-active');
        }

        function closeModal() {
          document.getElementById('dsCellModal').classList.remove('ds-active');
          state.editingCell = null;
        }
        function closeEngModal() {
          document
            .getElementById('dsEngagementModal')
            .classList.remove('ds-active');
        }

        function saveShift() {
          if (!state.editingCell) return;
          var employeeId = state.editingCell.employeeId;
          var day = state.editingCell.day;
          var directionId = state.editingCell.directionId;
          var sv = document.getElementById('dsModalShift').value;
          var err = validateSlot(directionId, day, employeeId, sv);
          if (err) {
            showToast(err, 'error');
            return;
          }
          setShift(employeeId, day, sv);
          closeModal();
          renderGrid();
          showToast('Смена сохранена', 'success');
        }

        function toggleApprove() {
          state.globalApproved = !state.globalApproved;
          if (state.globalApproved) {
            DIRECTIONS.forEach(function (d) {
              d.unlocked = false;
            });
            showToast(
              'График утвержден. Редактирование заблокировано.',
              'info',
            );
          } else {
            DIRECTIONS.forEach(function (d) {
              d.unlocked = true;
            });
            showToast('Утверждение снято. Редактирование разрешено.', 'info');
          }
          updateToolbar();
          renderGrid();
        }

        function toggleDirectionLock(dirId) {
          var dir = DIRECTIONS.find(function (d) {
            return d.id === dirId;
          });
          if (!dir) return;
          dir.unlocked = !dir.unlocked;
          showToast(
            'Направление "' +
              dir.name +
              '" ' +
              (dir.unlocked ? 'разблокировано' : 'заблокировано'),
            'info',
          );
          renderGrid();
        }

        function publishDraft() {
          var c = 0;
          Object.keys(state.draftData).forEach(function (k) {
            state.scheduleData[k] = {
              shift: state.draftData[k].shift,
              draft: false,
            };
            c++;
          });
          state.draftData = {};
          renderGrid();
          showToast('Опубликовано ' + c + ' изменений', 'success');
        }

        function copyPreviousMonth() {
          var dp = getDaysInMonth(
            new Date(
              state.currentMonth.getFullYear(),
              state.currentMonth.getMonth() - 1,
              1,
            ),
          );
          var dc = getDaysInMonth(state.currentMonth);
          var c = 0;
          EMPLOYEES.forEach(function (emp) {
            if (
              state.currentRole === 'specialist' &&
              state.specialistDirection &&
              state.specialistDirection !== emp.directionId
            )
              return;
            for (var d = 1; d <= Math.min(dp, dc); d++) {
              var pd = state.scheduleData[emp.id + '_' + d];
              if (pd && pd.shift) {
                if (state.currentRole === 'specialist')
                  state.draftData[emp.id + '_' + d] = {
                    shift: pd.shift,
                    draft: true,
                  };
                else
                  state.scheduleData[emp.id + '_' + d] = {
                    shift: pd.shift,
                    draft: false,
                  };
                c++;
              }
            }
          });
          renderGrid();
          showToast(
            'Скопировано ' + c + ' смен из предыдущего месяца',
            'success',
          );
        }

        // --- Engagement ---
        function openEngagementModal() {
          if (!state.editingCell) return;
          var emp = EMPLOYEES.find(function (e) {
            return e.id === state.editingCell.employeeId;
          });
          if (!emp) return;
          document.getElementById('dsEngEmployee').value = emp.name;
          document.getElementById('dsEngDate').value = fmtDate(
            state.editingCell.day,
          );
          document.getElementById('dsEngReason').value = '';
          document.getElementById('dsEngEscalation').value = '';
          document
            .getElementById('dsContextMenu')
            .classList.remove('ds-active');
          document
            .getElementById('dsEngagementModal')
            .classList.add('ds-active');
        }

        function saveEngagement() {
          if (!state.editingCell) return;
          var employeeId = state.editingCell.employeeId;
          var day = state.editingCell.day;
          var reason = document.getElementById('dsEngReason').value.trim();
          var escalation = document
            .getElementById('dsEngEscalation')
            .value.trim();
          if (!reason) {
            showToast('Укажите основание привлечения', 'error');
            return;
          }
          var emp = EMPLOYEES.find(function (e) {
            return e.id === employeeId;
          });
          var dir = DIRECTIONS.find(function (d) {
            return d.id === state.editingCell.directionId;
          });
          var ts = fmtDateTime();
          var author =
            state.currentRole === 'manager' ? 'Начальник смены' : 'Специалист';
          state.engagementData[employeeId + '_' + day] = {
            reason: reason,
            escalation: escalation,
            author: author,
            timestamp: ts,
          };
          state.engagementLog.unshift({
            timestamp: ts,
            employee: emp ? emp.name : employeeId,
            direction: dir ? dir.name : '',
            reason: reason,
            escalation: escalation,
            author: author,
          });
          closeEngModal();
          renderGrid();
          showToast('Привлечение отмечено', 'success');
        }

        function removeEngagement() {
          if (!state.editingCell) return;
          var key = state.editingCell.employeeId + '_' + state.editingCell.day;
          delete state.engagementData[key];
          document
            .getElementById('dsContextMenu')
            .classList.remove('ds-active');
          renderGrid();
          showToast('Привлечение снято', 'info');
        }

        // --- Settings ---
        function toggleSettings() {
          var p = document.getElementById('dsSettingsPanel');
          p.classList.toggle('ds-active');
          document
            .getElementById('dsJournalPanel')
            .classList.remove('ds-active');
          if (p.classList.contains('ds-active')) renderSettings();
        }

        function renderSettings() {
          var h = '';
          DIRECTIONS.forEach(function (dir) {
            h +=
              '<div class="ds-setting-card"><h4>' +
              dir.name +
              '</h4>' +
              '<div class="ds-setting-row"><label>Время пересменки</label><input type="time" value="' +
              dir.shiftChangeTime +
              '" style="width:100px;padding:4px 8px;border:1px solid var(--ds-border);border-radius:4px" data-dir="' +
              dir.id +
              '" data-key="shiftChangeTime" class="ds-si" /></div>' +
              '<div class="ds-setting-row"><label>Учитывать «Д» в Итого</label><label class="ds-toggle-switch"><input type="checkbox" ' +
              (dir.countDayShift ? 'checked' : '') +
              ' data-dir="' +
              dir.id +
              '" data-key="countDayShift" class="ds-st" /><span class="ds-toggle-slider"></span></label></div>' +
              '<div class="ds-setting-row"><label>Только будние дни</label><label class="ds-toggle-switch"><input type="checkbox" ' +
              (dir.weekdaysOnly ? 'checked' : '') +
              ' data-dir="' +
              dir.id +
              '" data-key="weekdaysOnly" class="ds-st" /><span class="ds-toggle-slider"></span></label></div>' +
              '<div class="ds-setting-row"><label>Контроль укомплектованности</label><label class="ds-toggle-switch"><input type="checkbox" ' +
              (dir.checkStaffing ? 'checked' : '') +
              ' data-dir="' +
              dir.id +
              '" data-key="checkStaffing" class="ds-st" /><span class="ds-toggle-slider"></span></label></div>' +
              '</div>';
          });
          document.getElementById('dsSettingsContent').innerHTML = h;
          document.querySelectorAll('.ds-si').forEach(function (el) {
            el.addEventListener('change', function (e) {
              var dir = DIRECTIONS.find(function (d) {
                return d.id === e.target.dataset.dir;
              });
              if (dir) {
                dir[e.target.dataset.key] = e.target.value;
                renderGrid();
                showToast('Настройка обновлена', 'success');
              }
            });
          });
          document.querySelectorAll('.ds-st').forEach(function (el) {
            el.addEventListener('change', function (e) {
              var dir = DIRECTIONS.find(function (d) {
                return d.id === e.target.dataset.dir;
              });
              if (dir) {
                dir[e.target.dataset.key] = e.target.checked;
                renderGrid();
                showToast('Настройка обновлена', 'success');
              }
            });
          });
        }

        // --- Journal (Audit + Engagement tabs) ---
        function toggleJournal() {
          var p = document.getElementById('dsJournalPanel');
          p.classList.toggle('ds-active');
          document
            .getElementById('dsSettingsPanel')
            .classList.remove('ds-active');
          if (p.classList.contains('ds-active')) renderJournal();
        }

        function renderJournal() {
          if (state.activeJournalTab === 'audit') renderAudit();
          else renderEngagementLog();
        }

        function renderAudit() {
          var body = document.getElementById('dsAuditBody');
          if (!state.auditLog.length) {
            body.innerHTML =
              '<tr><td colspan="6" style="text-align:center;padding:20px;color:var(--ds-text-light)">Нет записей</td></tr>';
            return;
          }
          body.innerHTML = state.auditLog
            .slice(0, 100)
            .map(function (l) {
              return (
                '<tr><td>' +
                l.timestamp +
                '</td><td>' +
                l.user +
                '</td><td>' +
                l.employee +
                '</td><td>' +
                l.editDate +
                '</td><td>' +
                l.oldValue +
                '</td><td>' +
                l.newValue +
                '</td></tr>'
              );
            })
            .join('');
        }

        function renderEngagementLog() {
          var body = document.getElementById('dsEngagementBody');
          if (!state.engagementLog.length) {
            body.innerHTML =
              '<tr><td colspan="6" style="text-align:center;padding:20px;color:var(--ds-text-light)">Нет записей</td></tr>';
            return;
          }
          body.innerHTML = state.engagementLog
            .slice(0, 100)
            .map(function (l) {
              return (
                '<tr><td>' +
                l.timestamp +
                '</td><td>' +
                l.employee +
                '</td><td>' +
                l.direction +
                '</td><td>' +
                l.reason +
                '</td><td>' +
                (l.escalation || '—') +
                '</td><td>' +
                l.author +
                '</td></tr>'
              );
            })
            .join('');
        }

        // --- Export XLSX ---
        function exportXLSX() {
          var X = window.XLSX;
          if (!X) {
            showToast('XLSX не загружен', 'error');
            return;
          }
          var y = state.currentMonth.getFullYear(),
            m = state.currentMonth.getMonth();
          var days = getDaysInMonth(state.currentMonth);
          var wb = X.utils.book_new();
          var ws = [];
          var merges = [];
          var cw = [
            { wch: 18 },
            { wch: 22 },
            { wch: 16 },
            { wch: 22 },
            { wch: 16 },
            { wch: 8 },
          ];
          for (var d = 1; d <= days; d++) cw.push({ wch: 5 });
          var hr = [
            'Подразделение',
            'Направление',
            'Должность',
            'ФИО',
            'Телефон',
            'Итого',
          ];
          for (var d = 1; d <= days; d++) {
            var dt = new Date(y, m, d);
            hr.push(d + ' ' + DAY_NAMES[dt.getDay()]);
          }
          ws.push(hr);
          var ri = 1;
          DIRECTIONS.forEach(function (dir) {
            var de = EMPLOYEES.filter(function (e) {
              return e.directionId === dir.id;
            });
            var sr = [dir.name + ' (' + dir.mode + ')'];
            for (var i = 1; i < 6 + days; i++) sr.push('');
            ws.push(sr);
            merges.push({ s: { r: ri, c: 0 }, e: { r: ri, c: 5 + days } });
            ri++;
            de.forEach(function (emp) {
              var row = [
                dir.department,
                dir.name,
                emp.position,
                emp.name,
                emp.phone,
              ];
              var fp = [];
              for (var d = 1; d <= days; d++) {
                var s = getShift(emp.id, d);
                row.push(s.shift || '');
                var cl = getExcelCol(6 + d - 1),
                  cr = cl + (ri + 1);
                if (dir.countDayShift)
                  fp.push(
                    'IF(OR(' +
                      cr +
                      '="Д",' +
                      cr +
                      '="Н",' +
                      cr +
                      '="Д/Н"),1,0)',
                  );
                else fp.push('IF(OR(' + cr + '="Н",' + cr + '="Д/Н"),1,0)');
              }
              row.splice(5, 0, { f: fp.join('+') });
              ws.push(row);
              ri++;
            });
          });
          var sheet = X.utils.aoa_to_sheet(ws);
          sheet['!cols'] = cw;
          sheet['!merges'] = merges;
          if (!sheet['!views']) sheet['!views'] = [{}];
          sheet['!views'][0] = { state: 'frozen', xSplit: 6, ySplit: 1 };
          X.utils.book_append_sheet(wb, sheet, MONTH_NAMES[m] + ' ' + y);
          X.writeFile(
            wb,
            'График_дежурств_' + MONTH_NAMES[m] + '_' + y + '.xlsx',
          );
          showToast('Файл XLSX экспортирован', 'success');
        }

        // --- Init ---
        var now = new Date();
        var mp = document.getElementById('dsMonthPicker');
        mp.value =
          now.getFullYear() + '-' + String(now.getMonth() + 1).padStart(2, '0');
        state.currentMonth = new Date(now.getFullYear(), now.getMonth(), 1);

        var df = document.getElementById('dsDirectionFilter');
        DIRECTIONS.forEach(function (d) {
          var o = document.createElement('option');
          o.value = d.id;
          o.textContent = d.name;
          df.appendChild(o);
        });

        generateDemoData();

        // Bind events
        mp.addEventListener('change', function (e) {
          var parts = e.target.value.split('-');
          state.currentMonth = new Date(
            parseInt(parts[0]),
            parseInt(parts[1]) - 1,
            1,
          );
          generateDemoData();
          renderGrid();
        });
        document
          .getElementById('dsRoleSelect')
          .addEventListener('change', function (e) {
            state.currentRole = e.target.value;
            updateToolbar();
            renderGrid();
          });
        df.addEventListener('change', function (e) {
          state.specialistDirection = e.target.value;
          renderGrid();
        });

        document
          .getElementById('dsBtnSettings')
          .addEventListener('click', toggleSettings);
        document
          .getElementById('dsBtnCloseSettings')
          .addEventListener('click', toggleSettings);
        document
          .getElementById('dsBtnJournal')
          .addEventListener('click', toggleJournal);
        document
          .getElementById('dsBtnCloseJournal')
          .addEventListener('click', toggleJournal);
        document
          .getElementById('dsBtnExport')
          .addEventListener('click', exportXLSX);
        document
          .getElementById('dsBtnApprove')
          .addEventListener('click', toggleApprove);
        document
          .getElementById('dsBtnPublish')
          .addEventListener('click', publishDraft);
        document
          .getElementById('dsBtnCopyMonth')
          .addEventListener('click', copyPreviousMonth);
        document
          .getElementById('dsBtnCancelModal')
          .addEventListener('click', closeModal);
        document
          .getElementById('dsBtnSaveShift')
          .addEventListener('click', saveShift);
        document
          .getElementById('dsBtnCancelEng')
          .addEventListener('click', closeEngModal);
        document
          .getElementById('dsBtnSaveEng')
          .addEventListener('click', saveEngagement);

        // Journal tabs
        document
          .querySelectorAll('#dsJournalTabs .ds-tab-btn')
          .forEach(function (btn) {
            btn.addEventListener('click', function () {
              document
                .querySelectorAll('#dsJournalTabs .ds-tab-btn')
                .forEach(function (b) {
                  b.classList.remove('ds-tab-active');
                });
              btn.classList.add('ds-tab-active');
              var tab = btn.getAttribute('data-tab');
              state.activeJournalTab = tab;
              document.getElementById('dsJournalAuditContent').style.display =
                tab === 'audit' ? '' : 'none';
              document.getElementById(
                'dsJournalEngagementContent',
              ).style.display = tab === 'engagement' ? '' : 'none';
              renderJournal();
            });
          });

        // Context menu
        document
          .getElementById('dsContextMenu')
          .addEventListener('click', function (e) {
            var action = e.target.dataset ? e.target.dataset.action : null;
            if (!action || !state.editingCell) return;
            var employeeId = state.editingCell.employeeId;
            var day = state.editingCell.day;
            var directionId = state.editingCell.directionId;
            if (action === 'engage') {
              openEngagementModal();
              return;
            }
            if (action === 'remove-engage') {
              removeEngagement();
              return;
            }
            var sv = '';
            if (action === 'set-d') sv = 'Д';
            else if (action === 'set-n') sv = 'Н';
            else if (action === 'set-dn') sv = 'Д/Н';
            var err = validateSlot(directionId, day, employeeId, sv);
            if (err) {
              showToast(err, 'error');
              return;
            }
            setShift(employeeId, day, sv);
            renderGrid();
            showToast('Смена обновлена', 'success');
            document
              .getElementById('dsContextMenu')
              .classList.remove('ds-active');
          });

        document.addEventListener('click', function () {
          document
            .getElementById('dsContextMenu')
            .classList.remove('ds-active');
        });

        var fl = document.getElementById('dsFrozenLeft');
        var sr = document.getElementById('dsScrollRight');
        sr.addEventListener('scroll', function () {
          fl.scrollTop = sr.scrollTop;
        });

        renderGrid();
        updateToolbar();
      })();
    </script>
  </body>
</html>
