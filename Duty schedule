
<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Интеллектуальный график дежурств S1</title>
<script src="https://cdn.sheetjs.com/xlsx-0.20.3/package/dist/xlsx.full.min.js"></script>
<style>
:root {
  --ds-primary: #1a73e8; --ds-primary-hover: #1557b0;
  --ds-bg: #f5f6fa; --ds-white: #ffffff; --ds-border: #d0d5dd;
  --ds-text: #1d2939; --ds-text-light: #667085;
  --ds-shift-d: #fff9c4; --ds-shift-n: #c8e6ff; --ds-shift-dn-d: #fff9c4; --ds-shift-dn-n: #c8e6ff;
  --ds-today: rgba(26,115,232,0.08); --ds-today-header: rgba(26,115,232,0.18);
  --ds-weekend: #fce4ec; --ds-weekend-text: #c62828;
  --ds-hole: #ff9800; --ds-section-bg: #e8eaf6;
  --ds-approved: #4caf50; --ds-draft: #ff9800;
  --ds-focus: #ffe0e6;
  --ds-frozen-w: 780px; --ds-row-h: 36px; --ds-hdr-h: 52px; --ds-sec-h: 34px; --ds-cell-w: 42px;
}
* { margin:0; padding:0; box-sizing:border-box; }
body { font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'Helvetica Neue',Arial,sans-serif; background:var(--ds-bg); color:var(--ds-text); font-size:13px; line-height:1.4; overflow:hidden; }

.ds-toolbar { display:flex; align-items:center; gap:12px; padding:10px 16px; background:var(--ds-white); border-bottom:1px solid var(--ds-border); position:sticky; top:0; z-index:1000; flex-wrap:wrap; }
.ds-toolbar h1 { font-size:16px; font-weight:600; margin-right:16px; white-space:nowrap; }
.ds-toolbar select,.ds-toolbar input[type="month"] { padding:6px 10px; border:1px solid var(--ds-border); border-radius:6px; font-size:13px; background:var(--ds-white); cursor:pointer; }
.ds-toolbar .ds-spacer { flex:1; }

.ds-btn { padding:7px 14px; border:none; border-radius:6px; font-size:13px; font-weight:500; cursor:pointer; transition:all .15s; display:inline-flex; align-items:center; gap:5px; white-space:nowrap; }
.ds-btn-primary { background:var(--ds-primary); color:#fff; } .ds-btn-primary:hover { background:var(--ds-primary-hover); }
.ds-btn-success { background:var(--ds-approved); color:#fff; } .ds-btn-success:hover { background:#388e3c; }
.ds-btn-warning { background:var(--ds-draft); color:#fff; } .ds-btn-warning:hover { background:#f57c00; }
.ds-btn-outline { background:var(--ds-white); color:var(--ds-text); border:1px solid var(--ds-border); } .ds-btn-outline:hover { background:#f0f1f3; }
.ds-btn:disabled { opacity:.5; cursor:not-allowed; }

.ds-role-badge { padding:4px 10px; border-radius:12px; font-size:11px; font-weight:600; text-transform:uppercase; }
.ds-role-badge.manager { background:#e8f5e9; color:#2e7d32; } .ds-role-badge.specialist { background:#e3f2fd; color:#1565c0; }
.ds-status-indicator { padding:4px 10px; border-radius:12px; font-size:11px; font-weight:600; }
.ds-status-indicator.approved { background:#e8f5e9; color:#2e7d32; }
.ds-status-indicator.draft { background:#fff3e0; color:#e65100; }
.ds-status-indicator.open { background:#e3f2fd; color:#1565c0; }

.ds-grid-wrapper { position:relative; overflow:hidden; margin:0; background:var(--ds-white); height:calc(100vh - 52px); }
.ds-frozen-left { position:absolute; top:0; left:0; width:var(--ds-frozen-w); height:100%; overflow:hidden; z-index:10; background:var(--ds-white); border-right:2px solid var(--ds-border); }
.ds-frozen-left .ds-header-row { position:sticky; top:0; z-index:12; background:var(--ds-white); }
.ds-scroll-right { position:absolute; top:0; left:var(--ds-frozen-w); right:0; height:100%; overflow:auto; z-index:5; }
.ds-scroll-right .ds-header-row { position:sticky; top:0; z-index:8; background:var(--ds-white); }

table { border-collapse:collapse; table-layout:fixed; }
.ds-frozen-left table { width:var(--ds-frozen-w); }
th, td { border:1px solid var(--ds-border); text-align:center; vertical-align:middle; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }

.ds-header-row th { background:#f8f9fc; font-weight:600; font-size:12px; padding:4px 2px; height:var(--ds-hdr-h); position:sticky; top:0; z-index:5; cursor:default; }
.ds-header-row th .ds-day-num { font-size:14px; font-weight:700; display:block; }
.ds-header-row th .ds-day-name { font-size:10px; color:var(--ds-text-light); display:block; }
.ds-header-row th.ds-weekend { background:var(--ds-weekend); }
.ds-header-row th.ds-weekend .ds-day-num,.ds-header-row th.ds-weekend .ds-day-name { color:var(--ds-weekend-text); }
.ds-header-row th.ds-today-col { background:var(--ds-today-header); }
.ds-header-row th.ds-hole { background:var(--ds-hole) !important; color:#fff !important; }
.ds-header-row th.ds-hole .ds-day-name { color:#fff !important; }
.ds-header-row th.ds-holiday-custom { background:#ffcdd2 !important; }
.ds-header-row th.ds-holiday-custom .ds-day-num { color:#c62828 !important; }
.ds-header-row th.ds-holiday-custom .ds-day-name { color:#c62828 !important; }
.ds-header-row th.ds-clickable-header { cursor:pointer; }
.ds-header-row th.ds-clickable-header:hover { outline:2px solid #c62828; outline-offset:-2px; }

.ds-col-dept { width:120px; text-align:left; padding:0 6px; }
.ds-col-dir { width:130px; text-align:left; padding:0 6px; }
.ds-col-pos { width:120px; text-align:left; padding:0 6px; }
.ds-col-name { width:170px; text-align:left; padding:0 6px; font-weight:500; }
.ds-col-phone { width:120px; text-align:left; padding:0 6px; }
.ds-col-total { width:60px; font-weight:700; font-size:14px; }

.ds-data-row td { height:var(--ds-row-h); padding:2px; cursor:default; font-size:12px; position:relative; }
.ds-data-row td.ds-editable { cursor:pointer; }
.ds-data-row td.ds-editable:hover { outline:2px solid var(--ds-primary); outline-offset:-2px; }
.ds-data-row td.ds-shift-d { background:var(--ds-shift-d); font-weight:500; }
.ds-data-row td.ds-shift-n { background:var(--ds-shift-n); font-weight:500; }
.ds-data-row td.ds-shift-dn { background:linear-gradient(135deg, var(--ds-shift-dn-d) 50%, var(--ds-shift-dn-n) 50%); font-weight:500; }
.ds-data-row td.ds-today-col { background:var(--ds-today); }
.ds-data-row td.ds-shift-d.ds-today-col { background:linear-gradient(135deg, var(--ds-shift-d) 50%, var(--ds-today) 50%); }
.ds-data-row td.ds-shift-n.ds-today-col { background:linear-gradient(135deg, var(--ds-shift-n) 50%, var(--ds-today) 50%); }
.ds-data-row td.ds-shift-dn.ds-today-col { background:linear-gradient(135deg, var(--ds-shift-dn-d) 33%, var(--ds-shift-dn-n) 33% 66%, var(--ds-today) 66%); }
.ds-data-row td.ds-past { opacity:.6; }
.ds-data-row td.ds-locked { cursor:not-allowed; }
.ds-data-row td.ds-draft-cell { border:2px dashed var(--ds-draft); }
.ds-data-row td.ds-weekend-cell { background:#fafafa; }
.ds-data-row td.ds-focus-cell { background:var(--ds-focus) !important; box-shadow:inset 0 0 0 2px #e91e63; }
.ds-day-cell { width:var(--ds-cell-w); min-width:var(--ds-cell-w); max-width:var(--ds-cell-w); }

.ds-alert-badge { position:absolute; top:1px; right:1px; font-size:9px; color:#d32f2f; font-weight:700; cursor:help; line-height:1; }

.ds-section-row td { height:var(--ds-sec-h); background:var(--ds-section-bg); font-weight:600; font-size:13px; text-align:left; padding:0 12px; color:#3949ab; border-bottom:2px solid #c5cae9; }
.ds-section-row .ds-section-title { display:flex; align-items:center; gap:8px; }
.ds-section-row .ds-section-mode { font-weight:400; font-size:11px; color:var(--ds-text-light); margin-left:8px; }
.ds-section-row .ds-unlock-btn { margin-left:auto; padding:2px 8px; font-size:11px; border-radius:4px; background:#fff; border:1px solid var(--ds-border); cursor:pointer; color:var(--ds-text); }
.ds-section-row .ds-unlock-btn:hover { background:#f0f1f3; }

.ds-modal-overlay { display:none; position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,.4); z-index:2000; justify-content:center; align-items:center; }
.ds-modal-overlay.ds-active { display:flex; }
.ds-modal { background:var(--ds-white); border-radius:12px; padding:24px; min-width:320px; max-width:500px; box-shadow:0 20px 60px rgba(0,0,0,.2); }
.ds-modal h3 { margin-bottom:16px; font-size:16px; }
.ds-modal .ds-form-group { margin-bottom:12px; }
.ds-modal label { display:block; font-size:12px; font-weight:600; margin-bottom:4px; color:var(--ds-text-light); }
.ds-modal select,.ds-modal input,.ds-modal textarea { width:100%; padding:8px 10px; border:1px solid var(--ds-border); border-radius:6px; font-size:13px; font-family:inherit; }
.ds-modal textarea { resize:vertical; min-height:60px; }
.ds-modal .ds-btn-row { display:flex; gap:8px; justify-content:flex-end; margin-top:16px; }

.ds-panel { display:none; position:fixed; top:0; right:0; bottom:0; width:520px; background:var(--ds-white); box-shadow:-4px 0 20px rgba(0,0,0,.1); z-index:1500; overflow-y:auto; padding:24px; }
.ds-panel.ds-active { display:block; }
.ds-panel h2 { font-size:18px; margin-bottom:16px; }
.ds-panel-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; }
.ds-tab-bar { display:flex; gap:0; margin-bottom:16px; border-bottom:2px solid var(--ds-border); }
.ds-tab-btn { padding:8px 16px; border:none; background:none; font-size:13px; font-weight:500; cursor:pointer; border-bottom:2px solid transparent; margin-bottom:-2px; color:var(--ds-text-light); }
.ds-tab-btn.ds-tab-active { color:var(--ds-primary); border-bottom-color:var(--ds-primary); }
.ds-tab-btn:hover { color:var(--ds-text); }

.ds-setting-card { background:#f8f9fc; border-radius:8px; padding:16px; margin-bottom:12px; }
.ds-setting-card h4 { margin-bottom:10px; color:#3949ab; }
.ds-setting-row { display:flex; align-items:center; justify-content:space-between; margin-bottom:8px; font-size:13px; }
.ds-setting-row label { margin-bottom:0; }
.ds-toggle-switch { position:relative; width:40px; height:22px; }
.ds-toggle-switch input { opacity:0; width:0; height:0; }
.ds-toggle-slider { position:absolute; cursor:pointer; top:0; left:0; right:0; bottom:0; background:#ccc; border-radius:22px; transition:.3s; }
.ds-toggle-slider:before { content:''; position:absolute; height:16px; width:16px; left:3px; bottom:3px; background:white; border-radius:50%; transition:.3s; }
.ds-toggle-switch input:checked+.ds-toggle-slider { background:var(--ds-primary); }
.ds-toggle-switch input:checked+.ds-toggle-slider:before { transform:translateX(18px); }

.ds-audit-table { width:100%; font-size:12px; border-collapse:collapse; }
.ds-audit-table th { background:#f8f9fc; padding:8px 6px; text-align:left; border-bottom:1px solid var(--ds-border); }
.ds-audit-table td { padding:6px; border-bottom:1px solid #eee; text-align:left; }

.ds-toast-container { position:fixed; bottom:20px; right:20px; z-index:3000; display:flex; flex-direction:column; gap:8px; }
.ds-toast { padding:10px 16px; border-radius:8px; color:#fff; font-size:13px; font-weight:500; animation:dsSlideIn .3s ease; max-width:350px; }
.ds-toast.success { background:#4caf50; } .ds-toast.error { background:#f44336; } .ds-toast.info { background:#2196f3; }
@keyframes dsSlideIn { from{transform:translateX(100%);opacity:0} to{transform:translateX(0);opacity:1} }

.ds-context-menu { display:none; position:fixed; background:var(--ds-white); border:1px solid var(--ds-border); border-radius:8px; box-shadow:0 4px 16px rgba(0,0,0,.12); z-index:2500; min-width:200px; padding:4px 0; }
.ds-context-menu.ds-active { display:block; }
.ds-context-menu-item { padding:8px 16px; cursor:pointer; font-size:13px; transition:background .1s; }
.ds-context-menu-item:hover { background:#f0f1f3; }
.ds-context-menu-item.danger { color:#f44336; }
.ds-context-menu-item.ds-separator { border-top:1px solid var(--ds-border); margin-top:4px; padding-top:8px; }

.ds-tooltip { position:fixed; background:#333; color:#fff; padding:8px 12px; border-radius:6px; font-size:11px; line-height:1.5; z-index:4000; pointer-events:none; max-width:300px; box-shadow:0 4px 12px rgba(0,0,0,.3); }
</style>
</head>
<body>

<div class="ds-toolbar">
  <h1>📋 График дежурств</h1>
  <input type="month" class="ds-month-picker" />
  <select class="ds-role-select">
    <option value="manager">Начальник смены</option>
    <option value="specialist">Специалист направления</option>
  </select>
  <select class="ds-direction-filter" style="display: 'none'"><option value="">— Направление —</option></select>
  <span class="ds-role-badge manager ds-role-badge-el">Начальник смены</span>
  <span class="ds-status-indicator open ds-status-badge-el">Открыт</span>
  <div class="ds-spacer"></div>
  <button class="ds-btn ds-btn-outline ds-btn-copy-month" style="display: 'none'">📄 Копировать месяц</button>
  <button class="ds-btn ds-btn-warning ds-btn-publish" style="display: 'none'">📢 Опубликовать</button>
  <button class="ds-btn ds-btn-success ds-btn-approve">✅ Утвердить график</button>
  <button class="ds-btn ds-btn-outline ds-btn-settings">⚙️ Настройки</button>
  <button class="ds-btn ds-btn-outline ds-btn-journal">📜 Журнал</button>
  <button class="ds-btn ds-btn-primary ds-btn-export">📥 Экспорт XLSX</button>
</div>
<div class="ds-grid-wrapper">
  <div class="ds-frozen-left"></div>
  <div class="ds-scroll-right"></div>
</div>

<div class="ds-panel ds-settings-panel">
  <div class="ds-panel-header"><h2>⚙️ Настройки направлений</h2><button class="ds-btn ds-btn-outline ds-btn-close-settings">✕ Закрыть</button></div>
  <div class="ds-settings-content"></div>
</div>

<div class="ds-panel ds-journal-panel" style="width:600px">
  <div class="ds-panel-header"><h2>📜 Журналы</h2><button class="ds-btn ds-btn-outline ds-btn-close-journal">✕ Закрыть</button></div>
  <div class="ds-tab-bar ds-journal-tabs">
    <button class="ds-tab-btn ds-tab-active" data-tab="audit">Журнал изменений</button>
    <button class="ds-tab-btn" data-tab="engagement">Журнал привлечений</button>
  </div>
  <div class="ds-journal-audit-content">
    <table class="ds-audit-table"><thead><tr><th>Дата/Время</th><th>Пользователь</th><th>Сотрудник</th><th>Ред.Дата</th><th>Было</th><th>Стало</th></tr></thead><tbody class="ds-audit-body"></tbody></table>
  </div>
  <div class="ds-journal-engagement-content" style="display: 'none'">
    <table class="ds-audit-table"><thead><tr><th>Дата/Время</th><th>ФИО</th><th>Направление</th><th>Основание</th><th>Эскалация</th><th>Автор</th></tr></thead><tbody class="ds-engagement-body"></tbody></table>
  </div>
</div>

<div class="ds-modal-overlay ds-cell-modal">
  <div class="ds-modal">
    <h3 class="ds-modal-title">Редактирование смены</h3>
    <div class="ds-form-group"><label>Сотрудник</label><input type="text" class="ds-modal-employee" readonly /></div>
    <div class="ds-form-group"><label>Дата</label><input type="text" class="ds-modal-date" readonly /></div>
    <div class="ds-form-group"><label>Тип смены</label>
      <select class="ds-modal-shift"><option value="">— Нет смены —</option><option value="Д">Д (Дневная)</option><option value="Н">Н (Ночная)</option><option value="Д/Н">Д/Н (Суточная)</option></select>
    </div>
    <div class="ds-btn-row"><button class="ds-btn ds-btn-outline ds-btn-cancel-modal">Отмена</button><button class="ds-btn ds-btn-primary ds-btn-save-shift">Сохранить</button></div>
  </div>
</div>

<div class="ds-modal-overlay ds-engagement-modal">
  <div class="ds-modal">
    <h3>Внеплановое привлечение</h3>
    <div class="ds-form-group"><label>Сотрудник</label><input type="text" class="ds-eng-employee" readonly /></div>
    <div class="ds-form-group"><label>Дата</label><input type="text" class="ds-eng-date" readonly /></div>
    <div class="ds-form-group"><label>Основание</label><textarea class="ds-eng-reason" placeholder="Укажите основание привлечения..."></textarea></div>
    <div class="ds-form-group"><label>Эскалация</label><textarea class="ds-eng-escalation" placeholder="Описание эскалации (свободный текст)..."></textarea></div>
    <div class="ds-btn-row"><button class="ds-btn ds-btn-outline ds-btn-cancel-eng">Отмена</button><button class="ds-btn ds-btn-primary ds-btn-save-eng">Сохранить</button></div>
  </div>
</div>

<div class="ds-context-menu">
  <div class="ds-context-menu-item" data-action="set-d">Поставить «Д»</div>
  <div class="ds-context-menu-item" data-action="set-n">Поставить «Н»</div>
  <div class="ds-context-menu-item" data-action="set-dn">Поставить «Д/Н»</div>
  <div class="ds-context-menu-item danger" data-action="clear">Очистить</div>
  <div class="ds-context-menu-item ds-separator" data-action="engage">⚡ Отметить привлечение</div>
  <div class="ds-context-menu-item danger" data-action="remove-engage">✕ Снять привлечение</div>
</div>

<div class="ds-toast-container"></div>
<div class="ds-tooltip" style="display: 'none'"></div>

